---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Do I Need GST Registration? Aggregate Turnover & Threshold Checker';
const description = 'Free offline GST threshold checker. Calculate your aggregate turnover to see if you cross the ₹20L/₹40L limit and need GST registration in India.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Aggregate Turnover Calculator',
    url: `${Astro.site?.toString() ?? 'https://example.com'}/aggregate-turnover-calculator`,
    description: description,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What is Aggregate Annual Turnover (AATO) under GST?', acceptedAnswer: { '@type': 'Answer', text: 'Aggregate Annual Turnover (AATO) is the sum of all taxable supplies, exempt supplies, and exports (zero-rated supplies) made by a person on a PAN-India basis under the same PAN, excluding taxes charged under CGST, SGST, IGST, and UTGST.' } },
      { '@type': 'Question', name: 'What is the GST registration threshold in 2026 for normal states?', acceptedAnswer: { '@type': 'Answer', text: 'For businesses supplying only goods in normal states, the mandatory registration threshold is ₹40 Lakhs. For service providers or mixed suppliers in normal states, the limit is ₹20 Lakhs.' } },
      { '@type': 'Question', name: 'What is the GST threshold for special category states?', acceptedAnswer: { '@type': 'Answer', text: 'Special category states have reduced thresholds. States like Arunachal Pradesh and Uttarakhand have a ₹20 Lakh limit, while states like Manipur, Mizoram, and Tripura have a ₹10 Lakh limit.' } },
      { '@type': 'Question', name: 'Does inter-state supply mandate GST registration regardless of turnover?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. If you supply goods across state borders (inter-state), GST registration is mandatory regardless of your annual turnover. This rule applies to goods; for interstate supply of services, you still get the turnover threshold.' } },
      { '@type': 'Question', name: 'Are exports included in aggregate turnover for GST purposes?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Exports (zero-rated supplies) are included in the aggregate turnover calculation even though they are taxed at 0%. This may push you above the registration threshold even if your domestic taxable turnover is low.' } },
      { '@type': 'Question', name: 'What is the Composition Scheme turnover limit in 2026?', acceptedAnswer: { '@type': 'Answer', text: 'For manufacturers and traders (goods suppliers), the Composition Scheme limit is ₹1.5 Crore in normal states and ₹75 Lakhs in special category states. For service providers, the limit is ₹50 Lakhs flat, regardless of state.' } },
      { '@type': 'Question', name: 'Can a business with inter-state supplies opt for the Composition Scheme?', acceptedAnswer: { '@type': 'Answer', text: 'No. A business making inter-state outward supplies cannot opt for the Composition Scheme under Section 10 of the CGST Act. This is an absolute restriction.' } },
      { '@type': 'Question', name: 'Are exempt supplies counted towards the Composition Scheme limit?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Exempt supplies are included in your aggregate turnover when evaluating whether you exceed the Composition Scheme limit, even though no tax is charged on them.' } },
      { '@type': 'Question', name: 'Does inter-state supply of services mandate registration?', acceptedAnswer: { '@type': 'Answer', text: 'Service providers making inter-state supplies are eligible for the standard turnover-based threshold. Unlike goods suppliers, they do not face mandatory registration solely because of inter-state supply unless their aggregate turnover crosses the ₹20 Lakh limit.' } },
      { '@type': 'Question', name: 'What happens if I cross the threshold mid-year?', acceptedAnswer: { '@type': 'Answer', text: 'If your aggregate turnover crosses the mandatory threshold during the financial year, you must apply for GST registration within 30 days from the day you exceeded the limit. Any supplies made after crossing the threshold without registration attract penalties.' } },
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-12 text-center">
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-[-1.28px] text-base mb-4">Aggregate Turnover & GST Threshold Checker</h1>
      <p class="text-[16px] text-muted max-w-2xl mx-auto leading-relaxed">
        <strong>Are you required to register for GST?</strong> Enter your sales details below to instantly calculate your Aggregate Annual Turnover (AATO) and check your mandatory registration and Composition Scheme eligibility.
      </p>
    </div>

    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
      <!-- Input Section -->
      <div class="rounded-[8px] border border-base bg-surface p-[24px] shadow-[0_2px_2px_#0000000a,0_8px_8px_-8px_#0000000a] space-y-6">
        
        <div>
          <label class="block text-[14px] font-medium text-base mb-2">Nature of Business</label>
          <div class="grid grid-cols-3 gap-3" role="group">
            <button type="button" id="btn-goods" class="biz-type-btn rounded-[8px] border border-accent bg-accent text-white py-2.5 text-[14px] font-medium transition-colors active:scale-95" data-type="goods">Goods Only</button>
            <button type="button" id="btn-services" class="biz-type-btn rounded-[8px] border border-base bg-subtle text-muted hover:border-accent hover:text-base py-2.5 text-[14px] font-medium transition-colors active:scale-95" data-type="services">Services Only</button>
            <button type="button" id="btn-both" class="biz-type-btn rounded-[8px] border border-base bg-subtle text-muted hover:border-accent hover:text-base py-2.5 text-[14px] font-medium transition-colors active:scale-95" data-type="both">Both</button>
          </div>
        </div>

        <div>
          <label for="state-category" class="block text-[14px] font-medium text-base mb-2">State Category</label>
          <select id="state-category" class="w-full rounded-[8px] border border-base bg-subtle px-4 py-3 text-[16px] focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all cursor-pointer">
            <option value="normal">Normal States (e.g., Maharashtra, Delhi, Gujarat)</option>
            <option value="special20">Special Category (e.g., Arunachal Pradesh, Uttarakhand) - ₹20L Limit</option>
            <option value="special10">Special Category (e.g., Manipur, Mizoram, Tripura) - ₹10L Limit</option>
          </select>
        </div>

        <div class="space-y-4 pt-4 border-t border-base">
          <div>
            <label for="val-taxable" class="block text-[13px] font-medium text-base mb-1">Taxable Supplies (₹)</label>
            <input id="val-taxable" type="number" min="0" placeholder="0" class="w-full rounded-[8px] border border-base bg-subtle px-3 py-2 text-[15px] focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label for="val-exempt" class="block text-[13px] font-medium text-base mb-1">Exempt & Nil-Rated Supplies (₹)</label>
            <input id="val-exempt" type="number" min="0" placeholder="0" class="w-full rounded-[8px] border border-base bg-subtle px-3 py-2 text-[15px] focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label for="val-export" class="block text-[13px] font-medium text-base mb-1">Exports (Zero-Rated) (₹)</label>
            <input id="val-export" type="number" min="0" placeholder="0" class="w-full rounded-[8px] border border-base bg-subtle px-3 py-2 text-[15px] focus:border-accent focus:outline-none" />
          </div>
          <div>
            <label for="val-interstate" class="block text-[13px] font-medium text-base mb-1">Inter-State Supplies (Out of State) (₹)</label>
            <input id="val-interstate" type="number" min="0" placeholder="0" class="w-full rounded-[8px] border border-base bg-subtle px-3 py-2 text-[15px] focus:border-accent focus:outline-none" />
          </div>
        </div>

        <button id="btn-reset" type="button" class="w-full rounded-[8px] border border-base py-3 text-[14px] font-medium text-muted hover:text-base hover:bg-subtle transition-all mt-4">
          Reset Fields
        </button>
      </div>

      <!-- Results Section -->
      <div class="rounded-[8px] border border-base bg-subtle p-[24px] space-y-6">
        <h2 class="text-[20px] font-semibold text-base tracking-[-0.6px]">Your GST Status</h2>
        
        <div class="flex justify-between items-center py-4 border-b border-base">
          <span class="text-[16px] font-medium">Aggregate Turnover</span>
          <span class="text-[28px] font-bold text-accent" id="res-total">₹0</span>
        </div>

        <div class="space-y-4">
          <div class="rounded-[8px] border border-base bg-surface p-4">
            <div class="flex items-start gap-3">
              <div id="icon-reg" class="mt-0.5 text-2xl">⚪</div>
              <div>
                <h3 class="font-semibold text-[15px] text-base" id="title-reg">Registration Status</h3>
                <p class="text-[13px] text-muted mt-1" id="desc-reg">Enter your supplies to see if you need to register.</p>
              </div>
            </div>
          </div>

          <div class="rounded-[8px] border border-base bg-surface p-4">
            <div class="flex items-start gap-3">
              <div id="icon-comp" class="mt-0.5 text-2xl">⚪</div>
              <div>
                <h3 class="font-semibold text-[15px] text-base" id="title-comp">Composition Scheme</h3>
                <p class="text-[13px] text-muted mt-1" id="desc-comp">Enter your supplies to check eligibility.</p>
              </div>
            </div>
          </div>
        </div>

        <div class="mt-6 rounded-[6px] bg-[#d3e5ff]/20 dark:bg-[#d3e5ff]/5 border border-[#d3e5ff]/50 p-4 text-[12px] text-muted">
          <p><strong>Note:</strong> Aggregate Turnover includes all supplies (taxable + exempt + exports + inter-state) made under the same PAN across all branches in India.</p>
        </div>
      </div>
    </div>
  </div>

  
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/gst-on-property-real-estate-india" class="text-primary hover:underline">GST on Property & Real Estate in India 2025: Complete Buyer & Builder Guide</a></li>
        <li><a href="/blog/mrp-revision-gst-rate-change" class="text-primary hover:underline">How to Revise MRP After GST Rate Change in 2026 — Step by Step</a></li>
      </ul>
    </div>
  </div>
<!-- FAQ Section -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16">
    <div class="border-t border-base pt-12">
      <h2 class="text-[28px] tracking-[-1px] font-semibold text-base mb-2">Frequently Asked Questions</h2>
      <p class="text-muted text-[15px] mb-8">Everything you need to know about GST registration thresholds and aggregate turnover.</p>
      <div class="space-y-3" id="faq-list">
        {[
          { q: 'What is Aggregate Annual Turnover (AATO) under GST?', a: 'AATO is the total value of all taxable supplies, exempt supplies, and exports made by a person under the same PAN across all states in India, excluding the GST amount itself. It is calculated on a financial year basis and is the key metric used to determine registration obligations.' },
          { q: 'What is the GST registration threshold for normal states in 2026?', a: 'For businesses supplying only goods in normal states (like Maharashtra, Delhi, Karnataka), the threshold is ₹40 Lakhs. For service providers or mixed suppliers, the threshold is ₹20 Lakhs. Crossing either limit during the financial year makes registration mandatory.' },
          { q: 'Does making even one inter-state goods sale mandate GST registration?', a: 'Yes, absolutely. If you supply goods to a buyer in another state, GST registration is mandatory from day one regardless of your total turnover. Even a single invoice of ₹1,000 for an inter-state goods sale triggers this requirement.' },
          { q: 'Are exports included in the aggregate turnover calculation?', a: 'Yes. Exports (zero-rated supplies) are fully included in the aggregate turnover calculation even though they are taxed at 0%. This means your exports could push you above the registration threshold even if your domestic business is small.' },
          { q: 'What is the Composition Scheme limit for goods suppliers in 2026?', a: 'For manufacturers and traders of goods in normal states, the Composition Scheme turnover limit is ₹1.5 Crore. In special category states (North-East, Himachal Pradesh), this drops to ₹75 Lakhs. You must opt in before the financial year begins.' },
          { q: 'Can service providers opt for the Composition Scheme?', a: 'Yes, but with a much lower limit. Service providers can opt for the Composition Scheme only if their aggregate turnover does not exceed ₹50 Lakhs. They pay a flat 6% tax (3% CGST + 3% SGST) and file Form CMP-08 quarterly.' },
          { q: 'Can I opt for Composition Scheme if I sell on Amazon or Flipkart?', a: 'No. E-commerce sellers who sell through operators (like Amazon/Flipkart) that collect TCS are not eligible for the Composition Scheme. This is an explicit exclusion under Section 10(2) of the CGST Act.' },
          { q: 'Does exempt supply count towards the Composition Scheme limit?', a: 'Yes. All supplies — taxable, exempt, and zero-rated — are included in aggregate turnover for both the registration threshold and the Composition Scheme limit check.' },
          { q: 'What is the GST registration threshold for special category states like Manipur?', a: 'States like Manipur, Mizoram, Nagaland, Sikkim, and Tripura have a reduced threshold of ₹10 Lakhs for mandatory GST registration. States like Uttarakhand, Arunachal Pradesh, and Meghalaya have a ₹20 Lakh limit.' },
          { q: 'If I cross the registration threshold, how many days do I have to register?', a: 'You have 30 days from the date your aggregate turnover first exceeds the threshold to apply for GST registration. Supplies made after crossing the limit without registration attract a penalty of 10% of the tax amount or ₹10,000, whichever is higher.' },
        ].map((faq, i) => (
          <details class="group rounded-[8px] border border-base bg-surface overflow-hidden" id={`faq-atc-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span class="text-[15px]">{faq.q}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[14px] text-muted leading-relaxed border-t border-base pt-4">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
let bizType = "goods";
const typeBtns = document.querySelectorAll(".biz-type-btn");
const stateCatSelect = document.getElementById("state-category");
const inTaxable = document.getElementById("val-taxable");
const inExempt = document.getElementById("val-exempt");
const inExport = document.getElementById("val-export");
const inInterstate = document.getElementById("val-interstate");
const btnReset = document.getElementById("btn-reset");
const resTotal = document.getElementById("res-total");
const iconReg = document.getElementById("icon-reg");
const titleReg = document.getElementById("title-reg");
const descReg = document.getElementById("desc-reg");
const iconComp = document.getElementById("icon-comp");
const titleComp = document.getElementById("title-comp");
const descComp = document.getElementById("desc-comp");
function formatINR(val) {
  return "\u20B9" + val.toLocaleString("en-IN", { maximumFractionDigits: 0 });
}
function formatThreshold(val) {
  if (val >= 1e7) return `\u20B9${(val / 1e7).toFixed(1)} Crore`;
  return `\u20B9${val / 1e5} Lakh`;
}
function calculate() {
  const taxable = parseFloat(inTaxable.value) || 0;
  const exempt = parseFloat(inExempt.value) || 0;
  const exports = parseFloat(inExport.value) || 0;
  const interstate = parseFloat(inInterstate.value) || 0;
  const total = taxable + exempt + exports;
  resTotal.textContent = formatINR(total);
  const stateCat = stateCatSelect.value;
  let threshold;
  if (stateCat === "special10") {
    threshold = 1e6;
  } else if (stateCat === "special20") {
    threshold = 2e6;
  } else {
    threshold = bizType === "goods" ? 4e6 : 2e6;
  }
  let mustRegister = false;
  let regReason = "";
  if (bizType !== "services" && interstate > 0) {
    mustRegister = true;
    regReason = "Mandatory registration required due to inter-state supply of goods, regardless of turnover.";
  } else if (total > threshold) {
    mustRegister = true;
    regReason = `Aggregate turnover of ${formatINR(total)} exceeds the ${formatThreshold(threshold)} mandatory registration limit for your category.`;
  } else {
    regReason = `You are below the ${formatThreshold(threshold)} limit. Registration is not mandatory yet.`;
  }
  if (mustRegister) {
    iconReg.textContent = "\u{1F534}";
    titleReg.textContent = "Registration Mandatory";
    titleReg.classList.add("text-red-500");
    titleReg.classList.remove("text-green-500");
  } else {
    iconReg.textContent = "\u{1F7E2}";
    titleReg.textContent = "Registration Not Required";
    titleReg.classList.remove("text-red-500");
    titleReg.classList.add("text-green-500");
  }
  descReg.textContent = regReason;
  let compThreshold;
  if (bizType === "services") {
    compThreshold = 5e6;
  } else {
    compThreshold = stateCat === "normal" ? 15e6 : 75e5;
  }
  let canOptComp = true;
  let compReason = "";
  if (interstate > 0) {
    canOptComp = false;
    compReason = "Not eligible: Businesses making inter-state supplies cannot opt for the Composition Scheme.";
  } else if (exports > 0) {
    canOptComp = false;
    compReason = "Not eligible: Exporters are not permitted under the Composition Scheme.";
  } else if (total > compThreshold) {
    canOptComp = false;
    compReason = `Not eligible: Turnover of ${formatINR(total)} exceeds the ${formatThreshold(compThreshold)} Composition Scheme limit.`;
  } else {
    compReason = `Eligible! Turnover is within the ${formatThreshold(compThreshold)} limit and no inter-state sales detected.`;
  }
  if (canOptComp) {
    iconComp.textContent = "\u2705";
    titleComp.textContent = "Eligible for Composition Scheme";
    titleComp.classList.add("text-green-500");
    titleComp.classList.remove("text-red-500");
  } else {
    iconComp.textContent = "\u274C";
    titleComp.textContent = "Not Eligible for Composition Scheme";
    titleComp.classList.add("text-red-500");
    titleComp.classList.remove("text-green-500");
  }
  descComp.textContent = compReason;
}
typeBtns.forEach((btn) => {
  btn.addEventListener("click", (e) => {
    const target = e.currentTarget;
    bizType = target.dataset.type;
    typeBtns.forEach((b) => {
      const isSelected = b.dataset.type === bizType;
      b.classList.toggle("border-accent", isSelected);
      b.classList.toggle("bg-accent", isSelected);
      b.classList.toggle("text-white", isSelected);
      b.classList.toggle("border-base", !isSelected);
      b.classList.toggle("bg-subtle", !isSelected);
      b.classList.toggle("text-muted", !isSelected);
    });
    calculate();
  });
});
[inTaxable, inExempt, inExport, inInterstate, stateCatSelect].forEach((el) => {
  el.addEventListener("input", calculate);
});
btnReset.addEventListener("click", () => {
  inTaxable.value = "";
  inExempt.value = "";
  inExport.value = "";
  inInterstate.value = "";
  stateCatSelect.value = "normal";
  document.getElementById("btn-goods").click();
  calculate();
});
calculate();
</script>
