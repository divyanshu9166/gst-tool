---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'TCS under GST Calculator | 1% E-Commerce Tax Collection';
const description = 'Calculate the 1% Tax Collected at Source (TCS) on e-commerce transactions under Section 52 of the CGST Act. Accurate offline calculator for sellers and ECOs.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'TCS under GST Calculator',
    url: Astro.site?.toString() ? `${Astro.site}tcs-gst-calculator` : 'https://example.com/tcs-gst-calculator',
    description: 'Calculate 1% TCS on e-commerce sales.',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: "What is the TCS rate under GST in 2026?", acceptedAnswer: { '@type': 'Answer', text: "E-commerce operators are required to collect TCS at the rate of 1% (0.5% CGST + 0.5% SGST, or 1% IGST) on the net value of taxable supplies made through their platform." } },
      { '@type': 'Question', name: "Who is liable to collect TCS under GST?", acceptedAnswer: { '@type': 'Answer', text: "Only specific e-commerce operators who facilitate the supply of goods or services (like Amazon, Flipkart, or Swiggy) are liable to collect TCS." } },
      {
        '@type': 'Question',
        name: 'What is TCS under GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Tax Collected at Source (TCS) under GST is a mechanism where E-Commerce Operators (like Amazon or Flipkart) are required to collect 1% tax on the net value of taxable supplies made through their platform by other suppliers.',
        }
      },
      {
        '@type': 'Question',
        name: 'What is the rate of TCS?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The statutory rate of TCS under Section 52 is 1%. For intra-state supplies, it is 0.5% CGST and 0.5% SGST. For inter-state supplies, it is 1% IGST.',
        }
      },
      {
        '@type': 'Question',
        name: 'How is the Net Value of Taxable Supplies calculated?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The net value is calculated as the total gross value of taxable supplies made during the month minus the aggregate value of taxable supplies returned by the customers during the same month.',
        }
      },
      {
        '@type': 'Question',
        name: 'Do e-commerce operators have to pay TCS out of pocket?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. The ECO collects this 1% from the amount payable to the supplier (seller). They then deposit it with the government while filing their GSTR-8 return.',
        }
      },
      {
        '@type': 'Question',
        name: 'How does the seller claim the TCS?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Once the ECO files GSTR-8, the TCS amount appears in the seller’s "TDS and TCS Credit Received" dashboard on the GST portal. Upon accepting it, the money is credited to the seller’s Electronic Cash Ledger.',
        }
      },
      {
        '@type': 'Question',
        name: 'Is TCS applicable on exempt supplies?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. TCS is only collected on "taxable supplies". It is not collected on exempted supplies, zero-rated supplies, or supplies where the ECO pays tax under reverse charge (Section 9(5)).',
        }
      },
      {
        '@type': 'Question',
        name: 'Is GST registration mandatory for e-commerce sellers?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Generally, yes. Persons supplying goods through an ECO who is required to collect TCS must take compulsory GST registration, irrespective of their turnover. However, recent amendments provide some relief to small intra-state sellers.',
        }
      },
      {
        '@type': 'Question',
        name: 'What happens if sales returns exceed gross sales?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'If the returns in a month are higher than the gross sales, the net taxable value becomes negative. In such a scenario, no TCS is collected for that particular month.',
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-12 lg:py-24">
    <!-- Header -->
    <div class="mb-10 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-base bg-surface px-4 py-1.5 text-[12px] font-mono uppercase tracking-wider text-muted mb-4 shadow-[0_1px_1px_#00000005]">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        100% Offline Tool
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-base mb-4">
        TCS under GST Calculator
      </h1>
      <p class="text-[16px] text-muted max-w-xl mx-auto leading-relaxed">
        Calculate the 1% Tax Collected at Source (TCS) on your e-commerce sales. Instantly compute the net taxable value and exact TCS deduction.
      </p>
    </div>

    <!-- Main Tool Container -->
    <div class="rounded-[12px] border border-base bg-surface p-6 sm:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] mb-12">
      <div class="flex flex-col gap-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="gross-sales" class="text-sm font-semibold text-base">Gross Taxable Sales (₹)</label>
            <input 
              type="number" 
              id="gross-sales" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-mono focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
              placeholder="e.g. 500000"
              min="0"
            />
            <p class="text-[12px] text-muted">Exclude GST and exempt sales.</p>
          </div>

          <div class="flex flex-col gap-2">
            <label for="sales-returns" class="text-sm font-semibold text-base">Sales Returns (₹)</label>
            <input 
              type="number" 
              id="sales-returns" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-mono focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
              placeholder="e.g. 50000"
              min="0"
            />
            <p class="text-[12px] text-muted">Value of goods returned this month.</p>
          </div>
        </div>

        <div class="grid grid-cols-1 gap-6">
          <div class="flex flex-col gap-2">
            <label for="txn-type" class="text-sm font-semibold text-base">Transaction Type</label>
            <select 
              id="txn-type" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-medium focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
            >
              <option value="intra">Intra-State (Same State)</option>
              <option value="inter">Inter-State (Different States)</option>
            </select>
          </div>
        </div>

      </div>

      <!-- Result Card -->
      <div id="result-card" class="mt-8 hidden overflow-hidden rounded-[8px] border border-base bg-subtle transition-all duration-300">
        
        <div id="status-tcs" class="hidden">
          <div class="p-6">
            <h3 class="text-[14px] font-medium text-muted mb-4 uppercase tracking-wider">TCS Calculation Result</h3>
            
            <div class="space-y-4">
              <div class="flex justify-between items-center pb-4 border-b border-base/50">
                <span class="text-base font-medium">Net Taxable Value:</span>
                <span class="text-xl font-mono text-base" id="res-net">₹0</span>
              </div>

              <div id="res-cgst-box" class="flex justify-between items-center text-muted">
                <span>TCS - CGST (0.5%):</span>
                <span class="text-lg font-mono text-accent" id="res-cgst">₹0</span>
              </div>
              
              <div id="res-sgst-box" class="flex justify-between items-center text-muted">
                <span>TCS - SGST (0.5%):</span>
                <span class="text-lg font-mono text-accent" id="res-sgst">₹0</span>
              </div>

              <div id="res-igst-box" class="hidden justify-between items-center text-muted">
                <span>TCS - IGST (1.0%):</span>
                <span class="text-lg font-mono text-accent" id="res-igst">₹0</span>
              </div>

              <div class="flex justify-between items-center pt-4 border-t border-base/50">
                <span class="text-lg font-bold text-accent">Total TCS to be Collected:</span>
                <span class="text-3xl font-mono font-bold text-accent" id="res-total">₹0</span>
              </div>
            </div>
          </div>
          <div class="border-t border-blue-200/50 bg-blue-50 dark:bg-blue-900/10 dark:border-blue-900/30 p-4">
            <p class="text-sm text-blue-700 dark:text-blue-400 font-medium">
              💡 The ECO will deduct this ₹<span id="res-tcs-note"></span> before transferring the settlement to your bank account. You can claim this in your GST cash ledger.
            </p>
          </div>
        </div>

        <div id="status-negative" class="hidden">
          <div class="p-6 bg-yellow-50 dark:bg-yellow-900/10">
            <div class="flex items-center gap-3 mb-4">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-yellow-100 text-yellow-600 dark:bg-yellow-900/30 dark:text-yellow-400">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
              </span>
              <h3 class="text-lg font-bold text-yellow-800 dark:text-yellow-400">No TCS Applicable</h3>
            </div>
            <p class="text-sm text-yellow-800 dark:text-yellow-400 font-medium leading-relaxed">
              Your sales returns exceed your gross sales, resulting in a negative net taxable value. Therefore, no TCS will be collected for this period.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- SEO Content -->
    <article class="prose prose-neutral dark:prose-invert max-w-none text-[15px] leading-relaxed">
      <h2 class="text-2xl font-semibold mb-4">Understanding TCS under GST (Section 52)</h2>
      <p>
        The rapid rise of e-commerce revolutionized business in India, but it also created a massive loophole for tax evasion. Many sellers were registering on platforms like Amazon, Flipkart, and Swiggy, making significant sales, but "forgetting" to declare this income to the government. To plug this revenue leak, the government introduced the concept of <strong>Tax Collected at Source (TCS)</strong> under Section 52 of the CGST Act.
      </p>
      <p>
        Under the TCS mechanism, the government shifted the burden of tracking sales from individual sellers to the giant tech platforms. Every E-Commerce Operator (ECO) is now legally mandated to collect a 1% tax on the net sales value before paying the seller. Our <strong>TCS under GST Calculator</strong> helps sellers accurately predict this deduction and manage their cash flows.
      </p>
      
      <h3>Who is an E-Commerce Operator (ECO)?</h3>
      <p>
        An E-Commerce Operator is any person who owns, operates, or manages a digital or electronic facility or platform for electronic commerce. Examples include:
      </p>
      <ul>
        <li>Online marketplaces like Amazon, Flipkart, Myntra.</li>
        <li>Food delivery apps like Zomato, Swiggy.</li>
        <li>Ride-hailing services like Ola, Uber.</li>
      </ul>
      <p>
        If you sell your own products on your own website (e.g., using Shopify to build a direct-to-consumer brand), you are NOT an ECO for the purpose of Section 52, and no TCS is required to be collected on your own sales.
      </p>

      <h3>How is the 1% TCS Calculated?</h3>
      <p>
        The statutory rate of TCS is 1%. The split depends on the location of the supplier and the customer:
      </p>
      <ul>
        <li><strong>Intra-State (Same State):</strong> The ECO collects 0.5% CGST and 0.5% SGST.</li>
        <li><strong>Inter-State (Different States):</strong> The ECO collects 1.0% IGST.</li>
      </ul>
      <p>
        <strong>Crucial Rule:</strong> TCS is calculated strictly on the "Net Value of Taxable Supplies".
      </p>
      <p>
        <code>Net Value = Gross Taxable Sales - Sales Returns</code>
      </p>
      <p>
        If an ECO facilitated ₹5,00,000 worth of taxable sales for a seller in August, but customers returned ₹50,000 worth of goods in the same month, the Net Value is ₹4,50,000. The ECO will collect 1% of ₹4,50,000 = ₹4,500 as TCS. Furthermore, TCS is not calculated on exempt supplies (like fresh fruits or unbranded grains) or on the GST tax component itself.
      </p>

      <h3>Impact on E-Commerce Sellers</h3>
      <p>
        As a seller, the TCS collected by the ECO is not a loss of money; it is essentially an advance tax payment. The ECO deposits this money with the government and files a monthly return called <strong>GSTR-8</strong> by the 10th of the following month.
      </p>
      <p>
        Once GSTR-8 is filed, the TCS amount automatically reflects in your GST portal under the "TDS and TCS Credit Received" dashboard. You must log in, review the entries, and click "Accept". Once accepted, the entire amount is transferred to your <strong>Electronic Cash Ledger</strong>. You can then utilize this cash balance to pay your monthly GSTR-3B tax liabilities or claim a refund if your cash ledger accumulates a huge balance.
      </p>

      <h3>Mandatory Registration</h3>
      <p>
        Section 24(ix) of the CGST Act originally made GST registration strictly mandatory for anyone selling through an ECO, even if their annual turnover was just ₹10,000 (well below the standard ₹40 Lakh threshold). 
      </p>
      <p>
        However, recent notifications have provided relief: Unregistered suppliers and composition taxpayers are now allowed to make intra-state (within the same state) supply of goods through ECOs, subject to certain conditions like generating an enrollment number. But for inter-state sales through an ECO, regular GST registration remains compulsory regardless of turnover.
      </p>
    </article>

    
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/hsn-code-importance" class="text-primary hover:underline">Why HSN Codes are Essential for GST Invoices in India</a></li>
        <li><a href="/blog/gstin-validation-check" class="text-primary hover:underline">How to Spot a Fake GST Bill Using a GSTIN Validator</a></li>
      </ul>
    </div>
  </div>
<script>
const grossInput = document.getElementById("gross-sales");
const returnsInput = document.getElementById("sales-returns");
const typeSelect = document.getElementById("txn-type");
const resultCard = document.getElementById("result-card");
const statusTcs = document.getElementById("status-tcs");
const statusNegative = document.getElementById("status-negative");
const resNet = document.getElementById("res-net");
const resCgstBox = document.getElementById("res-cgst-box");
const resCgst = document.getElementById("res-cgst");
const resSgstBox = document.getElementById("res-sgst-box");
const resSgst = document.getElementById("res-sgst");
const resIgstBox = document.getElementById("res-igst-box");
const resIgst = document.getElementById("res-igst");
const resTotal = document.getElementById("res-total");
const resTcsNote = document.getElementById("res-tcs-note");
function formatCur(num) {
  return "\u20B9" + num.toLocaleString("en-IN", { maximumFractionDigits: 2 });
}
function calculate() {
  const gross = parseFloat(grossInput.value) || 0;
  const returns = parseFloat(returnsInput.value) || 0;
  const type = typeSelect.value;
  if (gross <= 0 && returns <= 0) {
    resultCard.classList.add("hidden");
    return;
  }
  resultCard.classList.remove("hidden");
  const netValue = gross - returns;
  if (netValue <= 0) {
    statusTcs.classList.add("hidden");
    statusNegative.classList.remove("hidden");
  } else {
    statusNegative.classList.add("hidden");
    statusTcs.classList.remove("hidden");
    resNet.textContent = formatCur(netValue);
    const totalTcs = netValue * 0.01;
    resTotal.textContent = formatCur(totalTcs);
    resTcsNote.textContent = totalTcs.toLocaleString("en-IN", { maximumFractionDigits: 2 });
    if (type === "intra") {
      resCgstBox.classList.remove("hidden");
      resCgstBox.classList.add("flex");
      resSgstBox.classList.remove("hidden");
      resSgstBox.classList.add("flex");
      resIgstBox.classList.remove("flex");
      resIgstBox.classList.add("hidden");
      resCgst.textContent = formatCur(totalTcs / 2);
      resSgst.textContent = formatCur(totalTcs / 2);
    } else {
      resCgstBox.classList.remove("flex");
      resCgstBox.classList.add("hidden");
      resSgstBox.classList.remove("flex");
      resSgstBox.classList.add("hidden");
      resIgstBox.classList.remove("hidden");
      resIgstBox.classList.add("flex");
      resIgst.textContent = formatCur(totalTcs);
    }
  }
}
[grossInput, returnsInput, typeSelect].forEach((el) => el.addEventListener("input", calculate));
</script>

    <!-- FAQ Section -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16 pt-12 border-t border-base" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-base mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {structuredData[1].mainEntity.map((faq, i) => (
          <details class="group rounded-xl border border-base bg-surface overflow-hidden" id={`faq-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span>{faq.name}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[15px] text-muted leading-relaxed border-t border-base pt-4">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
</BaseLayout>
