---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GSTR-1, GSTR-3B & NIL Return Late Fee Calculator India';
const description = 'Calculate GSTR-1 late fee, GSTR-3B late fee, NIL return late fee, and 18% interest instantly. Accurate, offline, and free GST tool for India.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GST Late Fee Calculator',
    url: `${Astro.site?.toString() ?? 'https://example.com'}/late-fee-calculator`,
    description: 'Free online GST late fee and interest calculator for delayed returns.',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
    offers: {
      '@type': 'Offer',
      price: '0',
      priceCurrency: 'INR',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'How much is the GST late fee per day?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The GST late fee is ₹50 per day for normal returns and ₹20 per day for NIL returns under the CGST and SGST acts combined.',
        },
      },
      {
        '@type': 'Question',
        name: 'Is there a specific gstr 1 late fee calculator?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The late fee for GSTR-1 and GSTR-3B follows the same rules. You can use our general tool as a gstr 1 late fee calculator to estimate your exact penalty.',
        },
      },
      {
        '@type': 'Question',
        name: 'How does the gst late fee for nil return calculator work?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A nil return means you had no business activity. The gst late fee for nil return calculator applies a reduced penalty of ₹20 per day instead of the standard ₹50 per day.',
        },
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page header -->
    <div class="mb-12 text-center">
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-[-1.28px] text-base mb-4">GSTR-1, GSTR-3B & NIL Return Late Fee Calculator</h1>
      <p class="text-[16px] text-muted max-w-2xl mx-auto leading-relaxed">
        <strong>What is it?</strong> The GST late fee is ₹50 per day for normal returns and ₹20 per day for NIL returns. Simply click "NIL Return" to use this as a <strong>gst late fee for nil return calculator</strong>. Need a <strong>gstr 1 late fee calculator</strong>? This tool covers that too!
      </p>
    </div>

    <!-- Calculator layout -->
    <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 lg:gap-12 items-start">
      
      <!-- Input Section -->
      <div class="rounded-[8px] border border-base bg-surface p-[24px] shadow-[0_2px_2px_#0000000a,0_8px_8px_-8px_#0000000a]">
        
        <div class="space-y-6">
          <div>
            <label class="block text-[14px] font-medium text-base mb-2">Type of Return</label>
            <div class="grid grid-cols-2 gap-3" role="group" aria-label="Return type selection">
              <button
                type="button"
                id="btn-normal"
                class="return-type-btn rounded-[8px] border border-accent bg-accent text-white py-3 text-[14px] font-medium transition-colors active:scale-95 shadow-sm"
                data-type="normal"
                aria-pressed="true"
              >
                Normal Return
              </button>
              <button
                type="button"
                id="btn-nil"
                class="return-type-btn rounded-[8px] border border-base bg-subtle text-muted hover:border-accent hover:text-base py-3 text-[14px] font-medium transition-colors active:scale-95"
                data-type="nil"
                aria-pressed="false"
              >
                NIL Return
              </button>
            </div>
            <p class="mt-3 text-[12px] text-muted">
              Normal: ₹50/day. NIL: ₹20/day. Max capping applies based on turnover.
            </p>
          </div>

          <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
            <div>
              <label for="due-date" class="block text-[14px] font-medium text-base mb-2">Due Date</label>
              <input
                id="due-date"
                type="date"
                class="w-full rounded-[8px] border border-base bg-subtle px-4 py-3 text-[16px] focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all shadow-inner"
              />
            </div>
            <div>
              <label for="filing-date" class="block text-[14px] font-medium text-base mb-2">Actual Filing Date</label>
              <input
                id="filing-date"
                type="date"
                class="w-full rounded-[8px] border border-base bg-subtle px-4 py-3 text-[16px] focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all shadow-inner"
              />
            </div>
          </div>

          <div>
            <label for="tax-liability" class="block text-[14px] font-medium text-base mb-2">
              Net Tax Liability (₹) <span class="font-normal text-muted">— paid in cash</span>
            </label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted font-medium select-none" aria-hidden="true">₹</span>
              <input
                id="tax-liability"
                type="number"
                inputmode="decimal"
                min="0"
                placeholder="0"
                class="w-full rounded-[8px] border border-base bg-subtle pl-9 pr-4 py-3 text-[16px] focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all shadow-inner"
              />
            </div>
            <p class="mt-3 text-[12px] text-muted">
              Interest @ 18% p.a. is calculated only on the tax amount paid through electronic cash ledger.
            </p>
          </div>

          <button
            id="btn-reset"
            type="button"
            class="w-full rounded-[8px] border border-base py-3 text-[14px] font-medium text-muted hover:text-base hover:bg-subtle transition-all active:scale-95 mt-2"
          >
            Reset Fields
          </button>
        </div>
      </div>

      <!-- Results Section -->
      <div class="rounded-[8px] border border-base bg-subtle p-[24px] space-y-6">
        <h2 class="text-[20px] font-semibold text-base tracking-[-0.6px]">Calculation Results</h2>
        
        <div class="space-y-4">
          <div class="flex justify-between items-center text-[14px] border-b border-base pb-3">
            <span class="text-muted">Days Delayed</span>
            <span class="font-semibold text-base" id="result-days">0 Days</span>
          </div>

          <div class="pt-2">
            <div class="flex justify-between items-center text-[14px] mb-2">
              <span class="text-muted">Late Fee (CGST + SGST)</span>
              <span class="font-semibold text-base" id="result-late-fee">₹0</span>
            </div>
            <div class="flex justify-between items-center text-[12px] pl-4 border-l-2 border-base">
              <span class="text-muted">CGST</span>
              <span class="text-muted" id="result-cgst">₹0</span>
            </div>
            <div class="flex justify-between items-center text-[12px] pl-4 border-l-2 border-base mt-1">
              <span class="text-muted">SGST</span>
              <span class="text-muted" id="result-sgst">₹0</span>
            </div>
          </div>

          <div class="flex justify-between items-center text-[14px] border-y border-base py-3">
            <span class="text-muted">Interest @ 18% p.a.</span>
            <span class="font-semibold text-base" id="result-interest">₹0</span>
          </div>

          <div class="flex justify-between items-center pt-2">
            <span class="font-semibold text-[16px]">Total Payable</span>
            <span class="text-[24px] font-bold text-accent" id="result-total">₹0</span>
          </div>
        </div>

        <div class="mt-6 rounded-[6px] bg-[#d3e5ff]/20 dark:bg-[#d3e5ff]/5 border border-[#d3e5ff]/50 p-4 text-[12px] text-muted">
          <p><strong>Disclaimer:</strong> Late fee is subject to maximum capping based on your turnover. This calculator provides standard un-capped estimates for general guidance. Always consult the GST portal for exact liability.</p>
        </div>
      </div>

    </div>

    <!-- Semantic Content Guide -->
    <div class="mx-auto max-w-5xl mt-16 border-t border-base pt-12">
      <h2 class="text-[28px] tracking-[-1px] font-semibold text-base mb-6">Understanding GST Late Fees and Interest in 2026</h2>
      
      <div class="prose prose-neutral dark:prose-invert max-w-none text-[16px] leading-[24px]">
        <p>
          Missing a GST return deadline happens. Whether it's GSTR-1, GSTR-3B, or GSTR-9, the GST portal automatically calculates a late fee. Our <strong>GST late fee calculator</strong> allows you to estimate this penalty offline before you log into the portal.
        </p>

        <h3 class="text-[20px] font-semibold text-base mt-8 mb-4 tracking-[-0.6px]">1. Late Fee Calculation Rules</h3>
        <p>
          Under the CGST Act, if a registered taxpayer fails to furnish returns by the due date, they must pay a late fee. The standard rate is:
        </p>
        <ul class="list-disc pl-5 mt-2 space-y-1">
          <li><strong>Normal Returns (Tax Liability Exists):</strong> ₹50 per day (₹25 CGST + ₹25 SGST) of delay.</li>
          <li><strong>NIL Returns (Zero Tax Liability):</strong> ₹20 per day (₹10 CGST + ₹10 SGST) of delay.</li>
        </ul>
        <p class="mt-4">
          <em>Note on Capping:</em> To provide relief to small businesses, the CBIC has introduced maximum capping on late fees based on the taxpayer's Annual Aggregate Turnover (AATO). For example, taxpayers with a turnover up to ₹1.5 crore have a maximum late fee capping of ₹2,000 per return.
        </p>

        <h3 class="text-[20px] font-semibold text-base mt-8 mb-4 tracking-[-0.6px]">2. 18% Interest on Delayed Payment</h3>
        <p>
          Unlike the late fee, which is a flat daily charge, interest is charged as a percentage of your outstanding tax liability. Key things to remember:
        </p>
        <ul class="list-disc pl-5 mt-2 space-y-1">
          <li>Interest is strictly charged at <strong>18% per annum</strong>.</li>
          <li>It is calculated <strong>only on the net cash tax liability</strong>. This means if you offset your tax using the Input Tax Credit (ITC) balance in your electronic credit ledger, no interest is charged on that portion. Interest only applies to the amount deposited in cash.</li>
        </ul>

        <h3 class="text-[20px] font-semibold text-base mt-8 mb-4 tracking-[-0.6px]">3. How to use this tool</h3>
        <p>
          Select whether your return is Normal or NIL. Enter the original statutory Due Date and the Actual Filing Date. If you have an outstanding cash liability, enter it to calculate the 18% interest. Our offline calculator will instantly split the penalty into CGST and SGST.
        </p>
      </div>
    </div>
  </div>

  
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/gstr-2b-mismatch-itc-blocked-fix-guide" class="text-primary hover:underline">GSTR-2B Mismatches: Why Your ITC is Blocked & How to Fix It in 2026</a></li>
        <li><a href="/blog/itc-reversal-gst-rate-drop" class="text-primary hover:underline">ITC Reversal After GST Rate Drop: Do You Actually Need to Do It?</a></li>
      </ul>
    </div>
  </div>
<!-- FAQ Section -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16">
    <div class="border-t border-base pt-12">
      <h2 class="text-[28px] tracking-[-1px] font-semibold text-base mb-2">Frequently Asked Questions</h2>
      <p class="text-muted text-[15px] mb-8">All about GST late fees and interest calculation.</p>
      <div class="space-y-3">
        {[
          { q: 'What is the GST late fee per day?', a: 'For normal returns (where tax is payable): ₹50 per day (₹25 CGST + ₹25 SGST). For NIL returns (zero tax liability): ₹20 per day (₹10 CGST + ₹10 SGST). This applies per return that is filed late — so filing both GSTR-1 and GSTR-3B late doubles the late fee.' },
          { q: 'Is there a maximum cap on GST late fees?', a: 'Yes. The CBIC has introduced turnover-based maximum late fee caps: (1) Up to ₹1.5 Crore turnover: max ₹2,000 per return. (2) ₹1.5 Crore to ₹5 Crore: max ₹5,000 per return. (3) Above ₹5 Crore: max ₹10,000 per return. Annual return (GSTR-9) has a separate cap of 0.25% of turnover.' },
          { q: 'How is 18% GST interest calculated on delayed tax payment?', a: 'Interest is calculated as: Interest = Tax Liability × 18% × (Days Delayed ÷ 365). It applies only on the net cash tax liability — i.e., the amount you owe that cannot be covered by ITC in your Electronic Credit Ledger. If your ITC covers the full liability, no interest is charged.' },
          { q: 'Is GST late fee charged separately for CGST and SGST?', a: 'Yes. The ₹50/day late fee (for normal returns) is split as ₹25 CGST and ₹25 SGST. You pay the CGST portion from your CGST Electronic Cash Ledger and the SGST portion from your SGST ledger. You cannot use IGST credit to pay late fees.' },
          { q: 'What is the late fee for GSTR-1?', a: 'GSTR-1 late fee is ₹50 per day (₹25 CGST + ₹25 SGST) for returns with outward supplies, and ₹20 per day for NIL returns. The maximum cap applies based on your annual turnover (see turnover-based caps above). Note: GSTR-1 late fee is separate from GSTR-3B late fee.' },
          { q: 'What is the late fee for GSTR-3B?', a: 'GSTR-3B late fee is also ₹50/day for normal returns and ₹20/day for NIL returns, with the same turnover-based maximum caps. Additionally, interest at 18% per annum is charged on any outstanding cash tax liability for the period of delay. Filing GSTR-3B late also blocks you from filing subsequent months.' },
          { q: 'Can I get a waiver of GST late fees?', a: 'The CBIC periodically announces amnesty schemes waiving or reducing late fees for taxpayers who file pending returns within a specified window. These are announced via GST Council decisions and CBIC notifications. Outside of amnesty periods, late fees are mandatory and cannot be waived on the portal.' },
          { q: 'Is interest charged on ITC utilization?', a: 'No. Interest at 18% under Section 50 of the CGST Act is charged only on the cash component of the tax liability — the amount that exceeds your available ITC. If you have sufficient ITC in your Electronic Credit Ledger to cover the tax, the interest amount is zero even if you file late.' },
          { q: 'What is the penalty for not filing GSTR-9 (Annual Return)?', a: 'The late fee for GSTR-9 (Annual Return) is ₹200 per day (₹100 CGST + ₹100 SGST), subject to a maximum of 0.25% of the state turnover. For example, if your Karnataka turnover is ₹10 Crore, the maximum GSTR-9 late fee for Karnataka is ₹2,50,000.' },
          { q: 'Does late GSTR-1 filing block GSTR-3B filing?', a: 'Yes. If GSTR-1 is not filed for the previous month, the GST portal restricts filing of GSTR-3B for the current month. Similarly, if GSTR-3B is not filed, it can restrict e-way bill generation. This cascading effect makes timely filing extremely important for business continuity.' },
        ].map((faq, i) => (
          <details class="group rounded-[8px] border border-base bg-surface overflow-hidden" id={`faq-late-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span class="text-[15px]">{faq.q}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[14px] text-muted leading-relaxed border-t border-base pt-4">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>


<script>
const btnNormal = document.getElementById("btn-normal");
const btnNil = document.getElementById("btn-nil");
const dueDateInput = document.getElementById("due-date");
const filingDateInput = document.getElementById("filing-date");
const liabilityInput = document.getElementById("tax-liability");
const btnReset = document.getElementById("btn-reset");
const resDays = document.getElementById("result-days");
const resLateFee = document.getElementById("result-late-fee");
const resCgst = document.getElementById("result-cgst");
const resSgst = document.getElementById("result-sgst");
const resInterest = document.getElementById("result-interest");
const resTotal = document.getElementById("result-total");
let isNil = false;
function formatINR(value) {
  return "\u20B9" + Math.round(value).toLocaleString("en-IN");
}
function calculate() {
  let days = 0;
  if (dueDateInput.value && filingDateInput.value) {
    const parseDate = (dateStr) => {
      if (!dateStr) return null;
      const [year, month, day] = dateStr.split("-").map(Number);
      return new Date(year, month - 1, day);
    };
    const start = parseDate(dueDateInput.value);
    const end = parseDate(filingDateInput.value);
    if (start && end) {
      const startTime = start.getTime();
      const endTime = end.getTime();
      if (endTime > startTime) {
        days = Math.floor((endTime - startTime) / (1e3 * 60 * 60 * 24));
      }
    }
  }
  const feePerDay = isNil ? 20 : 50;
  const lateFee = days * feePerDay;
  const cgstSgst = lateFee / 2;
  const liability = parseFloat(liabilityInput.value) || 0;
  let interest = 0;
  if (liability > 0 && days > 0) {
    interest = liability * 18 * days / (100 * 365);
  }
  const total = lateFee + interest;
  resDays.textContent = `${days} Days`;
  resLateFee.textContent = formatINR(lateFee);
  resCgst.textContent = formatINR(cgstSgst);
  resSgst.textContent = formatINR(cgstSgst);
  resInterest.textContent = formatINR(interest);
  resTotal.textContent = formatINR(total);
}
function toggleType(type) {
  isNil = type === "nil";
  btnNormal.classList.toggle("border-accent", !isNil);
  btnNormal.classList.toggle("bg-accent", !isNil);
  btnNormal.classList.toggle("text-white", !isNil);
  btnNormal.classList.toggle("border-base", isNil);
  btnNormal.classList.toggle("bg-subtle", isNil);
  btnNormal.classList.toggle("text-muted", isNil);
  btnNormal.setAttribute("aria-pressed", String(!isNil));
  btnNil.classList.toggle("border-accent", isNil);
  btnNil.classList.toggle("bg-accent", isNil);
  btnNil.classList.toggle("text-white", isNil);
  btnNil.classList.toggle("border-base", !isNil);
  btnNil.classList.toggle("bg-subtle", !isNil);
  btnNil.classList.toggle("text-muted", !isNil);
  btnNil.setAttribute("aria-pressed", String(isNil));
  calculate();
}
btnNormal.addEventListener("click", () => toggleType("normal"));
btnNil.addEventListener("click", () => toggleType("nil"));
dueDateInput.addEventListener("change", calculate);
filingDateInput.addEventListener("change", calculate);
liabilityInput.addEventListener("input", calculate);
btnReset.addEventListener("click", () => {
  dueDateInput.value = "";
  filingDateInput.value = "";
  liabilityInput.value = "";
  toggleType("normal");
});
const today = /* @__PURE__ */ new Date();
const lastMonth = new Date(today.getFullYear(), today.getMonth() - 1, 20);
dueDateInput.value = lastMonth.toISOString().split("T")[0];
filingDateInput.value = today.toISOString().split("T")[0];
calculate();
</script>
