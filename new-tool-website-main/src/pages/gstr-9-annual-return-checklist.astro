---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GSTR-9 Annual Return Filing Checklist (FY 2025-26)';
const description = 'Interactive online checklist for filing your GSTR-9 Annual Return. Ensure compliance, reconcile ITC, and avoid penalties before the 31st December deadline.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GSTR-9 Annual Return Checklist',
    url: Astro.site?.toString() ? `${Astro.site}gstr-9-annual-return-checklist` : 'https://example.com/gstr-9-annual-return-checklist',
    description: 'Interactive checklist for filing GSTR-9 Annual Return.',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is GSTR-9?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'GSTR-9 is an annual return to be filed yearly by taxpayers registered under GST. It consists of details regarding the outward and inward supplies made or received during the relevant financial year.'
        }
      },
      {
        '@type': 'Question',
        name: 'Who is exempt from filing GSTR-9?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Taxpayers with an Annual Aggregate Turnover (AATO) of up to ₹2 Crores are generally exempt from filing GSTR-9 for the financial year, as per the government notifications.'
        }
      },
      {
        '@type': 'Question',
        name: 'What is the due date for filing GSTR-9?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The standard due date for filing GSTR-9 is the 31st of December of the year following the relevant financial year (e.g., 31 Dec 2026 for FY 2025-26).'
        }
      },
      {
        '@type': 'Question',
        name: 'What happens if I file GSTR-9 late?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Late filing of GSTR-9 attracts a late fee of ₹200 per day (₹100 CGST + ₹100 SGST) subject to a maximum cap of 0.25% of your turnover in the State/UT.'
        }
      },
      {
        '@type': 'Question',
        name: 'Can I revise GSTR-9 after filing?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No, GSTR-9 cannot be revised once filed. Any mistakes made in GSTR-9 cannot be corrected later, which is why a thorough checklist and reconciliation is mandatory.'
        }
      },
      {
        '@type': 'Question',
        name: 'What is GSTR-9C?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'GSTR-9C is a reconciliation statement that must be filed along with GSTR-9 by taxpayers whose aggregate turnover exceeds ₹5 Crores. It reconciles the audited financial statements with the GSTR-9.'
        }
      },
      {
        '@type': 'Question',
        name: 'What is Table 8A in GSTR-9?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Table 8A is auto-populated with the total ITC available to you based on your suppliers\' GSTR-1 filings. You must reconcile your claimed ITC against this auto-populated figure to avoid notices.'
        }
      },
      {
        '@type': 'Question',
        name: 'Can I claim missed ITC through GSTR-9?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No, you cannot claim any fresh Input Tax Credit (ITC) through GSTR-9. The last date to claim missed ITC for a financial year is the 30th of November of the following financial year.'
        }
      },
      {
        '@type': 'Question',
        name: 'Do I need to report HSN summaries in GSTR-9?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, reporting HSN summaries for outward supplies is mandatory for taxpayers with an aggregate turnover of more than ₹5 Crores (6 digits) and up to ₹5 Crores (4 digits).'
        }
      },
      {
        '@type': 'Question',
        name: 'How do I pay additional tax liability found during GSTR-9 prep?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Any additional tax liability identified while preparing GSTR-9 must be paid using Form GST DRC-03. You can select "Annual Return" as the cause of payment.'
        }
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-[32px] sm:text-[40px] tracking-[-1.5px] font-semibold text-base mb-4 leading-tight">
        GSTR-9 Annual Return Checklist
      </h1>
      <p class="text-[16px] text-muted max-w-2xl mx-auto leading-relaxed">
        GSTR-9 cannot be revised once filed. Use this interactive checklist to ensure 100% accurate reconciliation of your Books, GSTR-1, GSTR-3B, and GSTR-2B before hitting submit.
      </p>
    </div>

    <!-- Main Card -->
    <div class="bg-surface border border-base rounded-[16px] shadow-sm overflow-hidden mb-8">
      
      <!-- Progress Bar -->
      <div class="bg-subtle border-b border-base p-4 sm:p-6 sticky top-0 z-10">
        <div class="flex justify-between items-center mb-2">
          <h3 class="text-[14px] font-medium text-base">Preparation Progress</h3>
          <span id="progress-text" class="text-[14px] font-bold text-primary">0%</span>
        </div>
        <div class="w-full bg-base rounded-full h-2.5 overflow-hidden">
          <div id="progress-bar" class="bg-primary h-2.5 rounded-full transition-all duration-300" style="width: 0%"></div>
        </div>
      </div>

      <div class="p-6 sm:p-8 space-y-8">
        
        <!-- Category 1 -->
        <div>
          <h3 class="text-[18px] font-semibold text-base mb-4 border-b border-base pb-2 text-primary">1. Outward Supplies Reconciliation (GSTR-1 vs GSTR-3B vs Books)</h3>
          <div class="space-y-3">
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Reconcile total sales turnover in Audited Financial Statements with total outward supplies declared in GSTR-1 and GSTR-3B.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Ensure tax liability paid via GSTR-3B matches the liability declared in GSTR-1. Any short payment should be paid via DRC-03.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Verify that zero-rated supplies (Exports/SEZ) and exempt supplies are correctly categorized and reported in Table 4 and Table 5.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Confirm that Credit Notes and Debit Notes issued during the year are correctly adjusted against the gross turnover.</span>
            </label>
          </div>
        </div>

        <!-- Category 2 -->
        <div>
          <h3 class="text-[18px] font-semibold text-base mb-4 border-b border-base pb-2 text-primary">2. Inward Supplies & ITC Reconciliation (Table 8A)</h3>
          <div class="space-y-3">
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Reconcile ITC claimed in GSTR-3B (Table 4A) with Books of Accounts.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Compare total ITC claimed with the auto-populated figure in <strong>Table 8A of GSTR-9</strong> (which fetches data from suppliers' GSTR-1). Identify reasons for any negative variance in Table 8D.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Verify that blocked ITC under Section 17(5) has been properly reversed and not utilized.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Check if Rule 42 & 43 reversals (for exempt supplies/personal use) were accurately computed and reported.</span>
            </label>
          </div>
        </div>

        <!-- Category 3 -->
        <div>
          <h3 class="text-[18px] font-semibold text-base mb-4 border-b border-base pb-2 text-primary">3. Reverse Charge Mechanism (RCM)</h3>
          <div class="space-y-3">
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Ensure RCM liability (e.g., on GTA, Director Remuneration, Rent, Legal Services) was paid in cash in GSTR-3B.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Verify that ITC on RCM paid was subsequently claimed in the same month's GSTR-3B (if eligible).</span>
            </label>
          </div>
        </div>

        <!-- Category 4 -->
        <div>
          <h3 class="text-[18px] font-semibold text-base mb-4 border-b border-base pb-2 text-primary">4. HSN Summary & Spillover Transactions</h3>
          <div class="space-y-3">
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Prepare the HSN summary for outward supplies (Mandatory: 4 digits up to ₹5Cr, 6 digits above ₹5Cr). Ensure it matches total outward supplies.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Report spillover transactions (Sales/ITC of the current FY reported between April to November of the next FY) in Table 10, 11, 12, or 13.</span>
            </label>
            <label class="flex items-start gap-3 cursor-pointer p-3 rounded-lg hover:bg-subtle transition-colors border border-transparent hover:border-base">
              <input type="checkbox" class="task-check mt-1 w-5 h-5 text-primary border-base rounded focus:ring-primary focus:ring-offset-surface bg-surface transition-all">
              <span class="text-[14px] text-base leading-relaxed">Verify if GSTR-9C (Reconciliation Statement) is applicable to you (Turnover > ₹5 Crores) and initiate auditor certification if required.</span>
            </label>
          </div>
        </div>

      </div>
    </div>
    
    <div id="completion-message" class="hidden bg-green-50 border border-green-200 text-green-800 rounded-xl p-6 text-center shadow-sm">
      <h3 class="text-xl font-bold mb-2">🎉 Checklist Complete!</h3>
      <p class="text-[15px]">You have verified all critical reconciliation points. You are now ready to file your GSTR-9 without fear of departmental notices.</p>
    </div>

  </div>

  
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/finding-hsn-codes-for-exports" class="text-primary hover:underline">Finding HSN Codes for Exports: An 8-Digit Requirement</a></li>
        <li><a href="/blog/consequences-of-fake-gst-bills" class="text-primary hover:underline">The Consequences of Dealing with Fake GST Bills</a></li>
      </ul>
    </div>
  </div>
<!-- FAQ Section -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-8">
    <div class="border-t border-base pt-12">
      <h2 class="text-[28px] tracking-[-1px] font-semibold text-base mb-2">Frequently Asked Questions</h2>
      <p class="text-muted text-[15px] mb-8">Understanding GSTR-9 and Annual Reconciliations.</p>
      <div class="space-y-3">
        {structuredData[1].mainEntity.map((faq, i) => (
          <details class="group rounded-[8px] border border-base bg-surface overflow-hidden" id={`faq-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span class="text-[15px]">{faq.name}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[14px] text-muted leading-relaxed border-t border-base pt-4">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script lang="ts">
  const checkboxes = document.querySelectorAll('.task-check');
  const progressBar = document.getElementById('progress-bar');
  const progressText = document.getElementById('progress-text');
  const completionMessage = document.getElementById('completion-message');

  function updateProgress() {
    const total = checkboxes.length;
    let checked = 0;
    
    checkboxes.forEach((box: HTMLInputElement) => {
      if (box.checked) checked++;
    });

    const percentage = Math.round((checked / total) * 100);
    
    progressBar.style.width = `${percentage}%`;
    progressText.textContent = `${percentage}%`;

    if (percentage === 100) {
      progressBar.classList.replace('bg-primary', 'bg-green-500');
      progressText.classList.replace('text-primary', 'text-green-600');
      completionMessage.classList.remove('hidden');
    } else {
      progressBar.classList.replace('bg-green-500', 'bg-primary');
      progressText.classList.replace('text-green-600', 'text-primary');
      completionMessage.classList.add('hidden');
    }
  }

  checkboxes.forEach(box => {
    box.addEventListener('change', updateProgress);
  });
</script>
