---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GST ITC Calculator | Input Tax Credit Set-Off Calculator 2026';
const description = 'Accurately calculate your net GST payable in cash by setting off your Input Tax Credit (ITC) against your output tax liability according to new CBIC rules.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GST ITC Calculator',
    url: Astro.site?.toString() ? `${Astro.site}itc-calculator` : 'https://example.com/itc-calculator',
    description: 'Calculate Input Tax Credit set-off and net GST payable.',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the order of ITC utilization under GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under the new Section 49A, IGST credit must be fully exhausted first (against IGST, then CGST/SGST liability). Only after IGST credit is zero, can you use CGST credit (against CGST, then IGST liability) and SGST credit (against SGST, then IGST liability).',
        }
      },
      {
        '@type': 'Question',
        name: 'Can CGST credit be used to pay SGST liability?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. The cross-utilization of CGST and SGST is strictly prohibited. CGST credit cannot be used to pay SGST, and SGST credit cannot be used to pay CGST.',
        }
      },
      {
        '@type': 'Question',
        name: 'How do I minimize my cash outflow?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'To minimize cash outflow, you should carefully allocate any remaining IGST credit (after paying IGST liability) towards whichever liability (CGST or SGST) requires the most cash payment.',
        }
      },
      {
        '@type': 'Question',
        name: 'In what proportion should IGST credit be used against CGST and SGST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'There is no fixed statutory proportion. The law permits you to use the balance IGST credit against CGST and SGST liabilities in any order and in any proportion to optimize your cash flow.',
        }
      },
      {
        '@type': 'Question',
        name: 'Can SGST credit be used to pay IGST liability?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. After paying off the SGST liability, if any SGST credit remains, it can be utilized to pay off IGST liability.',
        }
      },
      {
        '@type': 'Question',
        name: 'What happens if I have ITC but no output liability?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Your ITC will be safely carried forward to the next month in your Electronic Credit Ledger. You will not lose it, except under specific circumstances like business closure.',
        }
      },
      {
        '@type': 'Question',
        name: 'Is there a time limit to claim ITC?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. ITC for a financial year must be claimed by the 30th of November of the next financial year, or the date of filing the Annual Return, whichever is earlier.',
        }
      },
      {
        '@type': 'Question',
        name: 'Can I claim ITC on all business purchases?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Section 17(5) lists blocked credits (e.g., motor vehicles, food & beverages, club memberships) on which you cannot claim ITC, even if used for business.',
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-[1000px] px-4 sm:px-6 py-12 lg:py-24">
    <!-- Header -->
    <div class="mb-10 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-base bg-surface px-4 py-1.5 text-[12px] font-mono uppercase tracking-wider text-muted mb-4 shadow-[0_1px_1px_#00000005]">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        100% Offline Tool
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-base mb-4">
        ITC Set-Off Calculator
      </h1>
      <p class="text-[16px] text-muted max-w-xl mx-auto leading-relaxed">
        Input your output liability and available ITC to calculate exactly how your credits will be utilized and find your net GST payable in cash.
      </p>
    </div>

    <!-- Main Tool Container -->
    <div class="rounded-[12px] border border-base bg-surface p-6 sm:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] mb-12">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8">
        
        <!-- Left: Inputs -->
        <div class="flex flex-col gap-8">
          
          <!-- Output Liability -->
          <div>
            <h3 class="text-lg font-bold text-base mb-4 border-b border-base pb-2">Output Tax Liability</h3>
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-4">
                <label for="out-igst" class="w-16 font-semibold text-muted">IGST</label>
                <div class="relative flex-1">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted">₹</span>
                  <input type="number" id="out-igst" class="w-full rounded-md border border-base bg-surface pl-8 pr-4 py-2 text-[16px] font-mono focus:border-accent outline-none" placeholder="0" min="0" />
                </div>
              </div>
              <div class="flex items-center gap-4">
                <label for="out-cgst" class="w-16 font-semibold text-muted">CGST</label>
                <div class="relative flex-1">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted">₹</span>
                  <input type="number" id="out-cgst" class="w-full rounded-md border border-base bg-surface pl-8 pr-4 py-2 text-[16px] font-mono focus:border-accent outline-none" placeholder="0" min="0" />
                </div>
              </div>
              <div class="flex items-center gap-4">
                <label for="out-sgst" class="w-16 font-semibold text-muted">SGST</label>
                <div class="relative flex-1">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted">₹</span>
                  <input type="number" id="out-sgst" class="w-full rounded-md border border-base bg-surface pl-8 pr-4 py-2 text-[16px] font-mono focus:border-accent outline-none" placeholder="0" min="0" />
                </div>
              </div>
            </div>
          </div>

          <!-- Input Tax Credit (ITC) -->
          <div>
            <h3 class="text-lg font-bold text-base mb-4 border-b border-base pb-2">Available ITC</h3>
            <div class="flex flex-col gap-4">
              <div class="flex items-center gap-4">
                <label for="in-igst" class="w-16 font-semibold text-muted">IGST</label>
                <div class="relative flex-1">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted">₹</span>
                  <input type="number" id="in-igst" class="w-full rounded-md border border-base bg-surface pl-8 pr-4 py-2 text-[16px] font-mono focus:border-accent outline-none" placeholder="0" min="0" />
                </div>
              </div>
              <div class="flex items-center gap-4">
                <label for="in-cgst" class="w-16 font-semibold text-muted">CGST</label>
                <div class="relative flex-1">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted">₹</span>
                  <input type="number" id="in-cgst" class="w-full rounded-md border border-base bg-surface pl-8 pr-4 py-2 text-[16px] font-mono focus:border-accent outline-none" placeholder="0" min="0" />
                </div>
              </div>
              <div class="flex items-center gap-4">
                <label for="in-sgst" class="w-16 font-semibold text-muted">SGST</label>
                <div class="relative flex-1">
                  <span class="absolute left-3 top-1/2 -translate-y-1/2 text-muted">₹</span>
                  <input type="number" id="in-sgst" class="w-full rounded-md border border-base bg-surface pl-8 pr-4 py-2 text-[16px] font-mono focus:border-accent outline-none" placeholder="0" min="0" />
                </div>
              </div>
            </div>
          </div>

        </div>

        <!-- Right: Output / Results -->
        <div class="flex flex-col bg-subtle rounded-xl p-6 border border-base overflow-hidden relative">
          
          <h3 class="text-[14px] font-medium text-muted mb-4 uppercase tracking-wider">Net Tax Payable (Cash)</h3>
          
          <div class="space-y-4 mb-8">
            <div class="flex justify-between items-center pb-3 border-b border-base">
              <span class="font-semibold text-base">IGST Liability:</span>
              <span class="text-xl font-mono text-base" id="pay-igst">₹0</span>
            </div>
            <div class="flex justify-between items-center pb-3 border-b border-base">
              <span class="font-semibold text-base">CGST Liability:</span>
              <span class="text-xl font-mono text-base" id="pay-cgst">₹0</span>
            </div>
            <div class="flex justify-between items-center pb-3 border-b border-base">
              <span class="font-semibold text-base">SGST Liability:</span>
              <span class="text-xl font-mono text-base" id="pay-sgst">₹0</span>
            </div>
            <div class="flex justify-between items-center pt-2">
              <span class="text-lg font-bold text-accent">Total Cash Required:</span>
              <span class="text-3xl font-mono font-bold text-accent" id="pay-total">₹0</span>
            </div>
          </div>

          <h3 class="text-[14px] font-medium text-muted mb-4 uppercase tracking-wider border-t border-base pt-6">ITC Balance Carry Forward</h3>
          <div class="space-y-3">
            <div class="flex justify-between items-center text-muted">
              <span>IGST Balance:</span>
              <span class="font-mono" id="bal-igst">₹0</span>
            </div>
            <div class="flex justify-between items-center text-muted">
              <span>CGST Balance:</span>
              <span class="font-mono" id="bal-cgst">₹0</span>
            </div>
            <div class="flex justify-between items-center text-muted">
              <span>SGST Balance:</span>
              <span class="font-mono" id="bal-sgst">₹0</span>
            </div>
          </div>

        </div>
      </div>
    </div>

    <!-- SEO Content -->
    <article class="prose prose-neutral dark:prose-invert max-w-none text-[15px] leading-relaxed">
      <h2 class="text-2xl font-semibold mb-4">How to Calculate ITC Set-Off under GST?</h2>
      <p>
        Input Tax Credit (ITC) is the backbone of the Goods and Services Tax (GST) system. It prevents the cascading "tax on tax" effect by allowing a business to reduce its final tax liability by claiming credit for the GST paid on purchases. If you buy raw materials worth ₹1,00,000 and pay ₹18,000 as GST, that ₹18,000 sits in your Electronic Credit Ledger as an asset. When you sell your finished goods and owe the government ₹25,000 in GST, you can "set off" the ₹18,000 credit and only pay the remaining ₹7,000 in cash.
      </p>
      <p>
        However, the government has established strict, non-negotiable rules for the order in which this ITC can be utilized. You cannot simply lump all credits together and subtract them from all liabilities. The introduction of <strong>Section 49A</strong> and <strong>Section 49B</strong> of the CGST Act completely changed the utilization algorithm. Our <strong>GST ITC Calculator Online</strong> automatically applies these latest rules to ensure perfect compliance and minimal cash outflow.
      </p>
      
      <h3>The Golden Rule: Exhaust IGST First</h3>
      <p>The most critical mandate of the new GST rules is that <strong>IGST Credit must be completely exhausted first (brought down to ₹0) before you are allowed to touch your CGST or SGST credits.</strong></p>
      
      <h4>Step 1: Utilizing IGST Credit</h4>
      <p>Your IGST (Integrated GST) credit is your most flexible asset. You must use it in this exact order:</p>
      <ol>
        <li>First, use IGST credit to pay off your IGST liability.</li>
        <li>If IGST credit is still left, you must use it to pay off your CGST and SGST liabilities. The law allows you to split this remaining IGST credit between CGST and SGST in <em>any proportion</em>. A smart accountant will allocate it to minimize the overall cash payment. Our calculator handles this optimization perfectly.</li>
        <li><strong>Rule Check:</strong> You cannot use any CGST or SGST credits until your IGST credit balance is exactly ₹0.</li>
      </ol>

      <h4>Step 2: Utilizing CGST Credit</h4>
      <p>Once your IGST credit is zero, you can unlock your CGST (Central GST) credit:</p>
      <ol>
        <li>First, use CGST credit to pay off your CGST liability.</li>
        <li>If CGST credit is still left, use it to pay off your IGST liability.</li>
        <li><strong>CRITICAL BAN:</strong> CGST credit can <em>never</em> be used to pay SGST liability. The central and state tax pools cannot cross over.</li>
      </ol>

      <h4>Step 3: Utilizing SGST Credit</h4>
      <p>Finally, you utilize your SGST (State GST) credit:</p>
      <ol>
        <li>First, use SGST credit to pay off your SGST liability.</li>
        <li>If SGST credit is still left, use it to pay off your IGST liability.</li>
        <li><strong>CRITICAL BAN:</strong> SGST credit can <em>never</em> be used to pay CGST liability.</li>
      </ol>

      <h3>Blocked Credits: Section 17(5)</h3>
      <p>While our calculator handles the mathematical set-off, you must ensure the ITC you input is actually eligible. Under Section 17(5), you cannot claim ITC on certain purchases, even if they are for business use. These include:</p>
      <ul>
        <li>Motor vehicles for passenger transportation (unless you are in the transport or driving school business).</li>
        <li>Food, beverages, outdoor catering, beauty treatments, and health services.</li>
        <li>Membership of clubs, health, and fitness centers.</li>
        <li>Goods given away as free samples or gifts.</li>
        <li>Goods lost, stolen, destroyed, or written off.</li>
      </ul>
      <p>Ensure you deduct any blocked credits before entering your "Available ITC" into the calculator.</p>
    </article>

    <!-- FAQ Section -->
    <section class="mt-16 pt-12 border-t border-base" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-base mb-8">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        
        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>What is the order of ITC utilization under GST?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            Under the new Section 49A, IGST credit must be fully exhausted first (against IGST, then CGST/SGST liability). Only after IGST credit is zero, can you use CGST credit (against CGST, then IGST liability) and SGST credit (against SGST, then IGST liability).
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>Can CGST credit be used to pay SGST liability?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            No. The cross-utilization of CGST and SGST is strictly prohibited. CGST credit cannot be used to pay SGST, and SGST credit cannot be used to pay CGST.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>How do I minimize my cash outflow?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            To minimize cash outflow, you should carefully allocate any remaining IGST credit (after paying IGST liability) towards whichever liability (CGST or SGST) requires the most cash payment, ensuring you don't leave stranded credits. Our calculator handles this distribution optimally.
          </div>
        </details>

      </div>
    </section>

  </div>

  <script>
    const ids = ['out-igst', 'out-cgst', 'out-sgst', 'in-igst', 'in-cgst', 'in-sgst'];
    const inputs = ids.map(id => document.getElementById(id) as HTMLInputElement);
    
    const payIgst = document.getElementById('pay-igst')!;
    const payCgst = document.getElementById('pay-cgst')!;
    const paySgst = document.getElementById('pay-sgst')!;
    const payTotal = document.getElementById('pay-total')!;
    
    const balIgst = document.getElementById('bal-igst')!;
    const balCgst = document.getElementById('bal-cgst')!;
    const balSgst = document.getElementById('bal-sgst')!;

    function formatCur(num: number) {
      return '₹' + Math.max(0, num).toLocaleString('en-IN', { maximumFractionDigits: 2 });
    }

    function calculate() {
      // Parse inputs
      let liabI = parseFloat(inputs[0].value) || 0;
      let liabC = parseFloat(inputs[1].value) || 0;
      let liabS = parseFloat(inputs[2].value) || 0;

      let itcI = parseFloat(inputs[3].value) || 0;
      let itcC = parseFloat(inputs[4].value) || 0;
      let itcS = parseFloat(inputs[5].value) || 0;

      // 1. Utilize IGST ITC
      // First against IGST liability
      let useIgstForIgst = Math.min(itcI, liabI);
      itcI -= useIgstForIgst;
      liabI -= useIgstForIgst;

      // If IGST ITC left, utilize against CGST and SGST
      if (itcI > 0) {
        // Simple logic: split it equally, but prioritize whatever is larger to minimize cash
        let useIgstForCgst = Math.min(itcI, liabC);
        itcI -= useIgstForCgst;
        liabC -= useIgstForCgst;

        let useIgstForSgst = Math.min(itcI, liabS);
        itcI -= useIgstForSgst;
        liabS -= useIgstForSgst;
      }

      // 2. Utilize CGST ITC
      // First against CGST liability
      let useCgstForCgst = Math.min(itcC, liabC);
      itcC -= useCgstForCgst;
      liabC -= useCgstForCgst;

      // Then against IGST liability
      let useCgstForIgst = Math.min(itcC, liabI);
      itcC -= useCgstForIgst;
      liabI -= useCgstForIgst;

      // 3. Utilize SGST ITC
      // First against SGST liability
      let useSgstForSgst = Math.min(itcS, liabS);
      itcS -= useSgstForSgst;
      liabS -= useSgstForSgst;

      // Then against IGST liability
      let useSgstForIgst = Math.min(itcS, liabI);
      itcS -= useSgstForIgst;
      liabI -= useSgstForIgst;

      // Display Results
      payIgst.textContent = formatCur(liabI);
      payCgst.textContent = formatCur(liabC);
      paySgst.textContent = formatCur(liabS);
      payTotal.textContent = formatCur(liabI + liabC + liabS);

      balIgst.textContent = formatCur(itcI);
      balCgst.textContent = formatCur(itcC);
      balSgst.textContent = formatCur(itcS);
    }

    inputs.forEach(input => input.addEventListener('input', calculate));
  </script>
</BaseLayout>
