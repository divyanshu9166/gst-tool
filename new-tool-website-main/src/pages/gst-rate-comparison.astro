---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Old vs New GST Rate Comparison Tool | Rate Change Impact';
const description = 'Free offline old vs new GST rate comparison tool. Instantly calculate the GST 2.0 rate change impact on your prices and margins.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GST Rate Comparison Tool',
    url: `${Astro.site?.toString() ?? 'https://example.com'}/gst-rate-comparison`,
    description: description,
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
    offers: { '@type': 'Offer', price: '0', priceCurrency: 'INR' },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: 'What is the difference between old GST rates and GST 2.0 rates?', acceptedAnswer: { '@type': 'Answer', text: 'Before September 2025, GST had five slabs: 0%, 5%, 12%, 18%, and 28%. Under GST 2.0 (effective 22 September 2025), the structure was simplified to mainly 0%, 5%, and 18%, with a new 40% luxury slab. The 12% and 28% slabs were largely merged or restructured.' } },
      { '@type': 'Question', name: 'How do I calculate the price impact of a GST rate change on my product?', acceptedAnswer: { '@type': 'Answer', text: 'To calculate the price impact: (1) Multiply the base price (excluding tax) by the old rate to get old tax. (2) Multiply the same base price by the new rate to get new tax. (3) The difference in tax amounts is the price impact on the consumer. Our Rate Comparison tool does this instantly.' } },
      { '@type': 'Question', name: 'If the GST rate on my product dropped, should I reduce my selling price?', acceptedAnswer: { '@type': 'Answer', text: 'Legally, yes. Under the Anti-Profiteering provisions (Section 171 of the CGST Act), if a GST rate reduction results in lower tax, the supplier must pass on the commensurate benefit to the consumer by reducing prices. Failure to do so can attract anti-profiteering investigations.' } },
      { '@type': 'Question', name: 'Does a GST rate change affect my Input Tax Credit (ITC)?', acceptedAnswer: { '@type': 'Answer', text: 'A rate reduction to a lower taxable slab (e.g., 12% to 5%) does not generally require ITC reversal. However, if the rate drops to 0% (Exempt), you must reverse ITC proportional to your exempt supplies under Rule 42/43.' } },
      { '@type': 'Question', name: 'What is the new 40% GST slab introduced in GST 2.0?', acceptedAnswer: { '@type': 'Answer', text: 'The 40% GST slab was introduced as a new luxury/sin goods category under GST 2.0. It applies to certain high-value luxury goods, aerated beverages, tobacco products, and sin goods that were previously taxed at 28% plus applicable cess.' } },
      { '@type': 'Question', name: 'How does the GST rate change affect my MRP-inclusive pricing?', acceptedAnswer: { '@type': 'Answer', text: 'If your product is sold at MRP-inclusive prices, a GST rate change means you must recalculate your base margin. Use our MRP Revision Calculator to find the exact new MRP that preserves your original base price and margin after the rate change.' } },
      { '@type': 'Question', name: 'When did GST 2.0 rates become effective?', acceptedAnswer: { '@type': 'Answer', text: 'GST 2.0 rate changes became effective from 22 September 2025, following the decisions of the 55th GST Council Meeting. The simplified slab structure (0%, 5%, 18%, 40%) replaced the older five-tier system.' } },
      { '@type': 'Question', name: 'Are services also affected by GST 2.0 rate changes?', acceptedAnswer: { '@type': 'Answer', text: 'Yes, some services were also reclassified under GST 2.0. The 12% slab for several service categories was abolished, with services moving to either the 5% or 18% bracket depending on their nature.' } },
      { '@type': 'Question', name: 'Can I use old GST rates for invoices raised before the GST 2.0 change date?', acceptedAnswer: { '@type': 'Answer', text: 'Yes. Invoices dated before the effective date of the rate change (22 September 2025) should use the old applicable rates. Only invoices from the effective date onwards must use the new GST 2.0 rates.' } },
      { '@type': 'Question', name: 'What is a rate comparison tool useful for?', acceptedAnswer: { '@type': 'Answer', text: 'A GST rate comparison tool is useful for: (1) Calculating the exact consumer price difference between old and new rates, (2) Planning product pricing strategy after a rate change, (3) Training your billing team on the new tax amounts, and (4) Communicating price changes transparently to customers.' } },
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-12 text-center">
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-[-1.28px] text-base mb-4">Old vs New GST Rate Comparison Tool</h1>
      <p class="text-[16px] text-muted max-w-2xl mx-auto leading-relaxed">
        <strong>How does GST 2.0 affect your pricing?</strong> Enter your base price and compare the old rate (pre-Sept-2025) with the new slab to instantly see the price impact for your customers.
      </p>
    </div>

    <div class="max-w-4xl mx-auto space-y-8">
      
      <!-- Inputs -->
      <div class="rounded-[8px] border border-base bg-surface p-[24px] shadow-[0_2px_2px_#0000000a,0_8px_8px_-8px_#0000000a]">
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          
          <div>
            <label for="base-price" class="block text-[14px] font-medium text-base mb-2">Base Price (excl. tax)</label>
            <div class="relative">
              <span class="absolute left-4 top-1/2 -translate-y-1/2 text-muted font-medium select-none" aria-hidden="true">₹</span>
              <input id="base-price" type="number" min="0" placeholder="0" value="1000" class="w-full rounded-[8px] border border-base bg-subtle pl-9 pr-4 py-3 text-[16px] focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all shadow-inner" />
            </div>
          </div>
          
          <div>
            <label for="old-rate" class="block text-[14px] font-medium text-base mb-2">Old Rate (Legacy)</label>
            <select id="old-rate" class="w-full rounded-[8px] border border-base bg-subtle px-4 py-3 text-[16px] focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all cursor-pointer">
              <option value="0">0%</option>
              <option value="5">5%</option>
              <option value="12" selected>12%</option>
              <option value="18">18%</option>
              <option value="28">28%</option>
            </select>
          </div>
          
          <div>
            <label for="new-rate" class="block text-[14px] font-medium text-base mb-2">New Rate (GST 2.0)</label>
            <select id="new-rate" class="w-full rounded-[8px] border border-base bg-subtle px-4 py-3 text-[16px] focus:border-accent focus:outline-none focus:ring-2 focus:ring-accent/20 transition-all cursor-pointer">
              <option value="0">0%</option>
              <option value="5">5%</option>
              <option value="18" selected>18%</option>
              <option value="40">40%</option>
            </select>
          </div>

        </div>
      </div>

      <!-- Outputs -->
      <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
        
        <!-- Old Rate Card -->
        <div class="rounded-[8px] border border-base bg-subtle p-[24px]">
          <h2 class="text-[18px] font-semibold text-base mb-4 pb-2 border-b border-base text-muted">Old Tax Scenario</h2>
          <div class="space-y-4">
            <div class="flex justify-between items-center text-[15px]">
              <span class="text-muted">Base Price</span>
              <span class="font-medium" id="old-base">₹0</span>
            </div>
            <div class="flex justify-between items-center text-[15px]">
              <span class="text-muted">GST Amount (<span id="old-rate-label">0%</span>)</span>
              <span class="font-medium" id="old-tax">₹0</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-base">
              <span class="text-[16px] font-semibold">Total Price (MRP)</span>
              <span class="text-[24px] font-bold" id="old-total">₹0</span>
            </div>
          </div>
        </div>

        <!-- New Rate Card -->
        <div class="rounded-[8px] border border-accent bg-accent/5 p-[24px]">
          <h2 class="text-[18px] font-semibold text-base mb-4 pb-2 border-b border-accent/20 text-accent">New Tax Scenario (GST 2.0)</h2>
          <div class="space-y-4">
            <div class="flex justify-between items-center text-[15px]">
              <span class="text-muted">Base Price</span>
              <span class="font-medium" id="new-base">₹0</span>
            </div>
            <div class="flex justify-between items-center text-[15px]">
              <span class="text-muted">GST Amount (<span id="new-rate-label">0%</span>)</span>
              <span class="font-medium" id="new-tax">₹0</span>
            </div>
            <div class="flex justify-between items-center pt-3 border-t border-accent/20">
              <span class="text-[16px] font-semibold">Total Price (MRP)</span>
              <span class="text-[24px] font-bold text-accent" id="new-total">₹0</span>
            </div>
          </div>
        </div>

      </div>

      <!-- Impact Card -->
      <div class="rounded-[8px] border border-base bg-surface p-[24px] text-center" id="impact-card">
        <h3 class="text-[16px] font-medium text-muted mb-2">Net Impact to Consumer</h3>
        <p class="text-[32px] font-bold tracking-tight" id="impact-val">No Change</p>
        <p class="text-[14px] text-muted mt-1" id="impact-desc"></p>
      </div>

    </div>
  </div>

  
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/calculate-gst-late-fees" class="text-primary hover:underline">How to Calculate GST Late Fees in 2026: A Complete Guide</a></li>
        <li><a href="/blog/interest-on-gst-paid-via-itc" class="text-primary hover:underline">Do You Pay 18% Interest on GST Paid via ITC?</a></li>
      </ul>
    </div>
  </div>
<!-- FAQ Section -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16">
    <div class="border-t border-base pt-12">
      <h2 class="text-[28px] tracking-[-1px] font-semibold text-base mb-2">Frequently Asked Questions</h2>
      <p class="text-muted text-[15px] mb-8">Common questions about comparing old vs new GST 2.0 rates and understanding price impact.</p>
      <div class="space-y-3">
        {[
          { q: 'What changed between old GST rates and GST 2.0 rates?', a: 'The old GST structure had 5 slabs: 0%, 5%, 12%, 18%, and 28%. Under GST 2.0 (effective 22 September 2025), this was simplified. The 12% slab was largely abolished, items were merged into 5% or 18%, and a new 40% luxury slab was created for sin/luxury goods that replaced the old 28% + cess structure.' },
          { q: 'How do I calculate the exact price impact of a GST rate change?', a: 'Take your base price (excluding tax). Multiply by the old rate to get old tax amount, then multiply by the new rate to get the new tax amount. The difference is the price impact on the consumer. For example, if base price is ₹1,000 and rate drops from 12% to 5%, old tax = ₹120, new tax = ₹50, saving = ₹70 per unit.' },
          { q: 'Am I legally required to reduce prices if GST rate drops on my product?', a: 'Yes, under Section 171 of the CGST Act (Anti-Profiteering), you must pass on the benefit of a GST rate reduction to your consumers. The National Anti-Profiteering Authority (NAA) investigates complaints, and non-compliance can result in penalties and forced refunds to customers.' },
          { q: 'What is the new 40% GST slab in GST 2.0?', a: 'The 40% slab was introduced as a consolidated luxury/sin goods bracket under GST 2.0. It covers high-end luxury goods, premium aerated beverages, tobacco products, and certain demerit goods. This replaced the old system of 28% base rate + compensation cess, making the total effective rate clearer.' },
          { q: 'Can I still use the 12% GST rate for old invoices?', a: 'Yes. The applicable GST rate is determined by the date of supply (invoice date / date of delivery, whichever is earlier). Invoices dated before 22 September 2025 use the old rates. Invoices from the effective date onwards must use the new GST 2.0 rates.' },
          { q: 'How does a rate increase affect my customers?', a: 'A rate increase means higher tax for the same base price, which increases the consumer-facing total price. You must update your billing system, price lists, and invoices to reflect the new GST-inclusive price. Failure to charge the correct higher rate means you pay the difference from your own pocket.' },
          { q: 'Does a GST rate change require me to reverse ITC?', a: 'A rate drop to a lower taxable slab (e.g., 12% to 5%) does NOT require ITC reversal on previously purchased inputs. However, if a product becomes Exempt (0%), you must reverse ITC on closing stock proportional to exempt supplies under Rule 42 of the CGST Rules.' },
          { q: 'How does GST rate change affect B2B buyers?', a: 'For B2B buyers, both the tax amount on their purchase invoice and the ITC they can claim changes proportionally with the rate change. If rates go down, they claim less ITC but also pay less cash. The net effect is usually neutral on fully ITC-eligible purchases.' },
          { q: 'Does this comparison tool work for services?', a: 'Yes. The tool compares GST rates for any taxable category, including services. Just select the old service rate (e.g., 12%) and the new rate (e.g., 18%) and enter the base service fee to see the exact impact on the final invoice amount.' },
          { q: 'When did GST 2.0 come into effect?', a: 'GST 2.0 rate changes came into effect on 22 September 2025, following the 55th GST Council Meeting decisions. All suppliers were required to update their billing systems, ERP software, and price lists from that date.' },
        ].map((faq, i) => (
          <details class="group rounded-[8px] border border-base bg-surface overflow-hidden" id={`faq-grc-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span class="text-[15px]">{faq.q}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[14px] text-muted leading-relaxed border-t border-base pt-4">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script>
const inBasePrice = document.getElementById("base-price");
const inOldRate = document.getElementById("old-rate");
const inNewRate = document.getElementById("new-rate");
const oldBase = document.getElementById("old-base");
const oldTax = document.getElementById("old-tax");
const oldTotal = document.getElementById("old-total");
const oldRateLabel = document.getElementById("old-rate-label");
const newBase = document.getElementById("new-base");
const newTax = document.getElementById("new-tax");
const newTotal = document.getElementById("new-total");
const newRateLabel = document.getElementById("new-rate-label");
const impactCard = document.getElementById("impact-card");
const impactVal = document.getElementById("impact-val");
const impactDesc = document.getElementById("impact-desc");
function formatINR(val) {
  const rounded = Math.round(val * 100) / 100;
  return "\u20B9" + rounded.toLocaleString("en-IN", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
}
function formatINRWhole(val) {
  return "\u20B9" + Math.round(val).toLocaleString("en-IN");
}
function calculate() {
  const basePrice = parseFloat(inBasePrice.value) || 0;
  const oldRate = parseFloat(inOldRate.value) || 0;
  const newRate = parseFloat(inNewRate.value) || 0;
  const oldTaxAmount = basePrice * (oldRate / 100);
  const oldTotalAmount = basePrice + oldTaxAmount;
  const newTaxAmount = basePrice * (newRate / 100);
  const newTotalAmount = basePrice + newTaxAmount;
  oldBase.textContent = formatINRWhole(basePrice);
  oldTax.textContent = formatINR(oldTaxAmount);
  oldTotal.textContent = formatINR(oldTotalAmount);
  oldRateLabel.textContent = `${oldRate}%`;
  newBase.textContent = formatINRWhole(basePrice);
  newTax.textContent = formatINR(newTaxAmount);
  newTotal.textContent = formatINR(newTotalAmount);
  newRateLabel.textContent = `${newRate}%`;
  const difference = newTotalAmount - oldTotalAmount;
  if (difference > 5e-3) {
    impactCard.className = "rounded-[8px] border border-red-500 bg-red-50 dark:bg-red-900/10 p-[24px] text-center";
    impactVal.textContent = `+ ${formatINR(Math.abs(difference))}`;
    impactVal.className = "text-[32px] font-bold tracking-tight text-red-600 dark:text-red-400";
    impactDesc.textContent = "Price increase for the end consumer.";
  } else if (difference < -5e-3) {
    impactCard.className = "rounded-[8px] border border-green-500 bg-green-50 dark:bg-green-900/10 p-[24px] text-center";
    impactVal.textContent = `- ${formatINR(Math.abs(difference))}`;
    impactVal.className = "text-[32px] font-bold tracking-tight text-green-600 dark:text-green-400";
    impactDesc.textContent = "Price reduction for the end consumer.";
  } else {
    impactCard.className = "rounded-[8px] border border-base bg-subtle p-[24px] text-center";
    impactVal.textContent = "No Change";
    impactVal.className = "text-[32px] font-bold tracking-tight text-base";
    impactDesc.textContent = "The consumer pays the exact same amount.";
  }
}
inBasePrice.addEventListener("input", calculate);
inOldRate.addEventListener("change", calculate);
inNewRate.addEventListener("change", calculate);
calculate();
</script>
