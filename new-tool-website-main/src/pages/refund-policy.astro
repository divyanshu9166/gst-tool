---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Refund Policy';
const description = 'Our refund policy.';
---

<BaseLayout {title} {description}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Refund Policy</h1>
    <p class="text-xl text-muted">Since our tools are free, there are no charges to refund.</p>
  </div>
</BaseLayout>