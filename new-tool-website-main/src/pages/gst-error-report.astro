---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GST Error Report Decoder | Fix GST JSON Errors Online';
const description = 'Decode GST portal error JSON files instantly. Upload your GSTR 1 error report to view human-readable error messages and easily fix compliance issues.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GST Error Report Decoder',
    url: `${Astro.site?.toString() ?? 'https://example.com'}/gst-error-report`,
    description: 'Instantly decode GST Error JSON files generated after failed GSTR-1 offline uploads.',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is a GST Error Report JSON?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'When you upload an offline JSON to the GST portal and there are discrepancies (like duplicate invoices or invalid GSTINs), the portal generates an Error Report link. This link contains a JSON file detailing exactly which invoices failed.'
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-base mb-3">GST Error Report Decoder</h1>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        Analyze the error JSON files generated by the GST Portal. View what went wrong with your uploaded invoices in a clear, readable table format.
      </p>
    </div>

    <div class="bg-surface border border-base rounded-2xl p-8 shadow-sm">
      <div class="max-w-xl mx-auto space-y-6">
        <div>
          <label class="block text-sm font-medium text-base mb-2">Upload Error JSON File</label>
          <input 
            type="file" 
            id="errorFileInput" 
            accept="application/json"
            class="block w-full text-sm text-muted file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-accent file:text-white hover:file:bg-accent/90"
          />
        </div>
        <div>
          <button id="analyzeBtn" class="w-full bg-accent hover:bg-accent/90 text-white font-semibold py-3 px-4 rounded-xl transition-colors">
            Analyze Error Report
          </button>
        </div>
      </div>

      <div id="resultsArea" class="mt-10 hidden border-t border-base pt-8">
        <h3 class="text-xl font-bold mb-4">Error Breakdown</h3>
        <div class="overflow-x-auto rounded-lg border border-base">
          <table class="min-w-full text-sm text-left">
            <thead class="bg-subtle text-muted">
              <tr>
                <th class="px-4 py-3 font-semibold border-b border-base">Section</th>
                <th class="px-4 py-3 font-semibold border-b border-base">Invoice #</th>
                <th class="px-4 py-3 font-semibold border-b border-base">Error Code</th>
                <th class="px-4 py-3 font-semibold border-b border-base">Error Message</th>
              </tr>
            </thead>
            <tbody id="errorTableBody" class="divide-y divide-base">
              <!-- Rows inserted by JS -->
            </tbody>
          </table>
        </div>
        <div id="noErrors" class="hidden mt-4 text-green-600 font-medium text-center">
          No error records found in this file!
        </div>
      </div>
      
      <div id="errorMsg" class="hidden text-sm text-center mt-6 p-4 bg-red-50 text-red-700 rounded-lg border border-red-200">
        Failed to read the file. Are you sure it's a valid GST error JSON?
      </div>
    </div>
    
    <div class="mt-16 prose prose-slate max-w-none text-muted">
      <h2>How to read the GST Error Report?</h2>
      <p>When you upload JSON payload via the GST Offline Tool and some invoices contain errors (like invalid GSTINs, duplicate invoices, incorrect tax rates), the portal generates an "Error Report". This decoder parses that obfuscated JSON and highlights precisely which invoices failed and why.</p>
      
      <h3>Frequently Asked Questions</h3>
      <dl class="space-y-4">
        <div>
          <dt class="font-bold text-base">What is a GST Error Report JSON?</dt>
          <dd>When you upload an offline JSON to the GST portal and there are discrepancies (like duplicate invoices or invalid GSTINs), the portal generates an Error Report link. This link contains a JSON file detailing exactly which invoices failed.</dd>
        </div>
        <div>
          <dt class="font-bold text-base">Are my invoices uploaded online?</dt>
          <dd>No. Our tool decodes the JSON offline directly in your web browser. Nothing is uploaded to our servers.</dd>
        </div>
      </dl>
    </div>
  </div>

  <script is:inline>
    document.getElementById('analyzeBtn').addEventListener('click', () => {
      const fileInput = document.getElementById('errorFileInput');
      const resultsArea = document.getElementById('resultsArea');
      const errorTableBody = document.getElementById('errorTableBody');
      const noErrors = document.getElementById('noErrors');
      const errorMsg = document.getElementById('errorMsg');
      
      resultsArea.classList.add('hidden');
      errorMsg.classList.add('hidden');
      noErrors.classList.add('hidden');
      errorTableBody.innerHTML = '';

      if (!fileInput.files.length) {
        alert('Please select a JSON file first.');
        return;
      }

      const file = fileInput.files[0];
      const reader = new FileReader();

      reader.onload = (e) => {
        try {
          const data = JSON.parse(e.target.result);
          const trs = [];

          // The GST portal error JSON generally structure looks similar to normal GSTR1 but contains "error_msg" nodes.
          // We will recursively search for "error_msg" or "error_cd"
          function searchErrors(obj, contextSection, contextInv) {
            if (Array.isArray(obj)) {
              obj.forEach(item => searchErrors(item, contextSection, contextInv));
            } else if (typeof obj === 'object' && obj !== null) {
              
              let currentInvoice = obj.inum || obj.doc_num || contextInv;
              
              if (obj.error_msg || obj.error_cd || obj.error_code) {
                trs.push(`
                  <tr class="hover:bg-subtle transition-colors">
                    <td class="px-4 py-3 whitespace-nowrap">${contextSection || 'Unknown'}</td>
                    <td class="px-4 py-3 whitespace-nowrap font-mono">${currentInvoice || 'N/A'}</td>
                    <td class="px-4 py-3 text-red-600 font-semibold">${obj.error_cd || obj.error_code || 'Err'}</td>
                    <td class="px-4 py-3 text-red-500">${obj.error_msg || obj.error_message || 'Validation Failed'}</td>
                  </tr>
                `);
              }

              for (const key in obj) {
                if (typeof obj[key] === 'object') {
                  const section = ['b2b', 'b2cl', 'b2cs', 'exp', 'cdnr', 'cdnur'].includes(key) ? key.toUpperCase() : contextSection;
                  searchErrors(obj[key], section, currentInvoice);
                }
              }
            }
          }

          searchErrors(data, '', '');

          if (trs.length > 0) {
            errorTableBody.innerHTML = trs.join('');
          } else {
            noErrors.classList.remove('hidden');
          }

          resultsArea.classList.remove('hidden');

        } catch (err) {
          console.error(err);
          errorMsg.classList.remove('hidden');
        }
      };

      reader.readAsText(file);
    });
  </script>
</BaseLayout>