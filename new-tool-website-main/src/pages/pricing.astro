---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Pricing - Free GST Tools';
const description = 'Pricing page. Good news! All our GST tools are completely free to use.';
---

<BaseLayout {title} {description}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Pricing</h1>
    <p class="text-xl text-muted">Good news! All our tools are currently 100% free to use. Enjoy our calculators and validation tools at no cost.</p>
  </div>
</BaseLayout>