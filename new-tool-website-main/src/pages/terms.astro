---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Terms & Conditions | Taxzentic';
const description = 'Terms and Conditions for using Taxzentic — our free Tax Calculator, HSN Code Lookup, and GSTIN Validator tools.';
const lastUpdated = '18 June 2025';
---

<BaseLayout {title} {description}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <div class="mb-8">
      <h1 class="text-3xl font-bold text-base mb-2">Terms & Conditions</h1>
      <p class="text-sm text-muted">Last updated: {lastUpdated}</p>
    </div>

    <div class="prose prose-neutral dark:prose-invert max-w-none space-y-6 text-base leading-relaxed text-muted">

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">1. Acceptance of Terms</h2>
        <p>
          By accessing and using <strong>Taxzentic</strong> (the "Website"), you agree to be bound by these Terms & Conditions. If you do not agree, please do not use the Website.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">2. Description of Service</h2>
        <p>
          Taxzentic provides free, informational tax tools including a GST Calculator, HSN/SAC Code Lookup, and GSTIN Validator. These tools are designed to assist users in understanding and working with India's Goods and Services Tax system.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">3. Disclaimer of Accuracy</h2>
        <p>
          <strong>Important:</strong> The information, calculations, and data provided on this Website are for <strong>informational and educational purposes only</strong>. While we strive for accuracy:
        </p>
        <ul class="list-disc pl-5 space-y-1">
          <li>GST rates and rules are subject to change by the Government of India and the GST Council.</li>
          <li>HSN/SAC codes and their associated rates are indicative and may not reflect the most recent notifications.</li>
          <li>GSTIN validation checks format and checksum only — it does not verify real-time registration status with the GST portal.</li>
          <li>We make no warranty, express or implied, regarding the accuracy, completeness, or fitness for a particular purpose of any information on this Website.</li>
        </ul>
        <p class="mt-3">
          Always verify GST-related information with the official GST portal at <a href="https://www.gst.gov.in" target="_blank" rel="noopener noreferrer" class="text-accent hover:underline">gst.gov.in</a> or consult a qualified Chartered Accountant or GST practitioner.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">4. No Professional Advice</h2>
        <p>
          Nothing on this Website constitutes legal, financial, tax, or professional advice. Use of this Website does not create a professional-client relationship. For specific tax advice, consult a qualified professional.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">5. Limitation of Liability</h2>
        <p>
          To the maximum extent permitted by applicable law, Taxzentic and its operators shall not be liable for any direct, indirect, incidental, special, consequential, or punitive damages arising from your use of, or inability to use, this Website or its tools — including but not limited to errors in GST calculations, incorrect HSN codes, or GSTIN validation results.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">6. Intellectual Property</h2>
        <p>
          All content on this Website, including text, design, code, and data, is the property of Taxzentic or its licensors. You may not reproduce, distribute, or create derivative works without prior written permission, except for personal, non-commercial use.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">7. Third-Party Links</h2>
        <p>
          This Website may contain links to third-party websites. We are not responsible for the content, accuracy, or practices of those websites. Links are provided for convenience only.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">8. Governing Law</h2>
        <p>
          These Terms shall be governed by and construed in accordance with the laws of India. Any disputes shall be subject to the exclusive jurisdiction of the courts of India.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">9. Changes to Terms</h2>
        <p>
          We reserve the right to modify these Terms at any time. Changes will be effective immediately upon posting. Continued use of the Website after changes constitutes acceptance of the revised Terms.
        </p>
      </section>

      <section>
        <h2 class="text-xl font-semibold text-base mb-3">10. Contact</h2>
        <p>
          For questions about these Terms, please <a href="/contact" class="text-accent hover:underline">contact us</a>.
        </p>
      </section>
    </div>
  </div>
</BaseLayout>
