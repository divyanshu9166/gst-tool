---
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqs } from '../data/faqs';

const title = 'GST FAQ — Frequently Asked Questions about GST in India';
const description = 'Answers to the most common GST questions: what is GST, how to get GST number, GST full form, how to file GST return, GSTIN check, new GST rates 2025, and more.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'FAQPage',
  mainEntity: faqs.map((faq) => ({
    '@type': 'Question',
    name: faq.question,
    acceptedAnswer: {
      '@type': 'Answer',
      text: `<p>${faq.answerText}</p>`,
    },
  })),
};
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Page header -->
    <div class="mb-10 text-center">
      <h1 class="text-3xl sm:text-4xl font-bold text-base mb-3">
        GST Frequently Asked Questions
      </h1>
      <p class="text-muted max-w-xl mx-auto">
        Everything you need to know about GST in India — from registration and returns to rates and GSTIN validation.
      </p>
    </div>

    <!-- FAQ accordion -->
    <div class="space-y-3" itemscope itemtype="https://schema.org/FAQPage">
      {faqs.map((faq, i) => (
        <details
          class="group rounded-xl border border-base bg-surface overflow-hidden"
          id={`faq-${i}`}
          itemscope
          itemprop="mainEntity"
          itemtype="https://schema.org/Question"
        >
          <summary
            class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none"
            itemprop="name"
          >
            <span>{faq.question}</span>
            <svg
              class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div
            class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4 space-y-2"
            itemscope
            itemprop="acceptedAnswer"
            itemtype="https://schema.org/Answer"
          >
            <div itemprop="text">
              <Fragment set:html={faq.answerHtml} />
            </div>
          </div>
        </details>
      ))}
    </div>

    <!-- CTA -->
    <div class="mt-12 rounded-2xl border border-base bg-subtle p-8 text-center">
      <h2 class="text-xl font-semibold text-base mb-2">Ready to use our GST tools?</h2>
      <p class="text-sm text-muted mb-6">Free, instant, and works offline — no login required.</p>
      <div class="flex flex-col sm:flex-row gap-3 justify-center">
        <a
          href="/gst-calculator"
          class="inline-flex items-center justify-center gap-2 rounded-lg bg-accent px-5 py-2.5 text-sm font-semibold text-white hover:opacity-90 transition-opacity"
        >
          🧮 GST Calculator
        </a>
        <a
          href="/hsn-code-lookup"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-base bg-surface px-5 py-2.5 text-sm font-semibold text-base hover:bg-subtle transition-colors"
        >
          🔍 HSN Code Lookup
        </a>
        <a
          href="/gstin-validator"
          class="inline-flex items-center justify-center gap-2 rounded-lg border border-base bg-surface px-5 py-2.5 text-sm font-semibold text-base hover:bg-subtle transition-colors"
        >
          ✅ GSTIN Validator
        </a>
      </div>
    </div>
  </div>
</BaseLayout>
