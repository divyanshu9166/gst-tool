---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'Merge Excel Files Online | Combine Multiple Workbooks Tool';
const description = 'Free tool to easily combine and merge multiple Excel (.xlsx, .xls) files into one single Excel document. Secure, offline merge right in your browser.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'Merge Excel Files',
    url: `${Astro.site?.toString() ?? 'https://example.com'}/merge-excel-files`,
    description: 'Combine multiple Excel sheets or workbooks into a single file.',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: "How do I merge multiple Excel files online safely?", acceptedAnswer: { '@type': 'Answer', text: "You can drag and drop multiple Excel files into our tool. It merges them into a single workbook offline in your browser, guaranteeing your data privacy." } },
      { '@type': 'Question', name: "Why merge Excel files for GST filing?", acceptedAnswer: { '@type': 'Answer', text: "Businesses often download multiple GSTR-2B, error reports, or branch-wise sales data. Merging them into one master Excel file makes reconciliation and filtering much easier." } },
      { '@type': 'Question', name: "Does the tool preserve Excel sheets during merging?", acceptedAnswer: { '@type': 'Answer', text: "Yes. Our tool can either append data from identically named sheets together or combine different files into separate sheets within the master workbook." } },
      { '@type': 'Question', name: "Is there a limit to how many files I can merge?", acceptedAnswer: { '@type': 'Answer', text: "There is no hard limit on the number of files, but merging dozens of massive files may consume significant browser memory." } },
      { '@type': 'Question', name: "Do I need to install any software to merge files?", acceptedAnswer: { '@type': 'Answer', text: "No installation is required. The merging process uses WebAssembly and JavaScript directly in your web browser." } },
      { '@type': 'Question', name: "Does it support .csv and .xlsx formats?", acceptedAnswer: { '@type': 'Answer', text: "Yes, our tool supports both modern .xlsx files and standard .csv files, converting them seamlessly into one output format." } },
      { '@type': 'Question', name: "Will the formatting of my Excel files be lost?", acceptedAnswer: { '@type': 'Answer', text: "Basic data and structure are perfectly preserved. However, complex macros, charts, or advanced conditional formatting may not carry over during the merge." } },
      { '@type': 'Question', name: "Are my merged files stored on your servers?", acceptedAnswer: { '@type': 'Answer', text: "Absolutely not. The entire file reading, merging, and downloading process happens on your local device." } },
      {
        '@type': 'Question',
        name: 'Is the Excel merge process secure?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, the merge process is 100% secure. Everything happens locally within your web browser. Your confidential data is never uploaded to our servers.'
        }
      },
      {
        '@type': 'Question',
        name: 'Is there a limit on how many Excel files I can merge?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Since processing is done by your browser, it largely depends on your system memory. Typically, merging up to 50-100 files of moderate size works seamlessly.'
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-base mb-3">Merge Excel Files</h1>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        Got multiple GST reports or purchase registers? Combine multiple Excel documents into a single workbook securely within your browser.
      </p>
    </div>

    <div class="bg-surface border border-base rounded-2xl p-8 shadow-sm">
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-base mb-2">Select Multiple Excel Files</label>
          <input 
            type="file" 
            id="excelFilesInput" 
            accept=".xlsx, .xls, .csv"
            multiple
            class="block w-full text-sm text-muted file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-accent file:text-white hover:file:bg-accent/90"
          />
          <p class="text-xs text-muted mt-2">Hold Ctrl/Cmd or shift to select multiple files.</p>
        </div>
        <div>
          <button id="mergeBtn" class="w-full bg-accent hover:bg-accent/90 text-white font-semibold py-3 px-4 rounded-xl transition-colors">
            Merge Files & Download
          </button>
        </div>

        <div id="output" class="hidden text-sm text-center p-4 bg-green-50 text-green-700 rounded-lg border border-green-200">
          Files successfully merged! Downloading the combined Excel file...
        </div>
        <div id="errorMsg" class="hidden text-sm text-center p-4 bg-red-50 text-red-700 rounded-lg border border-red-200">
          Error merging files. Ensure they are valid Excel/CSV formats.
        </div>
      </div>
    </div>
    
    <div class="mt-16 prose prose-slate max-w-none text-muted">
      <h2>How do I merge Excel files?</h2>
      <p>Sometimes you need to consolidate multiple data downloads (e.g. from Tally, Zoho, or GST Portal) into one unified file for tallying or offline preparation. Our free merge tool combines all the sheets from each selected file into one large workbook. If you upload 3 files with 2 sheets each, you will download 1 file with 6 sheets.</p>
      
      
    </div>
  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script is:inline>
    document.getElementById('mergeBtn').addEventListener('click', async () => {
      const fileInput = document.getElementById('excelFilesInput');
      const output = document.getElementById('output');
      const errorMsg = document.getElementById('errorMsg');
      
      output.classList.add('hidden');
      errorMsg.classList.add('hidden');

      if (!fileInput.files.length) {
        alert('Please select at least 2 Excel files to merge.');
        return;
      }
      
      if (fileInput.files.length === 1) {
        alert('Please select more than 1 file to merge.');
        return;
      }

      try {
        const combinedWb = XLSX.utils.book_new();
        let sheetIndex = 1;

        for (const file of Array.from(fileInput.files)) {
          const buffer = await file.arrayBuffer();
          const wb = XLSX.read(buffer, { type: 'array' });
          
          wb.SheetNames.forEach(sheetName => {
            const ws = wb.Sheets[sheetName];
            // Name conflicts can happen, so let's guarantee unique names if necessary
            let newSheetName = sheetName;
            if (combinedWb.SheetNames.includes(newSheetName)) {
              newSheetName = `${sheetName}_${sheetIndex}`;
            }
            sheetIndex++;
            XLSX.utils.book_append_sheet(combinedWb, ws, newSheetName.substring(0, 31)); // Excel limits sheet names to 31 chars
          });
        }

        XLSX.writeFile(combinedWb, 'Merged_Excel_Files.xlsx');
        output.classList.remove('hidden');
        
      } catch (err) {
        console.error(err);
        errorMsg.classList.remove('hidden');
      }
    });
  </script>

    <!-- FAQ Section -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16 pt-12 border-t border-base" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-base mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {structuredData[1].mainEntity.map((faq, i) => (
          <details class="group rounded-xl border border-base bg-surface overflow-hidden" id={`faq-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span>{faq.name}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[15px] text-muted leading-relaxed border-t border-base pt-4">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
</BaseLayout>