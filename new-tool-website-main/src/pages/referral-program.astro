---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Referral Program';
const description = 'Referral program for our free GST tools.';
---

<BaseLayout {title} {description}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Referral Program</h1>
    <p class="text-xl text-muted">Love our tools? Share them with your fellow CA/CS friends or business connections.</p>
  </div>
</BaseLayout>