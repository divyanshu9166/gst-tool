---
import BaseLayout from '../layouts/BaseLayout.astro';
import { faqs } from '../data/faqs';

const title = 'Free GST Tool Online — Calculator, Offline Tool & E-Commerce Tools';
const description = 'The ultimate free GST tool for India. Use our GST tool online or offline to calculate taxes, validate GSTINs, and manage e-commerce GST without registration.';

// JSON-LD: WebSite + FAQPage
const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebSite',
    name: 'GST HSN Lookup',
    url: Astro.site?.toString() ?? 'https://example.com',
    description: 'Free GST tools for India — Calculator, HSN Lookup, GSTIN Validator',
    potentialAction: {
      '@type': 'SearchAction',
      target: {
        '@type': 'EntryPoint',
        urlTemplate: `${Astro.site?.toString() ?? 'https://example.com'}/hsn-code-lookup?q={search_term_string}`,
      },
      'query-input': 'required name=search_term_string',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: {
        '@type': 'Answer',
        text: `<p>${faq.answerText}</p>`,
      },
    })),
  },
];

const tools = [
  {
    href: '/gst-notice-deadline-calculator',
    icon: '⏳',
    title: 'Notice Reply Deadline',
    description: 'Calculate the exact deadline to file your reply for ASMT-10, DRC-01, Section 73, and Section 74 notices.',
    badge: 'New',
  },
  {
    href: '/gst-margin-scheme-calculator',
    icon: '♻️',
    title: 'Margin Scheme (Second Hand)',
    description: 'Calculate your tax savings on second-hand goods. Pay GST only on your profit margin, not the full sale value.',
    badge: 'New',
  },
  {
    href: '/gst-on-rent-calculator',
    icon: '🏠',
    title: 'GST on Rent',
    description: 'Instantly check GST applicability, Reverse Charge Mechanism (RCM) rules, and tax liability for commercial or residential rent.',
    badge: 'New',
  },
  {
    href: '/gst-on-freight-calculator',
    icon: '🚚',
    title: 'GST on Freight',
    description: 'Determine GST liability, RCM applicability, and ITC eligibility for transport of goods (GTA vs Courier) in India.',
    badge: 'New',
  },
  {
    href: '/aggregate-turnover-calculator',
    icon: '📊',
    title: 'Aggregate Turnover',
    description: 'Calculate your exact GST turnover. Instantly check if you cross the ₹20L/₹40L mandatory registration limit or Composition Scheme thresholds.',
    badge: 'New',
  },
  {
    href: '/gst-rate-comparison',
    icon: '⚖️',
    title: 'Rate Comparison',
    description: 'Compare old GST slabs vs new GST 2.0 rates. Calculate the exact ₹ price impact for your end consumers.',
    badge: 'New',
  },
  {
    href: '/mrp-revision-calculator',
    icon: '🏷️',
    title: 'MRP Revision Calculator',
    description: 'Reverse calculate your base price and generate a new MRP after a GST rate change to preserve your margins exactly.',
    badge: 'New',
  },
  {
    href: '/itc-reversal-checker',
    icon: '🚦',
    title: 'ITC Reversal Checker',
    description: 'A simple yes/no decision tree to determine if a GST rate drop legally requires you to surrender your Input Tax Credit.',
    badge: 'New',
  },
  {
    href: '/gst-calculator',
    icon: '🧮',
    title: 'GST Calculator',
    description: 'Add or remove GST instantly. Supports 5%, 18%, 40% (GST 2.0) and custom rates. Old slabs (12%, 28%) available for historical context. Shows CGST/SGST split.',
    badge: 'Most Popular',
  },
  {
    href: '/hsn-code-lookup',
    icon: '🔍',
    title: 'HSN / SAC Code Lookup',
    description: 'Search HSN codes for goods and SAC codes for services. Instant client-side filtering with GST rate display.',
    badge: null,
  },
  {
    href: '/gstin-validator',
    icon: '✅',
    title: 'GSTIN Validator',
    description: 'Validate any 15-digit GST number offline. Verifies format, checksum, decodes state name and embedded PAN.',
    badge: null,
  },
  {
    href: '/invoice-generator',
    icon: '📝',
    title: 'GST Invoice Generator',
    description: 'Create perfect tax invoices instantly. Auto-calculates CGST/SGST/IGST. Download as PDF. 100% Free & Offline.',
    badge: 'Most Popular',
  },
  {
    href: '/eway-bill-limit-checker',
    icon: '🚚',
    title: 'E-Way Bill Limit Checker',
    description: 'Instantly check mandatory E-Way Bill threshold limits (₹50k vs ₹1 Lakh) for inter-state and intra-state goods movement.',
    badge: 'Trending',
  },
  {
    href: '/late-fee-calculator',
    icon: '🕒',
    title: 'Late Fee Calculator',
    description: 'Calculate GST late fees and interest for delayed filing of GSTR-1, GSTR-3B, or GSTR-9. Accurate client-side calculation.',
    badge: 'New',
  },
  {
    href: '/rcm-calculator',
    icon: '🔄',
    title: 'RCM Calculator',
    description: 'Calculate Reverse Charge Mechanism (RCM) liability instantly.',
    badge: 'New',
  },
  {
    href: '/composition-scheme-calculator',
    icon: '🏪',
    title: 'Composition Scheme',
    description: 'Check eligibility and calculate flat composition tax rates.',
    badge: 'New',
  },
  {
    href: '/eway-bill-validity',
    icon: '🛣️',
    title: 'E-Way Bill Validity',
    description: 'Calculate exactly how many days an E-way bill is valid.',
    badge: 'New',
  },
  {
    href: '/itc-calculator',
    icon: '📉',
    title: 'ITC Calculator',
    description: 'Calculate Input Tax Credit set-off and net GST payable.',
    badge: 'New',
  },
  {
    href: '/gst-interest-calculator',
    icon: '💸',
    title: 'Interest Calculator',
    description: 'Calculate interest on delayed GST payments at 18% p.a.',
    badge: 'New',
  },
  {
    href: '/tds-gst-calculator',
    icon: '✂️',
    title: 'TDS Calculator',
    description: 'Calculate 2% TDS under GST for contracts over ₹2.5 Lakhs.',
    badge: 'New',
  },
  {
    href: '/tcs-gst-calculator',
    icon: '🛒',
    title: 'TCS Calculator',
    description: 'Calculate 1% TCS under GST for e-commerce operators and sellers.',
    badge: 'New',
  },
  {
    href: '/gst-penalty-calculator',
    icon: '⚖️',
    title: 'Penalty Calculator',
    description: 'Calculate statutory GST penalties for fraud, late payment, and fake invoices.',
    badge: 'New',
  },
  {
    href: '/gst-due-dates',
    icon: '📅',
    title: 'GST Due Dates Calendar',
    description: 'Track all important GST return filing due dates. Never miss a deadline and avoid late fees and penalties.',
    badge: 'New',
  },
  {
    href: '/gstr-9-annual-return-checklist',
    icon: '✅',
    title: 'GSTR-9 Checklist',
    description: 'Interactive checklist for filing GSTR-9 Annual Return and avoiding notices.',
    badge: 'New',
  },
  {
    href: '/lut-renewal-reminder',
    icon: '🔔',
    title: 'LUT Renewal Reminder',
    description: 'Calculate your exact deadline to renew LUT for zero-rated GST exports.',
    badge: 'New',
  },
  {
    href: '/gst-director-remuneration-calculator',
    icon: '👔',
    title: 'Director RCM Calculator',
    description: 'Determine GST applicability (18% RCM vs Salary) on director remuneration.',
    badge: 'New',
  },
  {
    href: '/supply-type-classifier',
    icon: '📦',
    title: 'Supply Type Classifier',
    description: 'Classify bundled goods into Composite vs Mixed Supply for accurate tax rates.',
    badge: 'New',
  },
  {
    href: '/multi-gstin-invoice-splitter',
    icon: '🏢',
    title: 'Multi-GSTIN Splitter',
    description: 'Allocate values and determine IGST/CGST across multiple state branches.',
    badge: 'New',
  },
];
---

<BaseLayout {title} {description} {structuredData}>
  <!-- ── Hero ──────────────────────────────────────────────────────────────── -->
  <section class="relative overflow-hidden border-b border-base bg-surface">
    <!-- Vercel Mesh Gradient Backdrop -->
    <div class="absolute inset-0 z-0 pointer-events-none opacity-40 dark:opacity-20"
         style="background-image: radial-gradient(at 20% 0%, rgba(0,124,240,0.4) 0px, transparent 50%),
                                  radial-gradient(at 80% 0%, rgba(0,223,216,0.4) 0px, transparent 50%),
                                  radial-gradient(at 50% 100%, rgba(255,0,128,0.3) 0px, transparent 50%);">
    </div>
    
    <div class="relative z-10 mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 py-24 sm:py-32 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-base bg-canvas px-4 py-1.5 text-[12px] font-mono uppercase tracking-wider text-muted mb-6 shadow-[0_1px_1px_#00000005]">
        <span class="h-1.5 w-1.5 rounded-full bg-[#50e3c2]"></span>
        Free · Offline · No Login Required
      </div>
      <h1 class="text-5xl sm:text-6xl lg:text-[64px] font-bold tracking-tight text-base leading-[1.1] mb-6">
        The Ultimate Free GST Tool<br class="hidden sm:block" />
        for Small Business India.
      </h1>
      <p class="mt-6 text-[18px] text-muted max-w-2xl mx-auto leading-relaxed">
        Use our <strong>free GST tool online</strong> to instantly compute taxes. Whether you need a <strong>GST tool for e-commerce</strong>, a quick <strong>GST number search</strong>, or an <strong>offline GST tool</strong> alternative to the portal—we have you covered.
      </p>
      <div class="mt-10 flex flex-col sm:flex-row gap-4 justify-center items-center">
        <a
          href="/gst-calculator"
          class="inline-flex items-center justify-center rounded-full bg-accent px-6 py-3 text-[16px] font-medium text-white hover:opacity-90 active:scale-95 transition-all w-full sm:w-auto h-[48px]"
        >
          Open GST Calculator
        </a>
        <a
          href="/hsn-code-lookup"
          class="inline-flex items-center justify-center rounded-full border border-base bg-surface px-6 py-3 text-[16px] font-medium text-base hover:bg-subtle active:scale-95 transition-all w-full sm:w-auto h-[48px] shadow-[0_1px_1px_#00000005]"
        >
          Search HSN Codes
        </a>
      </div>
    </div>
  </section>

  <!-- ── Tool Cards ─────────────────────────────────────────────────────────── -->
  <section class="mx-auto max-w-[1400px] px-4 sm:px-6 lg:px-8 py-24" aria-labelledby="tools-heading">
    <h2 id="tools-heading" class="text-[32px] tracking-[-1.28px] font-semibold text-base text-center mb-4">
      The complete GST toolkit.
    </h2>
    <p class="text-center text-[18px] text-muted mb-16 max-w-2xl mx-auto">
      Everything you need for GST compliance — fast, offline, and completely free.
    </p>
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {tools.map((tool) => (
        <a
          href={tool.href}
          class="group relative flex flex-col rounded-[8px] border border-base bg-surface p-[24px] transition-all duration-300 hover:border-accent hover:shadow-[0_4px_12px_rgba(var(--accent),0.1)] hover:-translate-y-1"
        >
          {tool.badge && (
            <span class="absolute top-[24px] right-[24px] rounded-full bg-subtle border border-base px-[8px] py-[2px] text-[12px] font-mono text-muted">
              {tool.badge}
            </span>
          )}
          <div class="text-[32px] mb-6" aria-hidden="true">{tool.icon}</div>
          <h3 class="text-[20px] tracking-[-0.6px] font-semibold text-base mb-3 transition-colors">
            {tool.title}
          </h3>
          <p class="text-[14px] text-muted leading-relaxed flex-1">{tool.description}</p>
          <div class="mt-6 flex items-center gap-1 text-[14px] font-medium text-accent">
            Open tool
            <svg class="h-4 w-4 group-hover:translate-x-1 transition-transform" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
              <path stroke-linecap="round" stroke-linejoin="round" d="M9 5l7 7-7 7" />
            </svg>
          </div>
        </a>
      ))}
    </div>
  </section>

  <!-- ── SEO Content Section (~600 words) ──────────────────────────────────── -->
  <section class="border-t border-base bg-subtle" aria-labelledby="about-gst-heading">
    <div class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-24">
      <h2 id="about-gst-heading" class="text-[32px] tracking-[-1.28px] font-semibold text-base mb-8">
        Understanding GST in India — Your Complete Guide
      </h2>

      <div class="prose prose-neutral dark:prose-invert max-w-none space-y-6 text-[16px] leading-[24px]">
        <p>
          <strong>GST (Goods and Services Tax)</strong> — the full form of GST — is India's most significant indirect tax reform. Implemented on 1 July 2017, GST replaced a fragmented system of central and state taxes. Today, every business with annual turnover above the threshold must complete their <strong>GST registration</strong> on the official <strong>GST portal</strong>. Once registered, a business receives a unique 15-character <strong>GST number</strong>. You can do a quick <strong>GST number check</strong> or <strong>GST number search</strong> to verify details of any supplier before transacting, ensuring they are active on the <strong>GST portal login</strong>.
        </p>

        <p>
          Whether you're a small trader or a seasoned CA, having a reliable <strong>GST tool</strong> is essential. India uses a four-tier GST rate structure. To figure out tax on a bill, you can use our free <strong>GST calculator</strong>. It allows you to add GST to a base price or remove GST from an inclusive price in seconds. You can also generate beautiful bills using our <strong>free online GST invoice generator</strong>. For logistics and transport, knowing the <strong>E-Way bill limits 2026</strong> is critical to avoid massive penalties. Understanding <strong>new GST rates</strong> and applying them correctly ensures correct <strong>GST payment</strong> when filing returns.
        </p>

        <h3 class="text-[20px] font-semibold text-base mt-10 mb-4 tracking-[-0.6px]">What is a GST Number?</h3>
        <p>
          A GST number (also known as GSTIN) is an alphanumeric identifier assigned after successful <strong>gst registration</strong>. Knowing how to do a <strong>GST no check</strong> or <strong>GST no search</strong> is critical before entering a business transaction. Our <strong>GST verification</strong> tool lets you validate the checksum and PAN immediately without any external API call. You don't need a separate <strong>gst login</strong> to use our offline tools.
        </p>

        <h3 class="text-[20px] font-semibold text-base mt-10 mb-4 tracking-[-0.6px]">HSN Codes and GST Search</h3>
        <p>
          Every good traded in India is classified under an HSN code, and services under a SAC. These codes determine the applicable <strong>new gst rates list 2025</strong>. Doing a quick <strong>GST search</strong> through our HSN Lookup tool lets you find the exact code and its associated tax rate. This avoids errors during <strong>gst portal login</strong> and invoice generation. Our <strong>GST status</strong> tool can also assist in tracking the correct rates and filing requirements.
        </p>

        <h3 class="text-[20px] font-semibold text-base mt-10 mb-4 tracking-[-0.6px]">GST Portal Login and Payments</h3>
        <p>
          The official website is where you perform your <strong>gst login portal</strong> activities. This is your destination for filing returns, tracking your <strong>gst status</strong>, and making a secure <strong>gst payment</strong>. You can also download your certificate or perform a real-time <strong>gst check</strong>. While the official portal is essential for compliance, our fast, offline tools save you time during day-to-day operations like preparing invoices or performing a quick <strong>gst verification</strong> before paying vendors.
        </p>

        <p class="text-[14px] text-muted border-t border-base pt-6 mt-8">
          <strong>Note:</strong> All tools on this website are for informational and calculation purposes only. GST rates and rules are subject to change. Always refer to the official GST portal and CBIC notifications for authoritative information. Our <strong>gst tool</strong> suite is completely free and requires no <strong>gst login</strong>.
        </p>
      </div>
    </div>
  </section>

  <!-- ── FAQ Preview (first 6 questions) ───────────────────────────────────── -->
  <section class="mx-auto max-w-4xl px-4 sm:px-6 lg:px-8 py-16" aria-labelledby="faq-preview-heading">
    <div class="flex items-center justify-between mb-8">
      <h2 id="faq-preview-heading" class="text-2xl sm:text-3xl font-bold text-base">
        Frequently Asked Questions
      </h2>
      <a href="/faq" class="text-sm font-medium text-accent hover:underline hidden sm:block">
        View all FAQs →
      </a>
    </div>

    <div class="space-y-4">
      {faqs.slice(0, 6).map((faq, i) => (
        <details
          class="group rounded-xl border border-base bg-surface overflow-hidden"
          id={`faq-home-${i}`}
        >
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>{faq.question}</span>
            <svg
              class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200"
              fill="none"
              viewBox="0 0 24 24"
              stroke="currentColor"
              stroke-width="2"
              aria-hidden="true"
            >
              <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" />
            </svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            <Fragment set:html={faq.answerHtml} />
          </div>
        </details>
      ))}
    </div>

    <div class="mt-6 text-center sm:hidden">
      <a href="/faq" class="text-sm font-medium text-accent hover:underline">
        View all FAQs →
      </a>
    </div>
  </section>

  <!-- ── Stats / Trust bar ──────────────────────────────────────────────────── -->
  <section class="border-t border-base bg-subtle">
    <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-12">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 text-center">
        {[
          { value: '5 slabs', label: 'GST Rate Slabs' },
          { value: '100+', label: 'HSN/SAC Codes' },
          { value: '37', label: 'States & UTs Decoded' },
          { value: '100%', label: 'Offline & Free' },
        ].map(({ value, label }) => (
          <div>
            <div class="text-2xl sm:text-3xl font-bold text-accent">{value}</div>
            <div class="mt-1 text-sm text-muted">{label}</div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
