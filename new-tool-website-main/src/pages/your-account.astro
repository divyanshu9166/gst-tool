---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Your Account';
const description = 'Manage your account.';
---

<BaseLayout {title} {description}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Your Account</h1>
    <p class="text-xl text-muted">Currently, all features are accessible without an account.</p>
  </div>
</BaseLayout>