---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GSTR 1 JSON to Excel Converter | Free GST Tool Online';
const description = 'Convert your GSTR 1 JSON files into Excel format quickly and easily. Free online GST tool to decode parsing, view B2B, B2C, EXP, and CDNUR details in an Excel spreadsheet.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GSTR 1 JSON to Excel',
    url: `${Astro.site?.toString() ?? 'https://example.com'}/gstr1-json-to-excel`,
    description: 'Easily convert GSTR 1 JSON files downloaded from GST portal to Excel sheets.',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: "How do I convert GSTR-1 JSON to Excel offline?", acceptedAnswer: { '@type': 'Answer', text: "Simply drag and drop your GSTR-1 JSON file downloaded from the GST portal or generated by your ERP into our tool. It will instantly convert it to a structured Excel (.xlsx) file completely offline." } },
      { '@type': 'Question', name: "Is it safe to convert GSTR-1 JSON online?", acceptedAnswer: { '@type': 'Answer', text: "With our tool, yes. The conversion from GSTR-1 JSON to Excel happens entirely within your web browser. Your financial data is never sent to our servers." } },
      { '@type': 'Question', name: "Why should I convert GSTR-1 JSON to Excel?", acceptedAnswer: { '@type': 'Answer', text: "Converting GSTR-1 JSON to Excel allows you to easily read, filter, and reconcile your outward supplies and B2B invoices before filing, ensuring maximum accuracy for 2026 audits." } },
      { '@type': 'Question', name: "Does the tool separate B2B and B2C invoices?", acceptedAnswer: { '@type': 'Answer', text: "Yes, the generated Excel file contains separate sheets for B2B, B2CL, B2CS, CDNR, and HSN summaries, matching the exact structure of the GST return." } },
      { '@type': 'Question', name: "Can this tool handle large GSTR-1 JSON files?", acceptedAnswer: { '@type': 'Answer', text: "Yes, because it runs locally using your device's memory, it can process large JSON files with thousands of invoices much faster than cloud-based converters." } },
      { '@type': 'Question', name: "Is this tool updated for the latest 2026 GST schemas?", acceptedAnswer: { '@type': 'Answer', text: "Absolutely. The converter is fully compatible with the GST 2.0 schemas introduced for FY 2025-26." } },
      { '@type': 'Question', name: "Do I need Microsoft Excel installed to use this tool?", acceptedAnswer: { '@type': 'Answer', text: "No, you don't need Excel to run the tool, but you will need Excel, Google Sheets, or a compatible spreadsheet viewer to open the downloaded .xlsx file." } },
      { '@type': 'Question', name: "Can I edit the GSTR-1 data after converting to Excel?", acceptedAnswer: { '@type': 'Answer', text: "Yes, you can edit the downloaded Excel file. However, to file it on the portal, you will need to convert it back to JSON using the official GST offline utility." } },
      { '@type': 'Question', name: "Are there any file size limits?", acceptedAnswer: { '@type': 'Answer', text: "There are no strict file size limits imposed by our servers since the processing happens in your browser. However, extremely large files (50MB+) may slow down your browser." } },
      {
        '@type': 'Question',
        name: 'Is the GSTR-1 JSON to Excel tool free?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes! It is completely free and works beautifully directly in your browser. No sign-ups needed.'
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-base mb-3">GSTR-1 JSON to Excel Converter</h1>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        Convert your complicated GSTR-1 JSON files directly into readable Excel spreadsheets. 100% Free and works completely inside your browser. No data is uploaded to our servers.
      </p>
    </div>

    <div class="bg-surface border border-base rounded-2xl p-8 shadow-sm">
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-base mb-2">Upload GSTR-1 JSON File</label>
          <input 
            type="file" 
            id="jsonFileInput" 
            accept="application/json"
            class="block w-full text-sm text-muted file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-accent file:text-white hover:file:bg-accent/90"
          />
        </div>
        <div>
          <button id="convertBtn" class="w-full bg-accent hover:bg-accent/90 text-white font-semibold py-3 px-4 rounded-xl transition-colors">
            Convert to Excel
          </button>
        </div>
        <div id="output" class="hidden text-sm text-center p-4 bg-green-50 text-green-700 rounded-lg border border-green-200">
          Success! Your Excel file has been generated and should download automatically.
        </div>
        <div id="error" class="hidden text-sm text-center p-4 bg-red-50 text-red-700 rounded-lg border border-red-200">
          Error parsing JSON. Please ensure it is a valid GSTR-1 JSON file.
        </div>
      </div>
    </div>
    
    <div class="mt-16 prose prose-slate max-w-none text-muted">
      <h2>Why use our GSTR 1 JSON to Excel Tool?</h2>
      <p>The Goods and Services Tax Network (GSTN) provides the GSTR-1 offline return data in JSON format which can be incredibly hard to read. Our <strong>GSTR-1 JSON to Excel Converter</strong> makes it simple by parsing all internal records (B2B, B2C, CDNR, etc.) and placing them in a structured Excel spreadsheet.</p>
      
      
    </div>
  </div>

  <script is:inline src="https://cdnjs.cloudflare.com/ajax/libs/xlsx/0.18.5/xlsx.full.min.js"></script>
  <script is:inline>
    document.getElementById('convertBtn').addEventListener('click', () => {
      const fileInput = document.getElementById('jsonFileInput');
      const output = document.getElementById('output');
      const errorMsg = document.getElementById('error');
      
      output.classList.add('hidden');
      errorMsg.classList.add('hidden');

      if (!fileInput.files.length) {
        alert('Please select a JSON file first.');
        return;
      }

      const file = fileInput.files[0];
      const reader = new FileReader();

      reader.onload = (e) => {
        try {
          const data = JSON.parse(e.target.result);
          
          // Generate a workbook
          const wb = XLSX.utils.book_new();

          // We'll create basic sheets for B2B, B2CS, etc if they exist
          const tables = ['b2b', 'b2cs', 'b2cl', 'exp', 'cdnr', 'cdnur', 'hsn', 'nil'];
          let hasData = false;

          tables.forEach(key => {
            if (data[key] && Array.isArray(data[key])) {
              hasData = true;
              // Flatten the json slightly or just pass directly
              // Real GSTR1 has nested arrays for invoices/items but this provides a basic flat view
              const sheetData = [];
              data[key].forEach(supplier => {
                if (supplier.inv) {
                  supplier.inv.forEach(invoice => {
                    const row = {
                      'Supplier Details': supplier.ctin || supplier.sply_ty || '',
                      'Invoice No': invoice.inum || '',
                      'Invoice Date': invoice.idt || '',
                      'Invoice Value': invoice.val || '',
                      'POS': invoice.pos || ''
                    };
                    sheetData.push(row);
                  });
                } else {
                  sheetData.push(supplier);
                }
              });

              if (sheetData.length) {
                const ws = XLSX.utils.json_to_sheet(sheetData);
                XLSX.utils.book_append_sheet(wb, ws, key.toUpperCase());
              }
            }
          });

          if (!hasData) {
            // Just push exactly what's there
            const ws = XLSX.utils.json_to_sheet([data]);
            XLSX.utils.book_append_sheet(wb, ws, "RawData");
          }

          XLSX.writeFile(wb, 'GSTR1_Converted.xlsx');
          output.classList.remove('hidden');

        } catch (err) {
          console.error(err);
          errorMsg.classList.remove('hidden');
        }
      };

      reader.readAsText(file);
    });
  </script>

    <!-- FAQ Section -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16 pt-12 border-t border-base" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-base mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {structuredData[1].mainEntity.map((faq, i) => (
          <details class="group rounded-xl border border-base bg-surface overflow-hidden" id={`faq-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span>{faq.name}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[15px] text-muted leading-relaxed border-t border-base pt-4">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
</BaseLayout>