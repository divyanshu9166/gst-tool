---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'TDS under GST Calculator | 2% Tax Deduction';
const description = 'Calculate the exact TDS to be deducted under GST for government contracts exceeding ₹2.5 Lakhs. Free offline TDS rate calculator.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'TDS under GST Calculator',
    url: Astro.site?.toString() ? `${Astro.site}tds-gst-calculator` : 'https://example.com/tds-gst-calculator',
    description: 'Calculate 2% TDS under GST for contracts exceeding ₹2.5 Lakhs.',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: "What is the TDS rate under GST?", acceptedAnswer: { '@type': 'Answer', text: "The TDS rate under GST is 2% (1% CGST + 1% SGST, or 2% IGST) on payments made to suppliers for taxable goods or services." } },
      { '@type': 'Question', name: "When is TDS deducted under GST?", acceptedAnswer: { '@type': 'Answer', text: "TDS is deducted by specified government agencies, local authorities, and PSUs when the total value of supply under a single contract exceeds ₹2,50,000." } },
      {
        '@type': 'Question',
        name: 'What is the rate of TDS under GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The standard rate of TDS under GST is 2%. For intra-state transactions, this is split into 1% CGST and 1% SGST. For inter-state transactions, it is 2% IGST.',
        }
      },
      {
        '@type': 'Question',
        name: 'When is TDS required to be deducted under GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'TDS is only deducted when the total value of supply under a single contract exceeds ₹2,50,000. It is generally deducted by Government agencies, local authorities, and specified PSUs.',
        }
      },
      {
        '@type': 'Question',
        name: 'Is TDS calculated on the total invoice value including GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. The TDS is calculated strictly on the taxable value of the goods or services. It is not calculated on the GST amount (CGST/SGST/IGST) mentioned in the invoice.',
        }
      },
      {
        '@type': 'Question',
        name: 'Does a private limited company need to deduct TDS under GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. TDS under GST is strictly for government entities, PSUs, local authorities, and government societies. Private sector businesses do not deduct TDS under GST.',
        }
      },
      {
        '@type': 'Question',
        name: 'What happens if the contract is ₹3 Lakhs but the first invoice is ₹50,000?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Since the total contract value (₹3 Lakhs) exceeds the threshold of ₹2.5 Lakhs, TDS of 2% will be deducted on every invoice, including the ₹50,000 invoice.',
        }
      },
      {
        '@type': 'Question',
        name: 'When should the deductor deposit the TDS?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The deductor must deposit the deducted TDS amount to the government by the 10th of the following month using form GSTR-7.',
        }
      },
      {
        '@type': 'Question',
        name: 'How does the supplier claim the deducted TDS?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Once the deductor files GSTR-7, the amount automatically reflects in the supplier’s TDS/TCS Credit Received tab. The supplier can accept it, and it moves to their Electronic Cash Ledger.',
        }
      },
      {
        '@type': 'Question',
        name: 'Is there any late fee if the deductor fails to issue the TDS certificate?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. If the deductor fails to furnish the certificate (Form GSTR-7A) to the deductee within 5 days of crediting the government, a late fee of ₹100 per day (max ₹5,000) applies.',
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-12 lg:py-24">
    <!-- Header -->
    <div class="mb-10 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-base bg-surface px-4 py-1.5 text-[12px] font-mono uppercase tracking-wider text-muted mb-4 shadow-[0_1px_1px_#00000005]">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        100% Offline Tool
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-base mb-4">
        TDS under GST Calculator
      </h1>
      <p class="text-[16px] text-muted max-w-xl mx-auto leading-relaxed">
        Instantly calculate the 2% TDS to be deducted on government contracts and find the net payment amount to the supplier.
      </p>
    </div>

    <!-- Main Tool Container -->
    <div class="rounded-[12px] border border-base bg-surface p-6 sm:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] mb-12">
      <div class="flex flex-col gap-6">
        
        <div class="grid grid-cols-1 gap-6">
          <div class="flex flex-col gap-2">
            <label for="contract-val" class="text-sm font-semibold text-base">Total Contract Value (Excluding GST) (₹)</label>
            <input 
              type="number" 
              id="contract-val" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-mono focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
              placeholder="e.g. 300000"
              min="0"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="invoice-val" class="text-sm font-semibold text-base">Current Invoice Value (Excluding GST) (₹)</label>
            <input 
              type="number" 
              id="invoice-val" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-mono focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
              placeholder="e.g. 150000"
              min="0"
            />
            <p class="text-[12px] text-muted">Enter the taxable value of the current invoice.</p>
          </div>

          <div class="flex flex-col gap-2">
            <label for="txn-type" class="text-sm font-semibold text-base">Supply Type</label>
            <select 
              id="txn-type" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-medium focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
            >
              <option value="intra">Intra-State (Same State)</option>
              <option value="inter">Inter-State (Different States)</option>
            </select>
          </div>
        </div>

      </div>

      <!-- Result Card -->
      <div id="result-card" class="mt-8 hidden overflow-hidden rounded-[8px] border border-base bg-subtle transition-all duration-300">
        
        <div id="status-tds" class="hidden">
          <div class="p-6">
            <h3 class="text-[14px] font-medium text-muted mb-4 uppercase tracking-wider">TDS Calculation</h3>
            
            <div class="space-y-4">
              <div class="flex justify-between items-center pb-4 border-b border-base/50">
                <span class="text-base font-medium">Invoice Taxable Value:</span>
                <span class="text-xl font-mono text-base" id="res-inv">₹0</span>
              </div>

              <div id="res-cgst-box" class="flex justify-between items-center text-muted">
                <span>TDS - CGST (1%):</span>
                <span class="text-lg font-mono text-red-600 dark:text-red-400" id="res-cgst">-₹0</span>
              </div>
              
              <div id="res-sgst-box" class="flex justify-between items-center text-muted">
                <span>TDS - SGST (1%):</span>
                <span class="text-lg font-mono text-red-600 dark:text-red-400" id="res-sgst">-₹0</span>
              </div>

              <div id="res-igst-box" class="hidden justify-between items-center text-muted">
                <span>TDS - IGST (2%):</span>
                <span class="text-lg font-mono text-red-600 dark:text-red-400" id="res-igst">-₹0</span>
              </div>

              <div class="flex justify-between items-center pt-4 border-t border-base/50">
                <span class="text-lg font-bold text-accent">Total TDS Deducted:</span>
                <span class="text-3xl font-mono font-bold text-accent" id="res-total">₹0</span>
              </div>
            </div>
          </div>
          <div class="border-t border-blue-200/50 bg-blue-50 dark:bg-blue-900/10 dark:border-blue-900/30 p-4">
            <p class="text-sm text-blue-700 dark:text-blue-400 font-medium">
              💡 The deductor will deposit this ₹<span id="res-tds-note"></span> against the supplier's GSTIN. The supplier can claim this amount in their electronic cash ledger.
            </p>
          </div>
        </div>

        <div id="status-no-tds" class="hidden">
          <div class="p-6 bg-green-50 dark:bg-green-900/10">
            <div class="flex items-center gap-3 mb-4">
              <span class="flex h-8 w-8 items-center justify-center rounded-full bg-green-100 text-green-600 dark:bg-green-900/30 dark:text-green-400">
                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M5 13l4 4L19 7"/></svg>
              </span>
              <h3 class="text-lg font-bold text-green-700 dark:text-green-400">No TDS Applicable</h3>
            </div>
            <p class="text-sm text-green-700 dark:text-green-400 font-medium leading-relaxed">
              TDS is only required to be deducted if the total value of the contract exceeds ₹2,50,000. Since your contract value is lower, no TDS needs to be deducted from this invoice.
            </p>
          </div>
        </div>

      </div>
    </div>

    <!-- SEO Content -->
    <article class="prose prose-neutral dark:prose-invert max-w-none text-[15px] leading-relaxed">
      <h2 class="text-2xl font-semibold mb-4">Understanding TDS under GST</h2>
      <p>
        Tax Deducted at Source (TDS) under the Goods and Services Tax (GST) is fundamentally different from TDS under the Income Tax Act. Under Income Tax, TDS is deducted by almost all businesses on various services. However, under Section 51 of the CGST Act, TDS is a highly specific mechanism primarily aimed at tracking high-value government contracts to ensure contractors are paying their due taxes.
      </p>
      <p>
        Our <strong>TDS under GST Calculator</strong> helps both government deductors and private contractors instantly determine the exact TDS amount to be withheld on an invoice, preventing costly compliance errors and ensuring the contractor receives the correct net payment.
      </p>
      
      <h3>Who Must Deduct TDS under GST?</h3>
      <p>If you are a private limited company, a partnership firm, or an individual business owner dealing with other private businesses, <strong>you do not deduct TDS under GST</strong>. The mandate to deduct TDS is strictly limited to the following entities:</p>
      <ul>
        <li>A department or establishment of the Central Government or State Government.</li>
        <li>Local authorities (Municipal Corporations, Panchayats, etc.).</li>
        <li>Governmental agencies.</li>
        <li>Public Sector Undertakings (PSUs).</li>
        <li>Societies established by the Central Government, State Government, or a Local Authority.</li>
      </ul>

      <h3>The 2.5 Lakh Threshold Rule</h3>
      <p>
        The most common point of confusion is the ₹2,50,000 threshold. The law states that TDS is applicable if the <strong>total value of the contract exceeds ₹2.5 Lakhs</strong>. 
      </p>
      <p>
        This means you look at the <em>Contract Value</em>, not the individual <em>Invoice Value</em>. 
        For example, if a Municipal Corporation awards a road repair contract worth ₹10,00,000 to a contractor, the threshold is crossed. Even if the contractor raises a small monthly running bill of just ₹50,000, the Municipal Corporation must deduct 2% TDS on that ₹50,000. Conversely, if a total contract is only for ₹2,00,000, no TDS is deducted, even if a single invoice is raised for the full ₹2,00,000 amount.
      </p>

      <h3>How is TDS Calculated? (The 2% Rule)</h3>
      <p>
        The rate of TDS under GST is universally fixed at <strong>2%</strong>. However, the nature of the transaction determines how this 2% is split:
      </p>
      <ul>
        <li><strong>Intra-State (Same State):</strong> 1% CGST + 1% SGST.</li>
        <li><strong>Inter-State (Different States):</strong> 2% IGST.</li>
      </ul>
      <p>
        <strong>CRITICAL RULE:</strong> The 2% is calculated <em>strictly</em> on the taxable value of the goods or services. It is never calculated on the GST amount. 
        For instance, if the taxable value of a service is ₹1,00,000 and the 18% GST is ₹18,000, the total invoice is ₹1,18,000. The deductor will calculate the 2% TDS only on the ₹1,00,000 (which is ₹2,000). They will not calculate it on the ₹1,18,000.
      </p>

      <h3>What Happens to the Deducted TDS?</h3>
      <p>
        If you are the contractor whose money was deducted, do not worry—this money is not lost. The government department will deposit the deducted amount and file form <strong>GSTR-7</strong> by the 10th of the following month.
      </p>
      <p>
        Once they file GSTR-7, the deducted amount will automatically reflect on your GST portal under the <em>TDS and TCS Credit Received</em> tab. Once you accept it, this amount will flow directly into your <strong>Electronic Cash Ledger</strong>. You can then use this cash balance to pay your monthly GST liabilities, or even claim it as a refund if you don't have sufficient liabilities.
      </p>
    </article>

    
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/gstin-validation-check" class="text-primary hover:underline">How to Spot a Fake GST Bill Using a GSTIN Validator</a></li>
        <li><a href="/blog/new-gst-rates-2026" class="text-primary hover:underline">New GST Rates 2026: Full Slab List After GST 2.0 (5%, 18%, 40%)</a></li>
      </ul>
    </div>
  </div>
<script>
const contractInput = document.getElementById("contract-val");
const invoiceInput = document.getElementById("invoice-val");
const typeSelect = document.getElementById("txn-type");
const resultCard = document.getElementById("result-card");
const statusTds = document.getElementById("status-tds");
const statusNoTds = document.getElementById("status-no-tds");
const resInv = document.getElementById("res-inv");
const resCgstBox = document.getElementById("res-cgst-box");
const resCgst = document.getElementById("res-cgst");
const resSgstBox = document.getElementById("res-sgst-box");
const resSgst = document.getElementById("res-sgst");
const resIgstBox = document.getElementById("res-igst-box");
const resIgst = document.getElementById("res-igst");
const resTotal = document.getElementById("res-total");
const resTdsNote = document.getElementById("res-tds-note");
function formatCur(num) {
  return "\u20B9" + num.toLocaleString("en-IN", { maximumFractionDigits: 2 });
}
function calculate() {
  const contract = parseFloat(contractInput.value) || 0;
  const invoice = parseFloat(invoiceInput.value) || 0;
  const type = typeSelect.value;
  if (contract <= 0 || invoice <= 0) {
    resultCard.classList.add("hidden");
    return;
  }
  resultCard.classList.remove("hidden");
  if (contract <= 25e4) {
    statusTds.classList.add("hidden");
    statusNoTds.classList.remove("hidden");
  } else {
    statusNoTds.classList.add("hidden");
    statusTds.classList.remove("hidden");
    resInv.textContent = formatCur(invoice);
    const totalTds = invoice * 0.02;
    resTotal.textContent = formatCur(totalTds);
    resTdsNote.textContent = totalTds.toLocaleString("en-IN", { maximumFractionDigits: 2 });
    if (type === "intra") {
      resCgstBox.classList.remove("hidden");
      resCgstBox.classList.add("flex");
      resSgstBox.classList.remove("hidden");
      resSgstBox.classList.add("flex");
      resIgstBox.classList.remove("flex");
      resIgstBox.classList.add("hidden");
      resCgst.textContent = "-" + formatCur(totalTds / 2);
      resSgst.textContent = "-" + formatCur(totalTds / 2);
    } else {
      resCgstBox.classList.remove("flex");
      resCgstBox.classList.add("hidden");
      resSgstBox.classList.remove("flex");
      resSgstBox.classList.add("hidden");
      resIgstBox.classList.remove("hidden");
      resIgstBox.classList.add("flex");
      resIgst.textContent = "-" + formatCur(totalTds);
    }
  }
}
[contractInput, invoiceInput, typeSelect].forEach((el) => el.addEventListener("input", calculate));
</script>

    <!-- FAQ Section -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16 pt-12 border-t border-base" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-base mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {structuredData[1].mainEntity.map((faq, i) => (
          <details class="group rounded-xl border border-base bg-surface overflow-hidden" id={`faq-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span>{faq.name}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[15px] text-muted leading-relaxed border-t border-base pt-4">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
</BaseLayout>
