---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Help Center';
const description = 'Get help with our GST tools.';
---

<BaseLayout {title} {description}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Help Center</h1>
    <p class="text-xl text-muted">Explore answers to common questions in our FAQ or contact us for support.</p>
  </div>
</BaseLayout>