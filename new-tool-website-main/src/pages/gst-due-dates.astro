---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GST Return Due Dates Calendar 2025 — Deadlines & Penalties';
const description = 'Track GST return due dates for GSTR-1, GSTR-3B, GSTR-9, and CMP-08. Avoid late fees and penalties by filing before the deadline.';

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'WebPage',
  name: 'GST Return Due Dates Calendar',
  url: `${Astro.site?.toString() ?? 'https://example.com'}/gst-due-dates`,
  description: 'Track all important GST return filing due dates. Never miss a deadline.',
};

const dueDates = [
  {
    form: 'GSTR-1',
    description: 'Details of outward supplies of goods and services.',
    frequency: 'Monthly',
    deadline: '11th of the next month',
    applicableTo: 'Turnover > ₹5 Crore (or not opted for QRMP)',
  },
  {
    form: 'GSTR-1 (IFF)',
    description: 'Invoice Furnishing Facility for QRMP scheme.',
    frequency: 'Monthly (M1, M2)',
    deadline: '13th of the next month',
    applicableTo: 'Opted for QRMP scheme',
  },
  {
    form: 'GSTR-3B',
    description: 'Summary return and tax payment.',
    frequency: 'Monthly',
    deadline: '20th of the next month',
    applicableTo: 'Turnover > ₹5 Crore (or not opted for QRMP)',
  },
  {
    form: 'GSTR-3B (QRMP)',
    description: 'Summary return for QRMP scheme.',
    frequency: 'Quarterly',
    deadline: '22nd or 24th of the month succeeding the quarter',
    applicableTo: 'Opted for QRMP scheme',
  },
  {
    form: 'CMP-08',
    description: 'Statement for payment of self-assessed tax.',
    frequency: 'Quarterly',
    deadline: '18th of the month succeeding the quarter',
    applicableTo: 'Composition Scheme Taxpayers',
  },
  {
    form: 'GSTR-9',
    description: 'Annual Return.',
    frequency: 'Annually',
    deadline: '31st December of the next financial year',
    applicableTo: 'Regular Taxpayers (Turnover > ₹2 Crore)',
  },
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 py-12 sm:py-20">
    <div class="mb-12 text-center">
      <h1 class="text-4xl sm:text-5xl font-semibold tracking-[-1.28px] text-base mb-4">GST Due Dates Calendar</h1>
      <p class="text-[16px] text-muted max-w-2xl mx-auto leading-relaxed">
        Stay compliant. Track the statutory due dates for all major GST returns. Missing deadlines attracts a late fee of up to ₹50 per day and 18% p.a. interest.
      </p>
    </div>

    <!-- Due Dates Table/Cards -->
    <div class="rounded-[8px] border border-base bg-surface shadow-[0_2px_2px_#0000000a,0_8px_8px_-8px_#0000000a] overflow-hidden">
      <div class="overflow-x-auto">
        <table class="w-full text-left border-collapse">
          <thead>
            <tr class="bg-subtle border-b border-base text-[12px] font-mono text-muted uppercase tracking-wider">
              <th class="px-6 py-4 font-medium">Return Form</th>
              <th class="px-6 py-4 font-medium">Frequency</th>
              <th class="px-6 py-4 font-medium">Due Date</th>
              <th class="px-6 py-4 font-medium">Applicable To</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-base">
            {dueDates.map((item) => (
              <tr class="hover:bg-subtle/50 transition-colors">
                <td class="px-6 py-5">
                  <div class="font-semibold text-base text-[16px] tracking-[-0.28px]">{item.form}</div>
                  <div class="text-[13px] text-muted mt-1">{item.description}</div>
                </td>
                <td class="px-6 py-5 text-[14px] text-base">
                  <span class="inline-flex items-center rounded-full bg-accent/10 px-2.5 py-0.5 text-[12px] font-medium text-accent">
                    {item.frequency}
                  </span>
                </td>
                <td class="px-6 py-5 text-[14px] font-medium text-base">
                  {item.deadline}
                </td>
                <td class="px-6 py-5 text-[14px] text-muted">
                  {item.applicableTo}
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </div>

    <div class="mt-8 flex justify-center">
      <a
        href="/late-fee-calculator"
        class="inline-flex items-center justify-center rounded-full border border-base bg-surface px-6 py-3 text-[14px] font-medium text-base hover:bg-subtle active:scale-95 transition-all shadow-sm"
      >
        Missed a deadline? Use the Late Fee Calculator →
      </a>
    </div>
  </div>

  
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/gst-for-freelancers-india-2026" class="text-primary hover:underline">GST for Freelancers in India 2026: Export of Services & Registration</a></li>
        <li><a href="/blog/gstr-9-annual-return-fy-2025-26" class="text-primary hover:underline">GSTR-9 Annual Return FY 2025-26: The Complete Filing Guide</a></li>
      </ul>
    </div>
  </div>
<!-- FAQ Section -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[28px] tracking-[-1px] font-semibold text-base mb-2">Frequently Asked Questions</h2>
      <p class="text-muted text-[15px] mb-8">Important questions about GST return filing due dates and deadlines.</p>
      <div class="space-y-3">
        {[
          { q: 'What is the due date for GSTR-1 filing?', a: 'For monthly filers: 11th of the following month. For quarterly filers under the QRMP scheme: 13th of the month following the quarter. For example, GSTR-1 for January 2026 (monthly) is due by 11th February 2026. Quarterly filers for Q3 (Jan-Mar) are due by 13th April 2026.' },
          { q: 'What is the due date for GSTR-3B filing?', a: 'For monthly filers: 20th of the following month. QRMP scheme users have staggered dates: 22nd for Category 1 states and 24th for Category 2 states. For example, GSTR-3B for January 2026 (monthly) is due by 20th February 2026.' },
          { q: 'What is the GSTR-9 Annual Return due date?', a: 'GSTR-9 (Annual Return) is due by 31st December following the end of the financial year. So GSTR-9 for FY 2025-26 (April 2025 to March 2026) is due by 31st December 2026. GSTR-9C (Reconciliation Statement) for taxpayers above ₹5 Crore turnover has the same due date.' },
          { q: 'What is the due date for GSTR-4 (Composition Scheme)?', a: 'Composition scheme dealers file GSTR-4 annually, due by 30th April following the end of the financial year. They also pay quarterly tax using Form CMP-08 by the 18th of the month following each quarter (i.e., 18th July, 18th October, 18th January, and 18th April).' },
          { q: 'What is the TDS return due date under GST (GSTR-7)?', a: 'GSTR-7 (for TDS deductors) is due by the 10th of the following month. For example, TDS deducted in January must be reported by 10th February. Non-filing attracts a late fee of ₹200/day up to a maximum of the TDS amount.' },
          { q: 'What is the TCS return due date for e-commerce operators (GSTR-8)?', a: 'GSTR-8 (for e-commerce operators collecting TCS) is due by the 10th of the following month. For example, TCS collected in January must be reported by 10th February. Non-filing attracts ₹200/day late fee.' },
          { q: 'What happens if I miss the GSTR-1 due date?', a: 'Late filing of GSTR-1 attracts a late fee of ₹50/day (₹25 CGST + ₹25 SGST) for normal returns, or ₹20/day for NIL returns. Additionally, late GSTR-1 blocks your buyers from seeing your sales in their GSTR-2B, which can affect their ITC claims and harm your business relationships.' },
          { q: 'Can GST due dates be extended by the government?', a: 'Yes. The CBIC can extend GST return due dates via notifications issued under Section 168A of the CGST Act. Extensions are common during technical glitches on the portal, natural disasters, or major policy transitions. Always check the official CBIC website or GST portal for the latest notifications.' },
          { q: 'What is the due date for ISD (Input Service Distributor) return GSTR-6?', a: 'GSTR-6 (for Input Service Distributors) is due by the 13th of the following month. ISDs file this return to distribute the common ITC received for services used across multiple business units/branches.' },
          { q: 'What is the CMP-08 due date for Composition dealers?', a: 'CMP-08 (quarterly tax payment for Composition dealers) is due by the 18th of the month following each quarter: 18th July (Q1: Apr-Jun), 18th October (Q2: Jul-Sep), 18th January (Q3: Oct-Dec), and 18th April (Q4: Jan-Mar).' },
        ].map((faq, i) => (
          <details class="group rounded-[8px] border border-base bg-surface overflow-hidden" id={`faq-dates-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span class="text-[15px]">{faq.q}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[14px] text-muted leading-relaxed border-t border-base pt-4">{faq.a}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

