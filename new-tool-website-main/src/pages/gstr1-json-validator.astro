---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GSTR 1 JSON Validator | Check GST JSON Files Online';
const description = 'Validate your GSTR 1 JSON payload before uploading it to the GST Portal to prevent processing errors. Free offline semantic validation tool.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GSTR 1 JSON Validator',
    url: `${Astro.site?.toString() ?? 'https://example.com'}/gstr1-json-validator`,
    description: 'Ensure your GSTR-1 offline JSON file is structurally valid before uploading.',
    applicationCategory: 'BusinessApplication',
    operatingSystem: 'Any'
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      { '@type': 'Question', name: "What is a GSTR-1 JSON Validator?", acceptedAnswer: { '@type': 'Answer', text: "A GSTR-1 JSON Validator is a tool that checks your GST return file for schema errors, missing fields, and structural issues before you upload it to the official GST portal." } },
      { '@type': 'Question', name: "How do I check if my GSTR-1 JSON is valid for 2026?", acceptedAnswer: { '@type': 'Answer', text: "Upload your JSON file to our offline validator. It instantly checks the file against the latest 2026 GSTN schema rules and highlights any errors." } },
      { '@type': 'Question', name: "Why does the GST portal reject my JSON file?", acceptedAnswer: { '@type': 'Answer', text: "The portal rejects files if they contain invalid characters, incorrect GSTIN formats, missing mandatory fields, or mismatched tax rates. Our tool helps you catch these before uploading." } },
      { '@type': 'Question', name: "Is my GSTR-1 data uploaded to your server?", acceptedAnswer: { '@type': 'Answer', text: "No. The validation happens 100% offline within your browser. Your invoice details remain completely private and secure." } },
      { '@type': 'Question', name: "Does it validate HSN codes and tax rates?", acceptedAnswer: { '@type': 'Answer', text: "It validates the structure and format of the HSN codes and tax rates against the expected schema, but it does not cross-verify the actual tax rate of a specific HSN code against the live government database." } },
      { '@type': 'Question', name: "Can I use this for GSTR-3B JSON files?", acceptedAnswer: { '@type': 'Answer', text: "Currently, this specific tool is optimized for GSTR-1 JSON schemas. We recommend using our other utilities for GSTR-3B." } },
      { '@type': 'Question', name: "What are common GSTR-1 JSON errors?", acceptedAnswer: { '@type': 'Answer', text: "Common errors include duplicate invoice numbers, incorrect date formats (DD-MM-YYYY required), and invalid state codes for inter-state supplies." } },
      { '@type': 'Question', name: "Is this tool free for CAs and businesses?", acceptedAnswer: { '@type': 'Answer', text: "Yes, Taxzentic provides this validator entirely free of charge with no limits on the number of files you can check." } },
      { '@type': 'Question', name: "How fast is the offline JSON validation?", acceptedAnswer: { '@type': 'Answer', text: "Because it relies on your local device CPU rather than a network request, validation is virtually instantaneous, even for large files." } },
      {
        '@type': 'Question',
        name: 'Why should I validate my GSTR-1 JSON offline?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'The GST portal can often take several minutes to process an uploaded JSON file, only to return an error report if the schema does not match. This validator checks for core GST structural integrity offline, saving you time.'
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-12">
    <div class="text-center mb-10">
      <h1 class="text-3xl sm:text-4xl font-bold text-base mb-3">GSTR-1 JSON Validator</h1>
      <p class="text-muted text-lg max-w-2xl mx-auto">
        Verify your JSON files before uploading them to the GST Portal to avoid tedious correction steps. Validates JSON syntax and basic GST structural schemas.
      </p>
    </div>

    <div class="bg-surface border border-base rounded-2xl p-8 shadow-sm">
      <div class="space-y-6">
        <div>
          <label class="block text-sm font-medium text-base mb-2">Upload JSON Document to Validate</label>
          <input 
            type="file" 
            id="jsonFileInput" 
            accept="application/json"
            class="block w-full text-sm text-muted file:mr-4 file:py-2 file:px-4 file:rounded-full file:border-0 file:text-sm file:font-semibold file:bg-accent file:text-white hover:file:bg-accent/90"
          />
        </div>
        <div>
          <button id="validateBtn" class="w-full bg-accent hover:bg-accent/90 text-white font-semibold py-3 px-4 rounded-xl transition-colors">
            Run Validation
          </button>
        </div>
        
        <div id="validationResult" class="hidden rounded-lg border p-6">
          <div id="statusIcon" class="mb-4"></div>
          <h3 id="statusTitle" class="text-lg font-bold mb-2"></h3>
          <p id="statusDesc" class="text-sm text-muted mb-4"></p>
          <ul id="errorList" class="list-disc pl-5 text-sm text-red-600 hidden space-y-1"></ul>
        </div>
      </div>
    </div>
    
    <div class="mt-16 prose prose-slate max-w-none text-muted">
      <h2>Why Validate Returns Offline?</h2>
      <p>The GST portal can often take several minutes to process an uploaded JSON file, only to return an error report if the schema doesn't perfectly match expectations. This validator checks for core GST structural integrity (e.g. valid GSTIN formats, appropriate tax rates, valid date formats) completely offline.</p>
      
      
    </div>
  </div>

  <script is:inline>
    document.getElementById('validateBtn').addEventListener('click', () => {
      const fileInput = document.getElementById('jsonFileInput');
      const resultBox = document.getElementById('validationResult');
      const statusIcon = document.getElementById('statusIcon');
      const statusTitle = document.getElementById('statusTitle');
      const statusDesc = document.getElementById('statusDesc');
      const errorList = document.getElementById('errorList');
      
      resultBox.classList.add('hidden');
      errorList.classList.add('hidden');
      errorList.innerHTML = '';

      if (!fileInput.files.length) {
        alert('Please select a JSON file.');
        return;
      }

      const file = fileInput.files[0];
      const reader = new FileReader();

      reader.onload = (e) => {
        try {
          const data = JSON.parse(e.target.result);
          const errors = [];

          // Basic checks
          if (!data.gstin) {
            errors.push('Missing "gstin" attribute at the root level.');
          } else if (!/^[0-9]{2}[A-Z]{5}[0-9]{4}[A-Z]{1}[1-9A-Z]{1}Z[0-9A-Z]{1}$/.test(data.gstin)) {
            errors.push('Invalid GSTIN format assigned to the return.');
          }

          if (!data.fp) {
            errors.push('Missing "fp" (Financial Period) attribute. E.g., "042026"');
          }

          if (!data.gt) {
             // Not completely fatal but worth noting
          }

          // Check sections
          const sections = ['b2b', 'b2cl', 'b2cs', 'exp', 'cdnr', 'cdnur', 'hsn'];
          sections.forEach(sec => {
            if (data[sec] && !Array.isArray(data[sec])) {
              errors.push(`Section "${sec}" should be an Array.`);
            }
          });

          // Results
          resultBox.classList.remove('hidden', 'border-green-200', 'bg-green-50', 'border-red-200', 'bg-red-50');
          
          if (errors.length === 0) {
            resultBox.classList.add('border-green-200', 'bg-green-50');
            statusTitle.className = 'text-lg font-bold mb-2 text-green-800';
            statusTitle.textContent = 'JSON Validation Passed';
            statusDesc.textContent = 'The JSON structure looks structurally sound and ready for portal upload.';
          } else {
            resultBox.classList.add('border-red-200', 'bg-red-50');
            statusTitle.className = 'text-lg font-bold mb-2 text-red-800';
            statusTitle.textContent = 'Validation Completed with Errors';
            statusDesc.textContent = 'Please fix the following schema/logic errors before uploading:';
            errorList.classList.remove('hidden');
            errors.forEach(err => {
              const li = document.createElement('li');
              li.textContent = err;
              errorList.appendChild(li);
            });
          }

        } catch (err) {
          resultBox.classList.remove('hidden');
          resultBox.classList.add('border-red-200', 'bg-red-50');
          statusTitle.className = 'text-lg font-bold mb-2 text-red-800';
          statusTitle.textContent = 'Invalid JSON File';
          statusDesc.textContent = 'The uploaded file is not a valid JSON document. (Syntax Error)';
          errorList.classList.add('hidden');
        }
      };

      reader.readAsText(file);
    });
  </script>

    <!-- FAQ Section -->
    <section class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-16 pt-12 border-t border-base" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-base mb-8">Frequently Asked Questions</h2>
      <div class="space-y-4">
        {structuredData[1].mainEntity.map((faq, i) => (
          <details class="group rounded-xl border border-base bg-surface overflow-hidden" id={`faq-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span>{faq.name}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[15px] text-muted leading-relaxed border-t border-base pt-4">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </section>
</BaseLayout>