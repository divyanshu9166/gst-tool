---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GST on Freight Calculator | GTA vs Non-GTA (2026)';
const description = 'Calculate GST on freight and transportation services in India. Check RCM applicability and ITC eligibility for GTA (Goods Transport Agency) and Courier services.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GST on Freight Calculator',
    url: Astro.site?.toString() ? `${Astro.site}gst-on-freight-calculator` : 'https://example.com/gst-on-freight-calculator',
    description: 'Calculate GST on freight and transportation services (GTA/Non-GTA).',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is a Goods Transport Agency (GTA) under GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'A GTA is any person who provides service in relation to transport of goods by road and issues a consignment note. If no consignment note is issued, the service provider is not considered a GTA, and their services are generally exempt from GST.'
        }
      },
      {
        '@type': 'Question',
        name: 'What are the GST rates for GTA services?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'GTA services attract GST at either 5% (without ITC for the GTA) or 12% (with ITC for the GTA). The GTA must declare their chosen option at the beginning of the financial year.'
        }
      },
      {
        '@type': 'Question',
        name: 'When does Reverse Charge Mechanism (RCM) apply to freight?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'RCM applies when a GTA transports goods for specified recipients (like registered businesses, factories, societies, or partnership firms) and the GTA has NOT opted for the 12% or 5% forward charge mechanism. In this case, the recipient pays 5% GST under RCM.'
        }
      },
      {
        '@type': 'Question',
        name: 'Who pays the GST under RCM for freight?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under RCM, the person liable to pay the freight (either the consignor/sender or the consignee/receiver) is liable to pay the GST directly to the government.'
        }
      },
      {
        '@type': 'Question',
        name: 'Is GST applicable if I hire a local truck without a consignment note?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Transport of goods by road by an ordinary goods carriage (which does not issue a consignment note) is exempt from GST.'
        }
      },
      {
        '@type': 'Question',
        name: 'Can the recipient claim ITC if they pay 5% GST under RCM?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, the recipient who pays 5% GST under RCM can claim full Input Tax Credit (ITC) if the transportation was for business purposes.'
        }
      },
      {
        '@type': 'Question',
        name: 'What is the GST on Courier services?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Courier agency services are subject to 18% GST under the Forward Charge Mechanism (FCM). RCM does not apply to courier services.'
        }
      },
      {
        '@type': 'Question',
        name: 'Are there any exemptions for GTA services?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes, GTA services are exempt when transporting specific goods like agricultural produce, milk, salt, food grain, organic manure, defense/military equipment, and relief materials.'
        }
      },
      {
        '@type': 'Question',
        name: 'What is Forward Charge Mechanism (FCM) in GTA?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under FCM, the GTA collects the GST (either at 5% or 12%) from the customer on the invoice and deposits it with the government. The customer does not pay RCM.'
        }
      },
      {
        '@type': 'Question',
        name: 'Does a GTA need to register for GST if they only provide RCM services?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'If a GTA provides exclusively those services where 100% of the tax is payable by the recipient under RCM, the GTA is exempt from obtaining GST registration.'
        }
      }
    ]
  }
];
---

<BaseLayout title={title} description={description} structuredData={structuredData}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 lg:px-8 py-12">
    <!-- Header -->
    <div class="text-center mb-10">
      <h1 class="text-[32px] sm:text-[40px] tracking-[-1.5px] font-semibold text-base mb-4 leading-tight">
        GST on Freight Calculator
      </h1>
      <p class="text-[16px] text-muted max-w-2xl mx-auto leading-relaxed">
        Determine GST liability, Reverse Charge Mechanism (RCM) applicability, and ITC eligibility for transport of goods in India.
      </p>
    </div>

    <!-- Main Card -->
    <div class="bg-surface border border-base rounded-[16px] shadow-sm overflow-hidden mb-8">
      <div class="p-6 sm:p-8">
        <form id="freight-calculator-form" class="space-y-6">
          
          <!-- Freight Amount -->
          <div>
            <label for="freightAmount" class="block text-[14px] font-medium text-base mb-2">Freight Amount (₹)</label>
            <div class="relative">
              <div class="pointer-events-none absolute inset-y-0 left-0 flex items-center pl-3">
                <span class="text-muted sm:text-sm">₹</span>
              </div>
              <input 
                type="number" 
                id="freightAmount" 
                name="freightAmount"
                class="block w-full rounded-[8px] border-0 py-2.5 pl-8 pr-3 text-base ring-1 ring-inset ring-base focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 bg-surface transition-all"
                placeholder="e.g. 15000"
                min="0"
                step="1"
                required
              >
            </div>
          </div>

          <!-- Transport Type -->
          <div>
            <label class="block text-[14px] font-medium text-base mb-2">Transport Type</label>
            <select id="transportType" name="transportType" class="block w-full rounded-[8px] border-0 py-2.5 pl-3 pr-10 text-base ring-1 ring-inset ring-base focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 bg-surface transition-all">
              <option value="gta">Goods Transport Agency (GTA)</option>
              <option value="courier">Courier Agency</option>
              <option value="nongta">Ordinary Truck / Auto (No Consignment Note)</option>
            </select>
          </div>

          <!-- GTA Specific Options -->
          <div id="gta-options" class="space-y-6 border-t border-base pt-6 mt-6">
            <div>
              <label class="block text-[14px] font-medium text-base mb-2">Is the recipient a GST Registered Business?</label>
              <div class="grid grid-cols-2 gap-3">
                <label class="relative flex cursor-pointer rounded-lg border border-base bg-surface p-3 focus:outline-none has-[:checked]:border-primary has-[:checked]:bg-subtle transition-all">
                  <input type="radio" name="recipientStatus" value="registered" class="sr-only" checked>
                  <span class="text-[13px] font-medium text-base">Yes (B2B)</span>
                </label>
                <label class="relative flex cursor-pointer rounded-lg border border-base bg-surface p-3 focus:outline-none has-[:checked]:border-primary has-[:checked]:bg-subtle transition-all">
                  <input type="radio" name="recipientStatus" value="unregistered" class="sr-only">
                  <span class="text-[13px] font-medium text-base">No (B2C)</span>
                </label>
              </div>
            </div>

            <div id="gta-tax-mode">
              <label class="block text-[14px] font-medium text-base mb-2">How has the GTA opted to pay tax?</label>
              <select id="gtaOpt" name="gtaOpt" class="block w-full rounded-[8px] border-0 py-2.5 pl-3 pr-10 text-base ring-1 ring-inset ring-base focus:ring-2 focus:ring-inset focus:ring-primary sm:text-sm sm:leading-6 bg-surface transition-all">
                <option value="rcm">Under RCM @ 5% (Default)</option>
                <option value="fcm12">Forward Charge @ 12%</option>
                <option value="fcm5">Forward Charge @ 5%</option>
              </select>
            </div>
          </div>

        </form>
      </div>

      <!-- Results Section -->
      <div id="results-section" class="bg-subtle border-t border-base p-6 sm:p-8 hidden">
        <div class="mb-6">
          <div class="flex items-center gap-2 mb-1">
            <h3 class="text-[14px] font-medium text-muted uppercase tracking-wider">GST Applicability & Liability</h3>
          </div>
          <div id="status-badge" class="inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium mt-2">
            <!-- Badge content injected via JS -->
          </div>
          <p id="status-description" class="text-[14px] text-base mt-3 leading-relaxed">
            <!-- Description injected via JS -->
          </p>
        </div>

        <div id="calculation-breakdown" class="space-y-4">
          <div class="flex justify-between items-center">
            <span class="text-[15px] text-muted">Base Freight Amount</span>
            <span id="res-base" class="text-[15px] font-medium text-base">₹0</span>
          </div>
          
          <div class="flex justify-between items-center text-red-600">
            <span id="res-gst-label" class="text-[15px]">GST Amount</span>
            <span id="res-gst" class="text-[15px] font-medium">₹0</span>
          </div>
          
          <div class="my-4 border-t border-base"></div>
          
          <div class="flex justify-between items-center">
            <div>
              <span class="block text-[16px] font-semibold text-base">Total Payable to Transporter</span>
              <span class="block text-[13px] text-muted">Amount on Invoice</span>
            </div>
            <span id="res-transporter" class="text-[20px] font-bold text-base">₹0</span>
          </div>
          
          <div id="rcm-row" class="flex justify-between items-center hidden mt-2 p-3 bg-red-50/50 rounded-lg border border-red-100">
            <div>
              <span class="block text-[14px] font-semibold text-red-700">RCM Payable by Recipient</span>
              <span class="block text-[12px] text-red-600">Pay directly to Govt (Claim ITC later)</span>
            </div>
            <span id="res-rcm" class="text-[16px] font-bold text-red-700">₹0</span>
          </div>
        </div>
      </div>
    </div>
  </div>

  
  <!-- Related Guides -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-12">
    <div class="border-t border-base pt-12">
      <h2 class="text-[24px] font-semibold text-base mb-4">Related Guides</h2>
      <ul class="list-disc pl-5 space-y-2">
        <li><a href="/blog/gst-invoice-format" class="text-primary hover:underline">GST Invoice Format 2026: Mandatory Fields Under Rule 46 (Free Template)</a></li>
        <li><a href="/blog/gst-composition-scheme-2026-guide" class="text-primary hover:underline">GST Composition Scheme 2026: Complete Guide for Small Business</a></li>
      </ul>
    </div>
  </div>
<!-- FAQ Section -->
  <div class="mx-auto max-w-5xl px-4 sm:px-6 lg:px-8 pb-20 mt-8">
    <div class="border-t border-base pt-12">
      <h2 class="text-[28px] tracking-[-1px] font-semibold text-base mb-2">Frequently Asked Questions</h2>
      <p class="text-muted text-[15px] mb-8">Understanding GST on freight and GTA services.</p>
      <div class="space-y-3">
        {structuredData[1].mainEntity.map((faq, i) => (
          <details class="group rounded-[8px] border border-base bg-surface overflow-hidden" id={`faq-${i}`}>
            <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
              <span class="text-[15px]">{faq.name}</span>
              <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
            </summary>
            <div class="px-6 pb-5 text-[14px] text-muted leading-relaxed border-t border-base pt-4">{faq.acceptedAnswer.text}</div>
          </details>
        ))}
      </div>
    </div>
  </div>
</BaseLayout>

<script lang="ts">
  const form = document.getElementById('freight-calculator-form');
  const amountInput = document.getElementById('freightAmount') as HTMLInputElement;
  const typeSelect = document.getElementById('transportType') as HTMLSelectElement;
  const gtaOptions = document.getElementById('gta-options');
  const gtaOptSelect = document.getElementById('gtaOpt') as HTMLSelectElement;
  const recipientRadios = document.querySelectorAll('input[name="recipientStatus"]');
  const gtaTaxMode = document.getElementById('gta-tax-mode');
  
  const resultsSection = document.getElementById('results-section');
  const statusBadge = document.getElementById('status-badge');
  const statusDesc = document.getElementById('status-description');
  
  const resBase = document.getElementById('res-base');
  const resGst = document.getElementById('res-gst');
  const resGstLabel = document.getElementById('res-gst-label');
  const resTransporter = document.getElementById('res-transporter');
  const resRcm = document.getElementById('res-rcm');
  const rcmRow = document.getElementById('rcm-row');

  function formatINR(number) {
    return new Intl.NumberFormat('en-IN', {
      style: 'currency',
      currency: 'INR',
      minimumFractionDigits: 0,
      maximumFractionDigits: 0,
    }).format(number);
  }

  function handleUI() {
    if (typeSelect.value === 'gta') {
      gtaOptions.classList.remove('hidden');
      
      let recipientType = 'registered';
      recipientRadios.forEach((r: HTMLInputElement) => {
        if (r.checked) recipientType = r.value;
      });
      
      if (recipientType === 'unregistered') {
          // If unregistered (B2C), usually exempt if not a specified person, but for simplicity we assume fully exempt or FCM.
          // Actually, GTA to unregistered person is exempt under Notification No. 12/2017.
          gtaTaxMode.classList.add('hidden');
      } else {
          gtaTaxMode.classList.remove('hidden');
      }
    } else {
      gtaOptions.classList.add('hidden');
    }
    calculate();
  }

  function calculate() {
    const amount = parseFloat(amountInput.value) || 0;
    
    if (amount <= 0) {
      resultsSection.classList.add('hidden');
      return;
    }
    
    resultsSection.classList.remove('hidden');

    const type = typeSelect.value;
    let recipientType = 'registered';
    recipientRadios.forEach((r: HTMLInputElement) => {
      if (r.checked) recipientType = r.value;
    });
    
    const gtaOpt = gtaOptSelect.value;

    let isTaxable = false;
    let isRcm = false;
    let gstRate = 0;
    
    let badgeClass = '';
    let badgeText = '';
    let descHtml = '';
    
    resBase.textContent = formatINR(amount);

    if (type === 'nongta') {
      isTaxable = false;
      badgeClass = 'bg-green-100 text-green-800';
      badgeText = '<span class="w-1.5 h-1.5 rounded-full bg-green-600"></span> Exempt';
      descHtml = 'Transport of goods by an ordinary goods carriage (without issuing a consignment note) is completely <strong>Exempt from GST</strong>.';
      
      resGstLabel.textContent = 'GST Amount';
      resGst.textContent = '₹0';
      resTransporter.textContent = formatINR(amount);
      resTransporter.parentElement.parentElement.classList.remove('text-green-700');
      rcmRow.classList.add('hidden');
      
    } else if (type === 'courier') {
      isTaxable = true;
      gstRate = 0.18;
      badgeClass = 'bg-yellow-100 text-yellow-800';
      badgeText = '<span class="w-1.5 h-1.5 rounded-full bg-yellow-600"></span> Taxable (Forward Charge 18%)';
      descHtml = 'Courier services attract a flat <strong>18% GST under Forward Charge</strong>. The courier agency collects this from you.';
      
      const gstAmount = amount * gstRate;
      resGstLabel.textContent = 'GST @ 18%';
      resGst.textContent = formatINR(gstAmount);
      resTransporter.textContent = formatINR(amount + gstAmount);
      resTransporter.parentElement.parentElement.classList.add('text-green-700');
      rcmRow.classList.add('hidden');
      
    } else if (type === 'gta') {
        if (recipientType === 'unregistered') {
            isTaxable = false;
            badgeClass = 'bg-green-100 text-green-800';
            badgeText = '<span class="w-1.5 h-1.5 rounded-full bg-green-600"></span> Exempt (B2C)';
            descHtml = 'GTA services provided to unregistered individuals (B2C) are generally <strong>Exempt from GST</strong>.';
            
            resGstLabel.textContent = 'GST Amount';
            resGst.textContent = '₹0';
            resTransporter.textContent = formatINR(amount);
            resTransporter.parentElement.parentElement.classList.remove('text-green-700');
            rcmRow.classList.add('hidden');
        } else {
            isTaxable = true;
            if (gtaOpt === 'rcm') {
                isRcm = true;
                gstRate = 0.05;
                badgeClass = 'bg-red-100 text-red-800';
                badgeText = '<span class="w-1.5 h-1.5 rounded-full bg-red-600"></span> Taxable under RCM (5%)';
                descHtml = 'Since the GTA has not opted for forward charge, the <strong>Recipient pays 5% GST directly to the Govt</strong> via Reverse Charge Mechanism.';
                
                const gstAmount = amount * gstRate;
                resGstLabel.textContent = 'GST @ 5% (RCM)';
                resGst.textContent = formatINR(gstAmount);
                resTransporter.textContent = formatINR(amount);
                resTransporter.parentElement.parentElement.classList.remove('text-green-700');
                
                rcmRow.classList.remove('hidden');
                resRcm.textContent = formatINR(gstAmount);
            } else if (gtaOpt === 'fcm12') {
                gstRate = 0.12;
                badgeClass = 'bg-yellow-100 text-yellow-800';
                badgeText = '<span class="w-1.5 h-1.5 rounded-full bg-yellow-600"></span> Taxable (FCM 12%)';
                descHtml = 'The GTA has opted to pay tax at 12% under Forward Charge. They collect this from you and claim ITC on their inputs.';
                
                const gstAmount = amount * gstRate;
                resGstLabel.textContent = 'GST @ 12%';
                resGst.textContent = formatINR(gstAmount);
                resTransporter.textContent = formatINR(amount + gstAmount);
                resTransporter.parentElement.parentElement.classList.add('text-green-700');
                rcmRow.classList.add('hidden');
            } else if (gtaOpt === 'fcm5') {
                gstRate = 0.05;
                badgeClass = 'bg-yellow-100 text-yellow-800';
                badgeText = '<span class="w-1.5 h-1.5 rounded-full bg-yellow-600"></span> Taxable (FCM 5%)';
                descHtml = 'The GTA has opted to pay tax at 5% under Forward Charge (without claiming ITC on their inputs).';
                
                const gstAmount = amount * gstRate;
                resGstLabel.textContent = 'GST @ 5%';
                resGst.textContent = formatINR(gstAmount);
                resTransporter.textContent = formatINR(amount + gstAmount);
                resTransporter.parentElement.parentElement.classList.add('text-green-700');
                rcmRow.classList.add('hidden');
            }
        }
    }
    
    statusBadge.className = `inline-flex items-center gap-1.5 rounded-full px-3 py-1 text-sm font-medium ${badgeClass}`;
    statusBadge.innerHTML = badgeText;
    statusDesc.innerHTML = descHtml;
  }

  // Event Listeners
  form.addEventListener('input', handleUI);
  form.addEventListener('change', handleUI);
  
  // Initial UI Setup
  handleUI();
</script>
