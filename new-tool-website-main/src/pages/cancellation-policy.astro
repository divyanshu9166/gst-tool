---
import BaseLayout from '../layouts/BaseLayout.astro';
const title = 'Cancellation Policy';
const description = 'Our cancellation policy.';
---

<BaseLayout {title} {description}>
  <div class="mx-auto max-w-4xl px-4 sm:px-6 py-20 text-center">
    <h1 class="text-4xl font-bold mb-4">Cancellation Policy</h1>
    <p class="text-xl text-muted">You do not need an active subscription, so there is nothing to cancel.</p>
  </div>
</BaseLayout>