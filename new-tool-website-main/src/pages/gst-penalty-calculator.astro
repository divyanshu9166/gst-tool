---
import BaseLayout from '../layouts/BaseLayout.astro';

const title = 'GST Penalty Calculator | Section 122, 73 & 74';
const description = 'Calculate GST penalties for late payment, fraud, short payment, and fake invoices under Section 122, 73, and 74 of the CGST Act. Free offline penalty calculator.';

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'WebApplication',
    name: 'GST Penalty Calculator',
    url: Astro.site?.toString() ? `${Astro.site}gst-penalty-calculator` : 'https://example.com/gst-penalty-calculator',
    description: 'Calculate GST penalties under Section 122, 73, and 74.',
    applicationCategory: 'FinanceApplication',
    operatingSystem: 'Any',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What is the general penalty under GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under Section 125, any person who contravenes any provision of the GST Act for which no separate penalty is prescribed, shall be liable to a general penalty which may extend to ₹25,000.',
        }
      },
      {
        '@type': 'Question',
        name: 'What is the penalty for fraud or willful misstatement?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under Section 74, if tax is short-paid or evaded due to fraud or willful suppression of facts, the penalty is 100% of the tax evaded or ₹10,000, whichever is higher.',
        }
      },
      {
        '@type': 'Question',
        name: 'What is the penalty for non-fraud genuine errors?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Under Section 73, if tax is short-paid for reasons other than fraud (genuine mistakes), the penalty is 10% of the tax due or ₹10,000, whichever is higher.',
        }
      },
      {
        '@type': 'Question',
        name: 'Is there a minimum penalty amount?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. For most major offenses involving tax evasion or short payment, the law prescribes a strict minimum penalty of ₹10,000, even if the actual tax amount evaded is very small.',
        }
      },
      {
        '@type': 'Question',
        name: 'What is the penalty for issuing fake invoices?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Issuing an invoice without actual supply of goods or services to wrongly pass on ITC is a severe offense under Section 122. The penalty is 100% of the tax evaded or ₹10,000, whichever is higher.',
        }
      },
      {
        '@type': 'Question',
        name: 'Can the penalty be reduced if I pay before a notice is issued?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Under Section 73 (non-fraud), if you pay the tax and interest before a show-cause notice is issued, no penalty is levied. Under Section 74 (fraud), if you pay before the notice, the penalty is reduced to 15%.',
        }
      },
      {
        '@type': 'Question',
        name: 'What happens if I fail to register for GST?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'If you are liable to register but fail to do so, the penalty is 100% of the tax due or ₹10,000, whichever is higher.',
        }
      },
      {
        '@type': 'Question',
        name: 'Is penalty the same as late fees or interest?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Late fees are for delayed return filing. Interest is for the time value of delayed tax payment. Penalty is a punitive fine for committing specific offenses or evading tax.',
        }
      }
    ]
  }
];
---

<BaseLayout {title} {description} {structuredData}>
  <div class="mx-auto max-w-3xl px-4 sm:px-6 py-12 lg:py-24">
    <!-- Header -->
    <div class="mb-10 text-center">
      <div class="inline-flex items-center gap-2 rounded-full border border-base bg-surface px-4 py-1.5 text-[12px] font-mono uppercase tracking-wider text-muted mb-4 shadow-[0_1px_1px_#00000005]">
        <span class="h-1.5 w-1.5 rounded-full bg-accent"></span>
        100% Offline Tool
      </div>
      <h1 class="text-4xl sm:text-5xl font-bold tracking-tight text-base mb-4">
        GST Penalty Calculator
      </h1>
      <p class="text-[16px] text-muted max-w-xl mx-auto leading-relaxed">
        Calculate the statutory penalty applicable for short payment of tax, fraud, or issuing fake invoices under Sections 122, 73, and 74.
      </p>
    </div>

    <!-- Main Tool Container -->
    <div class="rounded-[12px] border border-base bg-surface p-6 sm:p-8 shadow-[0_8px_30px_rgb(0,0,0,0.04)] mb-12">
      <div class="flex flex-col gap-6">
        
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div class="flex flex-col gap-2">
            <label for="tax-evaded" class="text-sm font-semibold text-base">Tax Amount Evaded / Short Paid (₹)</label>
            <input 
              type="number" 
              id="tax-evaded" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-mono focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
              placeholder="e.g. 50000"
              min="0"
            />
          </div>

          <div class="flex flex-col gap-2">
            <label for="offense-type" class="text-sm font-semibold text-base">Nature of Offense</label>
            <select 
              id="offense-type" 
              class="w-full rounded-md border border-base bg-surface px-4 py-3 text-[16px] font-medium focus:border-accent focus:outline-none focus:ring-1 focus:ring-accent transition-colors"
            >
              <option value="10">Genuine Error / Non-Fraud (Sec 73)</option>
              <option value="100">Fraud / Willful Suppression (Sec 74)</option>
              <option value="100">Issuing Fake Invoice (Sec 122)</option>
              <option value="100">Failure to Register for GST (Sec 122)</option>
            </select>
          </div>
        </div>

      </div>

      <!-- Result Card -->
      <div id="result-card" class="mt-8 hidden overflow-hidden rounded-[8px] border border-base bg-subtle transition-all duration-300">
        
        <div class="p-6">
          <h3 class="text-[14px] font-medium text-muted mb-4 uppercase tracking-wider">Penalty Calculation Result</h3>
          
          <div class="space-y-4">
            <div class="flex justify-between items-center pb-4 border-b border-base/50">
              <span class="text-base font-medium">Calculated Percentage Penalty:</span>
              <div class="text-right">
                <span class="text-xl font-mono text-base" id="res-calc-amount">₹0</span>
                <p class="text-xs text-muted mt-1">Based on <span id="res-percent">10</span>% of tax due</p>
              </div>
            </div>

            <div class="flex justify-between items-center pb-4 border-b border-base/50">
              <span class="text-base font-medium">Statutory Minimum Penalty:</span>
              <span class="text-xl font-mono text-base">₹10,000</span>
            </div>

            <div class="flex justify-between items-center pt-2">
              <span class="text-lg font-bold text-red-600 dark:text-red-400">Final Penalty Payable:</span>
              <div class="text-right">
                <span class="text-3xl font-mono font-bold text-red-600 dark:text-red-400" id="res-final-amount">₹0</span>
                <p class="text-xs text-red-600/80 dark:text-red-400/80 mt-1">(Whichever is higher)</p>
              </div>
            </div>
          </div>
        </div>
        
        <div class="border-t border-red-200/50 bg-red-50 dark:bg-red-900/10 dark:border-red-900/30 p-4">
          <p class="text-sm text-red-700 dark:text-red-400 font-medium">
            ⚠️ The GST officer will levy this penalty in addition to the original tax due and the 18% per annum late payment interest.
          </p>
        </div>

      </div>
    </div>

    <!-- SEO Content -->
    <article class="prose prose-neutral dark:prose-invert max-w-none text-[15px] leading-relaxed">
      <h2 class="text-2xl font-semibold mb-4">Understanding GST Penalties (Sections 122, 73, and 74)</h2>
      <p>
        The Goods and Services Tax (GST) Act is equipped with strict penal provisions to deter tax evasion, fraud, and non-compliance. While late fees apply simply for filing a return past the due date, and interest applies for the time value of delayed payments, a <strong>penalty</strong> is a severe financial punishment levied when a taxpayer commits a specific offense.
      </p>
      <p>
        Our <strong>GST Penalty Calculator</strong> allows you to accurately determine the statutory penalty amount you may face if you short-pay your taxes, either by genuine mistake or through willful suppression. (Note: If you are looking for a <strong>gst penalty calculator for delayed filing</strong> of returns, please use our <a href="/late-fee-calculator" class="text-accent hover:underline">Late Fee Calculator</a> instead).
      </p>
      
      <h3>1. Non-Fraud or Genuine Errors (Section 73)</h3>
      <p>
        The law recognizes that human errors happen. If you fail to pay tax, short-pay tax, or wrongly avail Input Tax Credit (ITC) due to a genuine mistake or misinterpretation of the law—without any intent to evade tax—Section 73 applies.
      </p>
      <ul>
        <li><strong>Penalty Rate:</strong> 10% of the tax due OR ₹10,000, <strong>whichever is higher</strong>.</li>
        <li><strong>Relief:</strong> If you realize your mistake, calculate the tax and interest, and pay it <em>before</em> the GST officer issues a Show Cause Notice, no penalty will be levied at all. If you pay within 30 days of the notice, no penalty is levied.</li>
      </ul>

      <h3>2. Fraud or Willful Suppression (Section 74)</h3>
      <p>
        If the GST officer determines that you short-paid tax or wrongly claimed ITC by way of fraud, willful misstatement, or suppression of facts to actively evade taxes, the harsh provisions of Section 74 apply.
      </p>
      <ul>
        <li><strong>Penalty Rate:</strong> 100% of the tax evaded OR ₹10,000, <strong>whichever is higher</strong>.</li>
        <li><strong>Relief:</strong> If you voluntarily pay the tax and interest before the notice is issued, the penalty is reduced to 15%. If you pay within 30 days of receiving the notice, the penalty is reduced to 25%.</li>
      </ul>

      <h3>3. Specific Offenses (Section 122)</h3>
      <p>
        Section 122 lists 21 specific offenses that attract an immediate and severe penalty. The penalty for these offenses is <strong>100% of the tax involved or ₹10,000, whichever is higher</strong>. Some of the most common offenses under this section include:
      </p>
      <ul>
        <li><strong>Fake Invoices:</strong> Issuing an invoice without actually supplying any goods or services (to fraudulently pass on ITC).</li>
        <li><strong>Unrecorded Sales:</strong> Supplying goods or services without issuing any invoice to evade tax.</li>
        <li><strong>Failure to Register:</strong> Being liable to register under GST but failing to obtain registration.</li>
        <li><strong>TDS/TCS Default:</strong> Failing to deduct TDS or collect TCS, or deducting it but failing to pay it to the government.</li>
      </ul>

      <h3>General Penalty (Section 125)</h3>
      <p>
        If you commit a minor procedural offense for which no specific penalty is defined in the Act, the officer can invoke the General Penalty clause under Section 125. This penalty can extend up to ₹25,000. Examples include failing to display your GSTIN on your business signboard or not maintaining proper accounts at the principal place of business.
      </p>
    </article>

    <!-- FAQ Section -->
    <section class="mt-16 pt-12 border-t border-base" aria-labelledby="faq-heading">
      <h2 id="faq-heading" class="text-2xl sm:text-3xl font-bold text-base mb-8">
        Frequently Asked Questions
      </h2>
      <div class="space-y-4">
        
        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>What is the general penalty under GST?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            Under Section 125, any person who contravenes any provision of the GST Act for which no separate penalty is prescribed, shall be liable to a general penalty which may extend to ₹25,000.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>What is the penalty for fraud or willful misstatement?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            Under Section 74, if tax is short-paid or evaded due to fraud or willful suppression of facts, the penalty is 100% of the tax evaded or ₹10,000, whichever is higher.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>What is the penalty for non-fraud genuine errors?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            Under Section 73, if tax is short-paid for reasons other than fraud (genuine mistakes), the penalty is 10% of the tax due or ₹10,000, whichever is higher.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>Is there a minimum penalty amount?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            Yes. For most major offenses involving tax evasion or short payment, the law prescribes a strict minimum penalty of ₹10,000, even if the actual tax amount evaded is very small.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>What is the penalty for issuing fake invoices?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            Issuing an invoice without actual supply of goods or services to wrongly pass on ITC is a severe offense under Section 122. The penalty is 100% of the tax evaded or ₹10,000, whichever is higher.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>Can the penalty be reduced if I pay before a notice is issued?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            Yes. Under Section 73 (non-fraud), if you pay the tax and interest before a show-cause notice is issued, no penalty is levied. Under Section 74 (fraud), if you pay before the notice, the penalty is reduced to 15%.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>What happens if I fail to register for GST?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            If you are liable to register but fail to do so, the penalty is 100% of the tax due or ₹10,000, whichever is higher.
          </div>
        </details>

        <details class="group rounded-xl border border-base bg-surface overflow-hidden">
          <summary class="flex cursor-pointer items-center justify-between gap-4 px-6 py-4 font-medium text-base hover:bg-subtle transition-colors list-none">
            <span>Is penalty the same as late fees or interest?</span>
            <svg class="h-5 w-5 flex-shrink-0 text-muted group-open:rotate-180 transition-transform duration-200" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7" /></svg>
          </summary>
          <div class="px-6 pb-5 text-sm text-muted leading-relaxed border-t border-base pt-4">
            No. Late fees are for delayed return filing. Interest is for the time value of delayed tax payment. Penalty is a punitive fine for committing specific offenses or evading tax.
          </div>
        </details>

      </div>
    </section>

  </div>

  <script lang="ts">
    const taxInput = document.getElementById('tax-evaded') as HTMLInputElement;
    const typeSelect = document.getElementById('offense-type') as HTMLSelectElement;

    const resultCard = document.getElementById('result-card')!;
    const resPercent = document.getElementById('res-percent')!;
    const resCalcAmount = document.getElementById('res-calc-amount')!;
    const resFinalAmount = document.getElementById('res-final-amount')!;

    function formatCur(num: number) {
      return '₹' + num.toLocaleString('en-IN', { maximumFractionDigits: 2 });
    }

    function calculate() {
      const tax = parseFloat(taxInput.value) || 0;
      const percentStr = typeSelect.value;
      const percent = parseFloat(percentStr) || 10;

      if (tax <= 0) {
        resultCard.classList.add('hidden');
        return;
      }

      resultCard.classList.remove('hidden');

      resPercent.textContent = percentStr;

      const calcPenalty = tax * (percent / 100);
      resCalcAmount.textContent = formatCur(calcPenalty);

      const finalPenalty = Math.max(calcPenalty, 10000);
      resFinalAmount.textContent = formatCur(finalPenalty);
    }

    [taxInput, typeSelect].forEach(el => el.addEventListener('input', calculate));
    
  </script>
</BaseLayout>
