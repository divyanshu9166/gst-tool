---
/**
 * Footer — site-wide footer with tool links, legal links, and copyright.
 */
const year = new Date().getFullYear();

const tools = [
  { href: '/gst-calculator', label: 'GST Calculator' },
  { href: '/gst-registration-checker', label: 'GST Registration Checker' },
  { href: '/advance-tax-calculator', label: 'Advance Tax Calculator' },
  { href: '/place-of-supply-calculator', label: 'Place of Supply Calculator' },
  { href: '/hsn-code-lookup', label: 'HSN Code Lookup' },
  { href: '/gstin-validator', label: 'GSTIN Validator' },
  { href: '/late-fee-calculator', label: 'Late Fee Calculator' },
  { href: '/gst-due-dates', label: 'Due Dates Calendar' },
  { href: '/gstr-2b-reconciliation-tool', label: 'GSTR-2B Reconciliation Tool' },
  { href: '/gst-state-codes', label: 'GST State Codes' },
  { href: '/blog', label: 'GST Blog' },
  { href: '/faq', label: 'FAQ' },
];

const company = [
  { href: '/about', label: 'About Us' },
  { href: '/pricing', label: 'Pricing' },
  { href: '/referral-program', label: 'Referral Program' },
  { href: '/blog', label: 'Blog' }
];

const newTools = [
  { href: '/gstr1-json-to-excel', label: 'GSTR 1 Json to Excel' },
  { href: '/gst-error-report', label: 'GST Error Report' },
  { href: '/gstr1-json-validator', label: 'GSTR 1 JSON Validator' },
  { href: '/merge-excel-files', label: 'Merge Excel Files' },
  ...tools
];

const documentation = [
  { href: '/privacy-policy', label: 'Privacy & Policy' },
  { href: '/terms', label: 'Terms & Conditions' },
  { href: '/refund-policy', label: 'Refund Policy' },
  { href: '/cancellation-policy', label: 'Cancellation Policy' },
];

const resources = [
  { href: '/help-center', label: 'Help Center' },
  { href: '/contact', label: 'Contact Us' },
  { href: '/your-account', label: 'Your Account' },
];
---

<footer class="print:hidden border-t border-base bg-subtle mt-16" role="contentinfo">
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8 py-16">
    <div class="grid grid-cols-1 gap-10 sm:grid-cols-2 lg:grid-cols-5">

      <!-- Brand column -->
      <div class="lg:col-span-1">
        <a href="/" class="flex items-center gap-2 font-semibold text-base hover:text-accent transition-colors" aria-label="Taxzentic Home">
          <img
            src="/taxzentic-logo.png"
            alt="Taxzentic Logo"
            class="h-10 w-36 sm:w-48 object-cover object-center dark:hidden"
          />
          <img
            src="/taxzentic-logo-white.png"
            alt="Taxzentic Logo"
            class="h-10 w-36 sm:w-48 object-cover object-center hidden dark:block"
          />
        </a>
        <p class="mt-3 text-sm text-muted max-w-xs leading-relaxed">
          Free, instant GST tools for Indian businesses and taxpayers. Calculate GST, look up HSN/SAC codes, and validate GSTIN numbers — all offline, no login required.
        </p>
        <p class="mt-4 text-xs text-muted">
          <strong>Disclaimer:</strong> This website is for informational purposes only. Always verify with the official GST portal at <a href="https://www.gst.gov.in" target="_blank" rel="noopener noreferrer" class="underline hover:text-accent">gst.gov.in</a>.
        </p>
      </div>

      <!-- Company column -->
      <div>
        <h3 class="text-sm font-semibold text-base mb-4">Company</h3>
        <ul class="space-y-2">
          {company.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-muted hover:text-accent transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Tools column -->
      <div>
        <h3 class="text-sm font-semibold text-base mb-4">Our Free Tools</h3>
        <ul class="space-y-2">
          {newTools.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-muted hover:text-accent transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Documentation column -->
      <div>
        <h3 class="text-sm font-semibold text-base mb-4">Documentation</h3>
        <ul class="space-y-2">
          {documentation.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-muted hover:text-accent transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>

      <!-- Resources column -->
      <div>
        <h3 class="text-sm font-semibold text-base mb-4">Resources</h3>
        <ul class="space-y-2">
          {resources.map(({ href, label }) => (
            <li>
              <a href={href} class="text-sm text-muted hover:text-accent transition-colors">
                {label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </div>

    <!-- Bottom bar -->
    <div class="mt-10 pt-6 border-t border-base flex flex-col sm:flex-row items-center justify-between gap-4">
      <p class="text-xs text-muted">
        &copy; {year} Taxzentic. All rights reserved.
      </p>
      <p class="text-xs text-muted">
        GST data is indicative. Rates subject to change per Government of India notifications.
      </p>
    </div>
  </div>
</footer>
