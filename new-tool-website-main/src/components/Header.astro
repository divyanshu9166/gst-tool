---
/**
 * Header — sticky top navigation with mobile hamburger menu and dark mode toggle.
 */
const navCategories = [
  {
    title: 'Calculators',
    links: [
      { href: '/gst-calculator', label: 'GST Calculator' },
      { href: '/invoice-generator', label: 'Invoice Generator' },
      { href: '/advance-tax-calculator', label: 'Advance Tax Calculator' },
      { href: '/rcm-calculator', label: 'RCM Calculator' },
      { href: '/composition-scheme-calculator', label: 'Composition Scheme' },
      { href: '/itc-calculator', label: 'ITC Calculator' },
      { href: '/gst-interest-calculator', label: 'Interest Calculator' },
      { href: '/tds-gst-calculator', label: 'TDS Calculator' },
      { href: '/tcs-gst-calculator', label: 'TCS Calculator' },
      { href: '/gst-penalty-calculator', label: 'Penalty Calculator' },
      { href: '/late-fee-calculator', label: 'Late Fee Calculator' },
    ]
  },
  {
    title: 'Lookups & Tools',
    links: [
      { href: '/gst-registration-checker', label: 'Registration Checker' },
      { href: '/place-of-supply-calculator', label: 'Place of Supply' },
      { href: '/hsn-code-lookup', label: 'HSN Lookup' },
      { href: '/gstin-validator', label: 'GSTIN Validator' },
      { href: '/eway-bill-validity', label: 'E-Way Validity' },
      { href: '/pin-to-pin-distance-calculator', label: 'Pin to Pin Distance' },
      { href: '/gstr-2b-reconciliation-tool', label: 'GSTR-2B Tool' },
      { href: '/gst-state-codes', label: 'State Codes' },
    ]
  }
];

const currentPath = Astro.url.pathname;
---

<header
  class="print:hidden sticky top-0 z-50 w-full border-b border-base bg-white/90 dark:bg-[#0a0a0a]/90 backdrop-blur-md"
  role="banner"
>
  <div class="mx-auto max-w-7xl px-4 sm:px-6 lg:px-8">
    <div class="flex h-16 items-center justify-between">

      <!-- Logo / Brand -->
      <a
        href="/"
        class="flex items-center gap-2 font-semibold text-base hover:text-accent transition-colors shrink-0"
        aria-label="Taxzentic — Home"
      >
        <img
          src="/taxzentic-logo.png"
          alt="Taxzentic Logo"
          width="32"
          height="32"
          class="rounded-md object-contain"
        />
        <span class="text-xl font-bold tracking-tight">Taxzentic</span>
      </a>

      <!-- Desktop nav -->
      <nav class="hidden md:flex items-center gap-2" aria-label="Main navigation">
        <a href="/" class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${currentPath === '/' ? 'bg-subtle text-accent' : 'text-muted hover:text-base hover:bg-subtle'}`}>Home</a>
        
        {navCategories.map(cat => (
          <div class="relative group">
            <button class="flex items-center gap-1 px-3 py-2 rounded-md text-sm font-medium text-muted hover:text-base hover:bg-subtle transition-colors">
              {cat.title}
              <svg class="w-4 h-4 text-muted group-hover:text-base transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" /></svg>
            </button>
            
            <div class="absolute left-0 top-full hidden w-56 pt-2 group-hover:block z-50">
              <div class="rounded-md bg-surface border border-base shadow-xl py-2">
                {cat.links.map(link => (
                  <a href={link.href} class={`block px-4 py-2 text-sm transition-colors ${currentPath === link.href ? 'text-accent bg-subtle font-medium' : 'text-muted hover:text-base hover:bg-subtle'}`}>
                    {link.label}
                  </a>
                ))}
              </div>
            </div>
          </div>
        ))}

        <a href="/blog" class={`px-3 py-2 rounded-md text-sm font-medium transition-colors ${currentPath.startsWith('/blog') ? 'bg-subtle text-accent' : 'text-muted hover:text-base hover:bg-subtle'}`}>Blog</a>
      </nav>

      <!-- Right side: dark mode toggle + mobile menu button -->
      <div class="flex items-center gap-2 shrink-0">
        <!-- Dark mode toggle -->
        <button
          id="theme-toggle"
          type="button"
          aria-label="Toggle dark mode"
          class="rounded-md p-2 text-muted hover:text-base hover:bg-subtle transition-colors"
        >
          <!-- Sun icon (shown in dark mode) -->
          <svg id="icon-sun" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 8a4 4 0 1 0 0 8 4 4 0 0 0 0-8z" />
          </svg>
          <!-- Moon icon (shown in light mode) -->
          <svg id="icon-moon" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
          </svg>
        </button>

        <!-- Mobile hamburger -->
        <button
          id="mobile-menu-btn"
          type="button"
          aria-label="Open navigation menu"
          aria-expanded="false"
          aria-controls="mobile-menu"
          class="md:hidden rounded-md p-2 text-muted hover:text-base hover:bg-subtle transition-colors"
        >
          <svg id="icon-menu" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          <svg id="icon-close" class="hidden h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12" />
          </svg>
        </button>
      </div>
    </div>
  </div>

  <!-- Mobile menu (hidden by default) -->
  <div
    id="mobile-menu"
    class="hidden md:hidden border-b border-base bg-white/95 dark:bg-[#0a0a0a]/95 backdrop-blur-xl absolute w-full shadow-xl z-50 max-h-[calc(100vh-4rem)] overflow-y-auto"
    role="navigation"
    aria-label="Mobile navigation"
  >
    <div class="px-4 py-4 space-y-4">
      <a href="/" class={`block px-4 py-3 rounded-md text-[16px] font-medium transition-colors ${currentPath === '/' ? 'bg-subtle text-accent' : 'text-muted hover:text-base hover:bg-subtle'}`}>Home</a>
      
      {navCategories.map(cat => (
        <div>
          <div class="px-4 py-2 text-xs font-semibold text-base uppercase tracking-wider">{cat.title}</div>
          <div class="space-y-1 mt-1">
            {cat.links.map(link => (
              <a href={link.href} class={`block px-4 py-2.5 rounded-md text-[15px] font-medium transition-colors ${currentPath === link.href ? 'bg-subtle text-accent' : 'text-muted hover:text-base hover:bg-subtle'}`}>
                {link.label}
              </a>
            ))}
          </div>
        </div>
      ))}
      
      <a href="/blog" class={`block px-4 py-3 rounded-md text-[16px] font-medium transition-colors ${currentPath.startsWith('/blog') ? 'bg-subtle text-accent' : 'text-muted hover:text-base hover:bg-subtle'}`}>Blog</a>
    </div>
  </div>
</header>

<script>
  // ── Dark mode toggle ──────────────────────────────────────────────────────
  const html = document.documentElement;
  const themeBtn = document.getElementById('theme-toggle');
  const iconSun = document.getElementById('icon-sun');
  const iconMoon = document.getElementById('icon-moon');

  function applyTheme(dark) {
    html.classList.toggle('dark', dark);
    iconSun?.classList.toggle('hidden', !dark);
    iconMoon?.classList.toggle('hidden', dark);
    localStorage.setItem('theme', dark ? 'dark' : 'light');
  }

  // Initialise icons based on current state
  applyTheme(html.classList.contains('dark'));

  themeBtn?.addEventListener('click', () => {
    applyTheme(!html.classList.contains('dark'));
  });

  // ── Mobile menu toggle ────────────────────────────────────────────────────
  const mobileBtn = document.getElementById('mobile-menu-btn');
  const mobileMenu = document.getElementById('mobile-menu');
  const iconMenuEl = document.getElementById('icon-menu');
  const iconCloseEl = document.getElementById('icon-close');

  mobileBtn?.addEventListener('click', () => {
    const isOpen = mobileMenu?.classList.toggle('hidden') === false;
    mobileBtn.setAttribute('aria-expanded', String(isOpen));
    iconMenuEl?.classList.toggle('hidden', isOpen);
    iconCloseEl?.classList.toggle('hidden', !isOpen);
  });

  // Close mobile menu on nav link click
  mobileMenu?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      mobileMenu.classList.add('hidden');
      mobileBtn?.setAttribute('aria-expanded', 'false');
      iconMenuEl?.classList.remove('hidden');
      iconCloseEl?.classList.add('hidden');
    });
  });
</script>
